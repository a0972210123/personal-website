---
import BaseLayout from '../layouts/BaseLayout.astro';
import T from '../components/T.astro';

const SHEET_ID = '1vYSAfnbqFzLNBNcPY5dd8XRxvVozt1IDd-kIqKO5swA';
const AWARDS_URL       = `https://docs.google.com/spreadsheets/d/${SHEET_ID}/gviz/tq?tqx=out:csv&sheet=mentees_award_records`;
const TESTIMONIALS_URL = `https://docs.google.com/spreadsheets/d/${SHEET_ID}/gviz/tq?tqx=out:csv&gid=611725944`;
---
<BaseLayout
  title="Coaching — Matt Ye"
  description="葉淨維 Matt Ye 的競賽培訓成果。協助 MAIC、Falling Walls Lab 等學生團隊奪獎，獎金逾 127 萬。"
>
  <div class="container-wide">

    <!-- Hero -->
    <section class="coaching-hero">
      <h1><T zh="提案顧問與" en="Mentorship &" /> <span class="accent-text"><T zh="競賽培訓" en="Coaching" /></span></h1>
      <p class="coaching-subtitle">
        <T zh="協助學生團隊在國內外競賽中奪獎。" en="Helping student teams win awards in domestic and international competitions." /><br>
        <T zh="從提案結構到臨場表達，陪你走到舞台中央。" en="From proposal structure to on-stage delivery, guiding you to center stage." />
      </p>
    </section>

    <!-- Stats -->
    <div class="bento-grid coaching-stats-grid">
      <div class="bento-card">
        <div class="bento-card-label"><T zh="Teams Awarded" en="Teams Awarded" /></div>
        <div class="bento-card-num" id="c-teams">—</div>
        <div class="bento-card-sub"><T zh="MAIC 獲獎組數" en="MAIC award-winning teams" /></div>
      </div>
      <div class="bento-card">
        <div class="bento-card-label"><T zh="Prize Money" en="Prize Money" /></div>
        <div class="bento-card-num" id="c-prize">—</div>
        <div class="bento-card-sub"><T zh="學員獲獎總獎金（NTD）" en="Total prize money won (NTD)" /></div>
      </div>
      <div class="bento-card">
        <div class="bento-card-label"><T zh="Intl. Champions" en="Intl. Champions" /></div>
        <div class="bento-card-num" id="c-fw">—</div>
        <div class="bento-card-sub"><T zh="Falling Walls 得獎人次" en="Falling Walls award placements" /></div>
      </div>
    </div>

    <!-- MAIC Section -->
    <section class="coaching-section">
      <p class="section-heading"><T zh="行動應用創新賽" en="Mobile App Innovation Competition" /> <span class="section-heading-en">MAIC</span></p>
      <p class="coaching-section-desc">
        <T zh="Straight A × Apple 授權教育夥伴競賽培訓計畫。以提案結構、投影片設計、簡報表達三位一體為核心，協助學生團隊角逐亞太賽事獎項。" en="A competition coaching program by Straight A, an Apple Authorized Education Partner. Built around proposal structure, slide design, and delivery as a unified whole, helping student teams compete for Asia-Pacific honors." />
      </p>
      <div id="maic-container" class="maic-container">
        <div class="data-loading">載入中…</div>
      </div>
    </section>

    <!-- Falling Walls Section -->
    <section class="coaching-section">
      <p class="section-heading"><T zh="圍牆倒下實驗室" en="Falling Walls Lab" /> <span class="section-heading-en">Falling Walls Lab</span></p>
      <p class="coaching-section-desc">
        <T zh="協助學生以 3 分鐘英文學術簡報詮釋研究突破。台北賽事冠軍可晉級德國柏林國際決賽，與全球頂尖研究者同台競技。" en="Helping students present research breakthroughs in a 3-minute English academic pitch. Taipei winners advance to the international final in Berlin, Germany, competing alongside top researchers worldwide." />
      </p>
      <div id="fw-container" class="fw-container">
        <div class="data-loading">載入中…</div>
      </div>
    </section>

    <!-- Testimonials Carousel -->
    <section class="coaching-section">
      <p class="section-heading"><T zh="學生怎麼說" en="What Students Say" /></p>
      <div class="testi-carousel" id="testi-carousel">
        <div class="testi-track" id="testi-track">
          <div class="data-loading">載入中…</div>
        </div>
        <div class="testi-nav" id="testi-nav" style="display:none">
          <button class="testi-arrow" id="testi-prev" aria-label="上一則">‹</button>
          <div class="testi-dots" id="testi-dots"></div>
          <button class="testi-arrow" id="testi-next" aria-label="下一則">›</button>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="coaching-cta-section">
      <p class="coaching-cta-text"><T zh="想為你的團隊安排競賽培訓？" en="Want to arrange competition coaching for your team?" /></p>
      <a href="mailto:f08429008@ntu.edu.tw" class="hero-cta"><T zh="合作洽詢 →" en="Get in touch →" /></a>
    </section>

  </div>
</BaseLayout>

<script define:vars={{ AWARDS_URL, TESTIMONIALS_URL }}>
/* ── CSV Parser ── */
function parseCSV(text) {
  const rows = [], t = text.replace(/\r\n/g,'\n').replace(/\r/g,'\n');
  let row = [], cur = '', inQ = false;
  for (let i = 0; i < t.length; i++) {
    const c = t[i];
    if (c === '"') { if (inQ && t[i+1]==='"') { cur+='"'; i++; } else inQ=!inQ; }
    else if (c===',' && !inQ) { row.push(cur.trim()); cur=''; }
    else if (c==='\n' && !inQ) { row.push(cur.trim()); if (row.some(v=>v)) rows.push(row); row=[]; cur=''; }
    else cur+=c;
  }
  if (cur||row.length) { row.push(cur.trim()); rows.push(row); }
  return rows;
}
function makeHI(rows) {
  const h = rows[0].map(v => v.toLowerCase().trim());
  return name => h.findIndex(v => v.includes(name.toLowerCase()));
}

/* ── Medal helper ── */
function medalEmoji(award) {
  if (award.includes('一等') || award.includes('1st')) return '🥇';
  if (award.includes('二等') || award.includes('2nd')) return '🥈';
  if (award.includes('三等') || award.includes('3rd')) return '🥉';
  return '🏅';
}

/* ── Prize parser: "約22.95萬" → 229500 ── */
function parsePrize(str) {
  if (!str) return 0;
  const m = str.replace(/,/g,'').match(/[\d.]+/);
  if (!m) return 0;
  const n = parseFloat(m[0]);
  return str.includes('萬') ? n * 10000 : n;
}

/* ── Format NTD ── */
function fmtNTD(n) {
  if (n >= 1000000) return `${(n/10000).toFixed(0)} 萬`;
  if (n >= 10000)   return `${(n/10000).toFixed(1)} 萬`;
  return String(Math.round(n));
}

/* ── Count-up ── */
function countUp(el, finalVal, dur, formatter) {
  if (!el || isNaN(finalVal)) return;
  const fmt = formatter || (v => Math.round(v));
  const start = performance.now();
  const step = now => {
    const t = Math.min((now - start) / dur, 1);
    const ease = 1 - Math.pow(1 - t, 3);
    el.textContent = fmt(finalVal * ease);
    if (t < 1) requestAnimationFrame(step);
    else el.textContent = fmt(finalVal);
  };
  requestAnimationFrame(step);
}

/* ── Render MAIC ── */
function renderMAIC(rows) {
  const byYear = {};
  rows.forEach(r => {
    if (!byYear[r.year]) byYear[r.year] = [];
    byYear[r.year].push(r);
  });

  const el = document.getElementById('maic-container');
  if (!el) return;
  el.innerHTML = '';

  Object.keys(byYear).sort().forEach(year => {
    const entries = byYear[year];
    const totalTeams = entries.reduce((s, r) => s + r.teams, 0);
    const totalPrize = entries.reduce((s, r) => s + parsePrize(r.prize) * r.teams, 0);

    const block = document.createElement('div');
    block.className = 'maic-year-block';

    const awardRows = entries.map(e => `
      <div class="maic-award-row">
        <span class="maic-medal">${medalEmoji(e.award)}</span>
        <span class="maic-award-name">${e.award}</span>
        <span class="maic-teams-x">×${e.teams} 組</span>
        <span class="maic-prize-tag">${e.prize} / 組</span>
      </div>
    `).join('');

    block.innerHTML = `
      <div class="maic-year-header">
        <span class="maic-year-label">${year}</span>
        <span class="maic-year-meta">${totalTeams} 組獲獎 · 獎金合計約 NT$ ${fmtNTD(totalPrize)}</span>
      </div>
      <div class="maic-award-list">${awardRows}</div>
    `;
    el.appendChild(block);
  });
}

/* ── Render Falling Walls ── */
function renderFW(rows) {
  /* Group by year + person name (extracted from 報導連結) */
  const byKey = {};
  rows.forEach(r => {
    const parts = r.report.split('｜');
    const rawName = (parts[1] || '').trim();
    const name = rawName.replace(/\(.*?\)/g, '').trim() || '—';
    const topic = (parts[2] || '').trim();
    const key = r.year + '||' + name;
    if (!byKey[key]) byKey[key] = { year: r.year, name, topic, venues: [] };
    const isBerlin = r.contestName.toLowerCase().includes('berlin');
    byKey[key].venues.push({ venue: isBerlin ? 'Berlin' : 'Taipei', award: r.award });
    if (topic && !byKey[key].topic) byKey[key].topic = topic;
  });

  const el = document.getElementById('fw-container');
  if (!el) return;
  el.innerHTML = '';

  Object.values(byKey).sort((a, b) => a.year.localeCompare(b.year)).forEach(p => {
    const hasBerlin = p.venues.some(v => v.venue === 'Berlin');
    const venueHTML = p.venues.map(v =>
      `<span class="fw-venue-tag">${v.venue === 'Berlin' ? '🇩🇪' : '🇹🇼'} ${v.venue} · ${v.award}</span>`
    ).join('<span class="fw-venue-arrow">→</span>');

    const card = document.createElement('div');
    card.className = 'fw-card' + (hasBerlin ? ' fw-card-featured' : '');
    card.innerHTML = `
      <div class="fw-card-left">
        <div class="fw-year-badge">${p.year}</div>
      </div>
      <div class="fw-card-body">
        <div class="fw-name-row">
          <span class="fw-name">${p.name}</span>
          ${hasBerlin ? '<span class="fw-intl-badge">🌍 International Champion</span>' : ''}
        </div>
        <div class="fw-venues">${venueHTML}</div>
        ${p.topic ? `<div class="fw-topic">"${p.topic}"</div>` : ''}
      </div>
    `;
    el.appendChild(card);
  });
}

/* ── Main load ── */
async function loadAwards() {
  try {
    const resp = await fetch(AWARDS_URL);
    const text = await resp.text();
    const rows = parseCSV(text);
    if (!rows.length) return;

    const hi = makeHI(rows);
    const iName  = hi('競賽名稱');
    const iCName = hi('contest name');
    const iAbbr  = hi('abbreviation');
    const iYear  = hi('年分');
    const iAward = hi('獎項');
    const iPrize = hi('獎金');
    const iTeams = hi('組數');
    const iRpt   = hi('報導') >= 0 ? hi('報導') : hi('url');

    const data = rows.slice(1).map(r => ({
      name:        (r[iName]  || '').trim(),
      contestName: (r[iCName] || '').trim(),
      abbr:        (r[iAbbr]  || '').trim(),
      year:        (r[iYear]  || '').trim(),
      award:       (r[iAward] || '').trim(),
      prize:       (r[iPrize] || '').trim(),
      teams:       parseInt(r[iTeams] || '0') || 0,
      report:      (r[iRpt]   || '').trim(),
    })).filter(r => r.name && r.year);

    const maic = data.filter(r => r.abbr === 'MAIC' || r.name.includes('行動應用'));
    const fw   = data.filter(r => r.name.includes('圍牆'));

    renderMAIC(maic);
    renderFW(fw);

    /* Stats */
    const totalTeams  = maic.reduce((s, r) => s + r.teams, 0);
    const totalPrize  = maic.reduce((s, r) => s + parsePrize(r.prize) * r.teams, 0);
    const fwCount     = fw.length; // each row = one placement

    countUp(document.getElementById('c-teams'), totalTeams, 1200);
    countUp(document.getElementById('c-prize'), totalPrize, 1600,
      v => v >= 10000 ? `${(v/10000).toFixed(0)} 萬` : Math.round(v));
    countUp(document.getElementById('c-fw'), fwCount, 800);

  } catch (e) {
    console.error('Coaching data error:', e);
    ['maic-container','fw-container'].forEach(id => {
      const el = document.getElementById(id);
      if (el) el.innerHTML = '<div class="data-error">⚠️ 資料載入失敗</div>';
    });
  }
}

/* ── Testimonials: fetch from Sheet then init carousel ── */
async function loadTestimonials() {
  const track = document.getElementById('testi-track');
  const dotsEl = document.getElementById('testi-dots');
  const nav = document.getElementById('testi-nav');
  if (!track) return;

  try {
    const resp = await fetch(TESTIMONIALS_URL);
    const text = await resp.text();
    const rows = parseCSV(text);
    if (rows.length < 2) { track.innerHTML = ''; return; }

    const hi = makeHI(rows);
    const iQuote   = hi('quote');
    const iContext = hi('context');
    const iShow    = hi('show');

    const data = rows.slice(1)
      .map(r => ({ quote: (r[iQuote] || '').trim(), context: (r[iContext] || '').trim(), show: (r[iShow] || '').trim().toUpperCase() }))
      .filter(r => r.quote && (iShow < 0 || r.show === 'TRUE'));

    if (!data.length) { track.innerHTML = ''; return; }

    track.innerHTML = data.map((t, i) => `
      <div class="testi-slide${i === 0 ? ' active' : ''}">
        <div class="testi-quote-mark">❝</div>
        <p class="testi-quote">${t.quote}</p>
        <div class="testi-context">— ${t.context}</div>
      </div>
    `).join('');

    if (dotsEl) {
      dotsEl.innerHTML = data.map((_, i) =>
        `<button class="testi-dot${i === 0 ? ' active' : ''}" aria-label="第 ${i+1} 則"></button>`
      ).join('');
    }

    if (nav) nav.style.display = '';

    /* Init carousel */
    const slides = track.querySelectorAll('.testi-slide');
    const dots   = dotsEl ? dotsEl.querySelectorAll('.testi-dot') : [];
    let cur = 0;

    function goTo(n) {
      slides[cur].classList.remove('active');
      if (dots[cur]) dots[cur].classList.remove('active');
      cur = (n + slides.length) % slides.length;
      slides[cur].classList.add('active');
      if (dots[cur]) dots[cur].classList.add('active');
    }

    document.getElementById('testi-prev')?.addEventListener('click', () => goTo(cur - 1));
    document.getElementById('testi-next')?.addEventListener('click', () => goTo(cur + 1));
    dots.forEach((d, i) => d.addEventListener('click', () => goTo(i)));

    let timer = setInterval(() => goTo(cur + 1), 5000);
    document.getElementById('testi-carousel')?.addEventListener('mouseenter', () => clearInterval(timer));
    document.getElementById('testi-carousel')?.addEventListener('mouseleave', () => {
      timer = setInterval(() => goTo(cur + 1), 5000);
    });

  } catch (e) {
    if (track) track.innerHTML = '';
  }
}

loadAwards();
loadTestimonials();
</script>
