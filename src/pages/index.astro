---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);

const SHEET_ID = '1vYSAfnbqFzLNBNcPY5dd8XRxvVozt1IDd-kIqKO5swA';
const CSV_URL = `https://docs.google.com/spreadsheets/d/${SHEET_ID}/gviz/tq?tqx=out:csv&gid=0`;

// Key experience roles (curated)
const roles = [
  {
    icon: '🎓',
    org: 'National Taiwan University',
    orgZh: '國立臺灣大學',
    title: 'PhD Researcher — AI & Handwriting Diagnostics',
    desc: '研究 AI 輔助的手寫動作分析，用於輕度認知障礙（MCI）與阿茲海默症的早期偵測。已發表 6 篇 SCI/SSCI 期刊論文，含 2 篇國際研討會最佳口頭報告獎。',
    period: '2019 – 現在',
  },
  {
    icon: '📣',
    org: 'CAPE 起駛簡報表達教育協會',
    orgZh: 'Cheese Association of Presentation Education',
    title: '理事 · 課程研發組長',
    desc: '共同設計三套模組化簡報課程（邏輯、設計、表達），帶領團隊前往偏鄉國高中實地授課，推廣到更多資源不足的地區。',
    period: '2022 – 現在',
  },
  {
    icon: '🍎',
    org: 'Straight A × Apple Education',
    orgZh: '晶盛科技（蘋果授權教育夥伴）',
    title: 'MAIC 競賽提案培訓講師',
    desc: '負責 2024–2026 年行動應用創新競賽（MAIC）賽前培訓工作坊。2024 年協助培訓的台灣代表隊於亞太賽事獲獎。',
    period: '2024 – 2026',
  },
