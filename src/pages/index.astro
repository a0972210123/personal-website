---
import BaseLayout from '../layouts/BaseLayout.astro';
import T from '../components/T.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);

const SHEET_ID = '1vYSAfnbqFzLNBNcPY5dd8XRxvVozt1IDd-kIqKO5swA';
const CSV_URL       = `https://docs.google.com/spreadsheets/d/${SHEET_ID}/gviz/tq?tqx=out:csv&gid=0`;
const CONTENT_URL   = `https://docs.google.com/spreadsheets/d/${SHEET_ID}/gviz/tq?tqx=out:csv&sheet=site_content`;
const STRENGTHS_URL = `https://docs.google.com/spreadsheets/d/${SHEET_ID}/gviz/tq?tqx=out:csv&sheet=core_strengths`;
const ROLES_URL     = `https://docs.google.com/spreadsheets/d/${SHEET_ID}/gviz/tq?tqx=out:csv&sheet=experience_roles`;
---
<BaseLayout
  title="葉淨維 Matt Ye"
  description="葉淨維 Ching-Wei (Matt) Ye — 職能治療師、研究者、溝通教育者。PhD @ NTU，150+ 場演講，專注 AI 輔助診斷與簡報教育。"
>
  <div class="container-wide">

    <!-- ① Hero -->
    <section class="hero-section">
      <div class="hero-text">
        <h1>
          葉淨維
          <span class="name-en">Ching-Wei (Matt) Ye</span>
        </h1>
        <p class="hero-tagline" id="hero-tagline"></p>
        <div class="hero-tags">
          <span class="hero-tag">🧠 <T zh="AI ＆認知科學研究" en="AI &amp; Cognitive Science Research" /></span>
          <span class="hero-tag">🎤 <T zh="150+ 場演講" en="150+ Talks Delivered" /></span>
          <span class="hero-tag">🎓 NTU PhD Candidate</span>
          <span class="hero-tag">🏆 <T zh="3MT 冠軍" en="3MT Champion" /></span>
        </div>
        <div class="hero-actions">
          <a href="mailto:f08429008@ntu.edu.tw" class="hero-cta">
            <T zh="合作洽詢 →" en="Get in Touch →" />
          </a>
          <div class="hero-social">
            <a href="https://www.instagram.com/brown.yeh" target="_blank" rel="noopener" aria-label="Instagram" class="social-icon-btn">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
              </svg>
            </a>
            <a href="https://www.linkedin.com/in/ching-wei-ye" target="_blank" rel="noopener" aria-label="LinkedIn" class="social-icon-btn">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/>
              </svg>
            </a>
            <a href="https://orcid.org/0009-0001-6085-8303" target="_blank" rel="noopener" aria-label="ORCID" class="social-icon-btn">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 0C5.372 0 0 5.372 0 12s5.372 12 12 12 12-5.372 12-12S18.628 0 12 0zM7.369 4.378c.525 0 .947.431.947.947s-.422.947-.947.947a.947.947 0 0 1 0-1.894zm-.722 3.038h1.444v10.041H6.647V7.416zm3.562 0h3.9c3.712 0 5.344 2.653 5.344 5.025 0 2.578-2.016 5.016-5.325 5.016h-3.919V7.416zm1.444 1.303v7.444h2.297c2.359 0 3.9-1.609 3.9-3.722 0-2.016-1.453-3.722-3.866-3.722h-2.331z"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
      <div class="hero-photo-wrap">
        <div class="hero-carousel" id="hero-carousel">
          <div class="carousel-slide active">
            <img src="/photo-pointing.jpg" alt="葉淨維 Matt Ye — 演講姿態" />
          </div>
          <div class="carousel-slide">
            <img src="/photo-standing.jpg" alt="葉淨維 Matt Ye — 站姿" />
          </div>
          <div class="carousel-slide">
            <img src="/photo-5.jpg" alt="葉淨維 Matt Ye — 笑容" />
          </div>
        </div>
        <div class="carousel-dots">
          <button class="carousel-dot active" aria-label="Photo 1"></button>
          <button class="carousel-dot" aria-label="Photo 2"></button>
          <button class="carousel-dot" aria-label="Photo 3"></button>
        </div>
      </div>
    </section>

    <!-- ② Bento Stats -->
    <section style="margin-bottom: var(--spacing-xl)">
      <p class="section-heading"><T zh="數字看見" en="By the Numbers" /></p>
      <div class="bento-grid">
        <div class="bento-card">
          <div class="bento-card-label"><T zh="演講場次" en="Speeches" /></div>
          <div class="bento-card-num" id="h-total">—</div>
          <div class="bento-card-sub"><T zh="場次累計" en="Total sessions" /></div>
        </div>
        <div class="bento-card">
          <div class="bento-card-label"><T zh="講台時數" en="Hours" /></div>
          <div class="bento-card-num" id="h-hours">—</div>
          <div class="bento-card-sub"><T zh="講台時數" en="Hours on stage" /></div>
        </div>
        <div class="bento-card">
          <div class="bento-card-label"><T zh="觸及人次" en="Audience" /></div>
          <div class="bento-card-num" id="h-audience">—</div>
          <div class="bento-card-sub"><T zh="觸及人次" en="People reached" /></div>
        </div>
        <div class="bento-card">
          <div class="bento-card-label"><T zh="出版著作" en="Publications" /></div>
          <div class="bento-card-num" id="h-pubs">2</div>
          <div class="bento-card-sub">SCIE · SSCI</div>
          <a href="https://orcid.org/0009-0001-6085-8303" target="_blank" rel="noopener" class="bento-orcid-link">ORCID ↗</a>
        </div>
      </div>
    </section>

    <!-- ③ Three Pillars (dynamic from Sheet: core_strengths) -->
    <section style="margin-bottom: var(--spacing-xl)">
      <p class="section-heading"><T zh="核心優勢" en="Core Strengths" /></p>
      <div class="pillars-grid" id="pillars-grid">
        <div class="data-loading"><T zh="載入中…" en="Loading…" /></div>
      </div>
    </section>

    <!-- ④ Experience Roles (dynamic from Sheet: experience_roles) -->
    <section style="margin-bottom: var(--spacing-xl)">
      <p class="section-heading"><T zh="經歷 & 角色" en="Experience &amp; Roles" /></p>
      <div class="roles-list" id="roles-list">
        <div class="data-loading"><T zh="載入中…" en="Loading…" /></div>
      </div>
    </section>

    <!-- ⑤ Partners / Organizations (dynamic from Sheet) -->
    <section class="partners-section">
      <p class="section-heading"><T zh="主要合作單位" en="Top Collaborating Organizations" /></p>
      <div class="partners-orgs-grid" id="partners-grid">
        <div class="data-loading"><T zh="載入中…" en="Loading…" /></div>
      </div>
      <a href="/speeches" class="section-cta" style="margin-top:1rem"><T zh="查看所有演講 →" en="View all speeches →" /></a>
    </section>

    <!-- ⑥ Recent Writing -->
    {posts.length > 0 && (
      <section style="margin-top: var(--spacing-xl)">
        <p class="section-heading"><T zh="近期文章" en="Recent Writing" /></p>
        <ul class="post-list">
          {posts.map(post => (
            <PostCard
              id={post.id}
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              lang={post.data.lang}
            />
          ))}
        </ul>
        <a href="/writing" class="section-cta"><T zh="所有文章 →" en="All posts →" /></a>
      </section>
    )}

  </div>
</BaseLayout>

<script>
/* ── Hero Photo Carousel ── */
(function () {
  var slides = document.querySelectorAll('#hero-carousel .carousel-slide');
  var dots   = document.querySelectorAll('.carousel-dots .carousel-dot');
  if (!slides.length) return;

  var current = 0;

  function goTo(n) {
    slides[current].classList.remove('active');
    dots[current].classList.remove('active');
    current = (n + slides.length) % slides.length;
    slides[current].classList.add('active');
    dots[current].classList.add('active');
  }

  // Auto-advance every 4 seconds
  var timer = setInterval(function () { goTo(current + 1); }, 4000);

  // Dot click → jump + reset timer
  dots.forEach(function (dot, i) {
    dot.addEventListener('click', function () {
      clearInterval(timer);
      goTo(i);
      timer = setInterval(function () { goTo(current + 1); }, 4000);
    });
  });

  // Pause on hover
  var carousel = document.getElementById('hero-carousel');
  if (carousel) {
    carousel.addEventListener('mouseenter', function () { clearInterval(timer); });
    carousel.addEventListener('mouseleave', function () {
      timer = setInterval(function () { goTo(current + 1); }, 4000);
    });
  }
})();
</script>

<script define:vars={{ CSV_URL, CONTENT_URL, STRENGTHS_URL, ROLES_URL }}>
/* ── Count-up animation ── */
function countUp(el, finalVal, dur) {
  if (!el || isNaN(finalVal)) return;
  var fmt = finalVal >= 1000
    ? function(v) { return (v / 1000).toFixed(1) + 'K'; }
    : function(v) { return Math.round(v); };
  var start = performance.now();
  requestAnimationFrame(function step(now) {
    var t = Math.min((now - start) / dur, 1);
    var ease = 1 - Math.pow(1 - t, 3);
    el.textContent = fmt(finalVal * ease);
    if (t < 1) requestAnimationFrame(step);
    else el.textContent = fmt(finalVal);
  });
}

/* ── Robust CSV parser ── */
function parseCSV(text) {
  var rows = [], row = [], cur = '', inQ = false;
  var t = text.replace(/\r\n/g, '\n').replace(/\r/g, '\n');
  for (var i = 0; i < t.length; i++) {
    var c = t[i];
    if (c === '"') {
      if (inQ && t[i+1] === '"') { cur += '"'; i++; }
      else inQ = !inQ;
    } else if (c === ',' && !inQ) {
      row.push(cur.trim()); cur = '';
    } else if (c === '\n' && !inQ) {
      row.push(cur.trim());
      if (row.some(function(v) { return v; })) rows.push(row);
      row = []; cur = '';
    } else { cur += c; }
  }
  if (cur || row.length) { row.push(cur.trim()); rows.push(row); }
  return rows;
}

function makeHI(rows) {
  var headers = rows[0].map(function(h) { return h.toLowerCase().trim(); });
  return function(name) {
    return headers.findIndex(function(h) { return h.includes(name.toLowerCase()); });
  };
}

/* ── i18n helpers ── */
function lang() { return document.documentElement.getAttribute('data-lang') === 'en' ? 'en' : 'zh'; }
function pick(zh, en) { return (lang() === 'en' && en) ? en : (zh || en || ''); }

/* render hooks set after each sheet loads; re-invoked on langchange */
var contentRender = null, strengthsRender = null, rolesRender = null;

/* ── Speeches sheet: stats + partners leaderboard ── */
function loadSpeeches() {
  fetch(CSV_URL)
    .then(function(r) { return r.text(); })
    .then(function(text) {
      var allRows = parseCSV(text);
      if (!allRows.length) return;
      var hi = makeHI(allRows);
      var iDate = hi('日期'), iOrg = hi('主辦單位_zh'), iOrgEn = hi('主辦單位_eng');
      var iCoOrg1 = hi('協辦單位_1_zh'), iCoOrg1En = hi('協辦單位_1_eng');
      var iCoOrg2 = hi('協辦單位_2_zh'), iCoOrg2En = hi('協辦單位_2_eng');
      var iTopic = hi('主題'), iType = hi('場次類型');
      var iAudience = hi('人數'), iHours = hi('小時');

      var EXCLUDED = ['彩排', '教材製作'];
      var rows = allRows.slice(1).filter(function(r) {
        return (r[iDate] || '').trim() && (r[iTopic] || '').trim() &&
               EXCLUDED.indexOf((r[iType] || '').trim()) === -1;
      });

      var total = rows.length;
      var hours = rows.reduce(function(s, r) { return s + (parseFloat(r[iHours]) || 0); }, 0);
      var audience = rows.reduce(function(s, r) { return s + (parseInt(r[iAudience]) || 0); }, 0);

      countUp(document.getElementById('h-total'),    total,              1400);
      countUp(document.getElementById('h-hours'),    Math.round(hours),  1400);
      countUp(document.getElementById('h-audience'), audience,           1600);
      countUp(document.getElementById('h-pubs'),     2,                   800);

      /* Partners leaderboard */
      var orgMap = {};
      for (var i = 0; i < rows.length; i++) {
        var orgsInRow = [
          { zh: (rows[i][iOrg] || '').trim(),    eng: iOrgEn    >= 0 ? (rows[i][iOrgEn]    || '').trim() : '' },
          { zh: iCoOrg1   >= 0 ? (rows[i][iCoOrg1]   || '').trim() : '', eng: iCoOrg1En  >= 0 ? (rows[i][iCoOrg1En]  || '').trim() : '' },
          { zh: iCoOrg2   >= 0 ? (rows[i][iCoOrg2]   || '').trim() : '', eng: iCoOrg2En  >= 0 ? (rows[i][iCoOrg2En]  || '').trim() : '' },
        ];
        for (var p = 0; p < orgsInRow.length; p++) {
          var zh = orgsInRow[p].zh, eng = orgsInRow[p].eng;
          if (!zh) continue;
          if (!orgMap[zh]) orgMap[zh] = { count: 0, eng: '' };
          orgMap[zh].count++;
          if (!orgMap[zh].eng && eng) orgMap[zh].eng = eng;
        }
      }
      var ranked = Object.keys(orgMap)
        .map(function(k) { return [k, orgMap[k]]; })
        .sort(function(a, b) { return b[1].count - a[1].count; })
        .slice(0, 5);
      var maxCount = ranked.length ? ranked[0][1].count : 1;

      var grid = document.getElementById('partners-grid');
      if (!grid) return;
      grid.innerHTML = '';
      for (var j = 0; j < ranked.length; j++) {
        var name = ranked[j][0], info = ranked[j][1];
        var pct = (info.count / maxCount) * 100;
        var rowEl = document.createElement('div');
        rowEl.className = 'org-row';
        rowEl.innerHTML =
          '<span class="org-rank' + (j < 3 ? ' org-rank-top' : '') + '">' + String(j+1).padStart(2,'0') + '</span>' +
          '<span class="org-name"><span class="org-name-zh">' + name + '</span>' +
          (info.eng ? '<span class="org-name-en">' + info.eng + '</span>' : '') + '</span>' +
          '<span class="org-bar-bg"><span class="org-bar" data-width="' + pct + '"></span></span>' +
          '<span class="org-count">' + info.count + '</span>';
        grid.appendChild(rowEl);
      }
      requestAnimationFrame(function() {
        requestAnimationFrame(function() {
          grid.querySelectorAll('.org-bar').forEach(function(b) {
            b.style.width = b.dataset.width + '%';
          });
        });
      });
    })
    .catch(function() {
      var grid = document.getElementById('partners-grid');
      if (grid) grid.innerHTML = '';
    });
}

/* ── site_content: hero tagline ── */
function loadContent() {
  fetch(CONTENT_URL)
    .then(function(r) { return r.text(); })
    .then(function(text) {
      var rows = parseCSV(text);
      /* Build key → value map (header row is row[0], skip it) */
      var kv = {};
      rows.slice(1).forEach(function(r) {
        var key = (r[0] || '').trim();
        var val = (r[1] || '').trim();
        if (key) kv[key] = val;
      });

      /* Hero tagline: collect base hero_tagline_line* keys (skip _eng), sort, pick by lang */
      var taglineEl = document.getElementById('hero-tagline');
      contentRender = function() {
        if (!taglineEl) return;
        var lines = Object.keys(kv)
          .filter(function(k) { return k.indexOf('hero_tagline_line') === 0 && k.indexOf('_eng') === -1; })
          .sort()
          .map(function(k) { return pick(kv[k], kv[k + '_eng']); })
          .filter(Boolean);
        taglineEl.innerHTML = lines.join('<br>');
      };
      contentRender();
    })
    .catch(function() { /* silent fail — tagline stays empty */ });
}

/* ── core_strengths: pillar cards ── */
function loadStrengths() {
  fetch(STRENGTHS_URL)
    .then(function(r) { return r.text(); })
    .then(function(text) {
      var rows = parseCSV(text);
      if (rows.length < 2) return;
      var hi = makeHI(rows);
      var iSort = hi('排序'), iIcon = hi('icon'), iTitle = hi('title'), iDesc = hi('description');
      var iTitleEn = hi('title_eng'), iDescEn = hi('description_eng');

      var data = rows.slice(1)
        .filter(function(r) { return (r[iTitle] || '').trim(); })
        .sort(function(a, b) {
          return (parseInt(a[iSort]) || 99) - (parseInt(b[iSort]) || 99);
        });

      var grid = document.getElementById('pillars-grid');
      if (!grid) return;
      strengthsRender = function() {
        grid.innerHTML = '';
        data.forEach(function(r) {
          var card = document.createElement('div');
          card.className = 'pillar-card';
          card.innerHTML =
            '<div class="pillar-icon">' + (r[iIcon] || '') + '</div>' +
            '<div class="pillar-title">' + pick(r[iTitle], iTitleEn >= 0 ? r[iTitleEn] : '') + '</div>' +
            '<p class="pillar-desc">' + pick(r[iDesc], iDescEn >= 0 ? r[iDescEn] : '') + '</p>';
          grid.appendChild(card);
        });
      };
      strengthsRender();
    })
    .catch(function() {
      var g = document.getElementById('pillars-grid');
      if (g) g.innerHTML = '';
    });
}

/* ── experience_roles: role cards ── */
function loadRoles() {
  fetch(ROLES_URL)
    .then(function(r) { return r.text(); })
    .then(function(text) {
      var rows = parseCSV(text);
      if (rows.length < 2) return;
      var hi = makeHI(rows);
      var iSort   = hi('排序');
      var iIcon   = hi('icon');
      var iOrgZh  = hi('org_zh');
      var iOrgEn  = hi('org_en');
      var iTitle  = hi('title');
      var iDesc   = hi('description');
      var iDescEn = hi('description_eng');
      var iPeriod = hi('period');

      var data = rows.slice(1)
        .filter(function(r) { return (r[iOrgZh] || '').trim() || (r[iTitle] || '').trim(); })
        .sort(function(a, b) {
          return (parseInt(a[iSort]) || 99) - (parseInt(b[iSort]) || 99);
        });

      var list = document.getElementById('roles-list');
      if (!list) return;
      rolesRender = function() {
        list.innerHTML = '';
        data.forEach(function(r) {
          var card = document.createElement('div');
          card.className = 'role-card';
          var orgZh  = (r[iOrgZh]  || '').trim();
          var orgEn  = (r[iOrgEn]  || '').trim();
          var period = (r[iPeriod] || '').trim();
          card.innerHTML =
            '<div class="role-icon-box">' + (r[iIcon] || '') + '</div>' +
            '<div class="role-body">' +
              '<div class="role-org">' + orgZh + (orgEn ? ' <span class="role-org-en">· ' + orgEn + '</span>' : '') + '</div>' +
              '<div class="role-title">' + (r[iTitle] || '') + '</div>' +
              '<div class="role-desc">'  + pick(r[iDesc], iDescEn >= 0 ? r[iDescEn] : '') + '</div>' +
            '</div>' +
            (period ? '<div class="role-period">' + period + '</div>' : '');
          list.appendChild(card);
        });
      };
      rolesRender();
    })
    .catch(function() {
      var l = document.getElementById('roles-list');
      if (l) l.innerHTML = '';
    });
}

/* ── Run all ── */
loadSpeeches();
loadContent();
loadStrengths();
loadRoles();

window.addEventListener('langchange', function() {
  if (contentRender) contentRender();
  if (strengthsRender) strengthsRender();
  if (rolesRender) rolesRender();
});
</script>
