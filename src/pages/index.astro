          </p>
        </div>
      </div>
    </section>

    <!-- ④ Experience Roles -->
    <section style="margin-bottom: var(--spacing-xl)">
      <p class="section-heading">Experience &amp; Roles</p>
      <div class="roles-list">
        {roles.map(r => (
          <div class="role-card">
            <div class="role-icon-box">{r.icon}</div>
            <div class="role-body">
              <div class="role-org">{r.org}</div>
              <div class="role-title">{r.title}</div>
              <div class="role-desc">{r.desc}</div>
            </div>
            <div class="role-period">{r.period}</div>
          </div>
        ))}
      </div>
    </section>

    <!-- ⑤ Partners / Organizations (dynamic from Sheet) -->
    <section class="partners-section">
      <p class="section-heading">Top collaborating organizations</p>
      <div class="partners-orgs-grid" id="partners-grid">
        <div class="data-loading">Loading…</div>
      </div>
      <a href="/speeches" class="section-cta" style="margin-top:1rem">View all speeches →</a>
    </section>

    <!-- ⑥ Recent Writing -->
    {posts.length > 0 && (
      <section style="margin-top: var(--spacing-xl)">
        <p class="section-heading">Recent Writing</p>
        <ul class="post-list">
          {posts.map(post => (
            <PostCard
              id={post.id}
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              lang={post.data.lang}
            />
          ))}
        </ul>
        <a href="/writing" class="section-cta">All posts →</a>
      </section>
    )}

  </div>
</BaseLayout>

<script>
/* ── Hero Photo Carousel ── */
(function () {
  var slides = document.querySelectorAll('#hero-carousel .carousel-slide');
  var dots   = document.querySelectorAll('.carousel-dots .carousel-dot');
  if (!slides.length) return;

  var current = 0;

  function goTo(n) {
    slides[current].classList.remove('active');
    dots[current].classList.remove('active');
    current = (n + slides.length) % slides.length;
    slides[current].classList.add('active');
    dots[current].classList.add('active');
  }

  // Auto-advance every 4 seconds
  var timer = setInterval(function () { goTo(current + 1); }, 4000);

  // Dot click → jump + reset timer
  dots.forEach(function (dot, i) {
    dot.addEventListener('click', function () {
      clearInterval(timer);
      goTo(i);
      timer = setInterval(function () { goTo(current + 1); }, 4000);
    });
  });

  // Pause on hover
  var carousel = document.getElementById('hero-carousel');
  if (carousel) {
    carousel.addEventListener('mouseenter', function () { clearInterval(timer); });
    carousel.addEventListener('mouseleave', function () {
      timer = setInterval(function () { goTo(current + 1); }, 4000);
    });
  }
})();
</script>

<script define:vars={{ CSV_URL, orgDomains }}>
/* Robust CSV parser — handles quoted multi-line cells */
function parseCSV(text) {
  var rows = [], row = [], cur = '', inQ = false;
  var t = text.replace(/\r\n/g, '\n').replace(/\r/g, '\n');
  for (var i = 0; i < t.length; i++) {
    var c = t[i];
    if (c === '"') {
      if (inQ && t[i+1] === '"') { cur += '"'; i++; }
      else inQ = !inQ;
    } else if (c === ',' && !inQ) {
      row.push(cur.trim()); cur = '';
    } else if (c === '\n' && !inQ) {
      row.push(cur.trim());
      if (row.some(function(v) { return v; })) rows.push(row);
      row = []; cur = '';
    } else {
      cur += c;
    }
  }
  if (cur || row.length) { row.push(cur.trim()); rows.push(row); }
  return rows;
}

/* Get domain for an org name */
function getDomain(orgName) {
  var keys = Object.keys(orgDomains);
  for (var i = 0; i < keys.length; i++) {
    if (orgName.indexOf(keys[i]) !== -1) return orgDomains[keys[i]];
  }
  return null;
}

/* Shorten org name for display */
function shortName(name) {
  if (!name) return '';
  var enMatch = name.match(/\(([A-Z][A-Z\s\-]{1,12})\)/);
  if (enMatch) return enMatch[1];
  name = name.replace(/^(國立|社團法人|財團法人|台灣|臺灣)/, '');
  return name.length > 18 ? name.substring(0, 16) + '…' : name;
}

(function () {
  fetch(CSV_URL)
    .then(function(r) { return r.text(); })
    .then(function(text) {
      var allRows = parseCSV(text);
      if (!allRows.length) return;

      /* Build header index — find column by name, not by hardcoded position */
      var headers = allRows[0].map(function(h) { return h.toLowerCase().trim(); });
      function hi(name) {
        return headers.findIndex(function(h) { return h.includes(name.toLowerCase()); });
      }
      var iDate     = hi('日期');
      var iOrg      = hi('主辦單位');
      var iCoOrg1   = hi('協辦單位_1_zh');
      var iCoOrg2   = hi('協辦單位_2_zh');
      var iTopic    = hi('主題');
      var iType     = hi('類型');
      var iAudience = hi('人數');
      var iHours    = hi('小時');

      var EXCLUDED = ['彩排', '教材製作'];
      var rows = allRows.slice(1).filter(function(r) {
        return (r[iDate] || '').trim() &&
               (r[iTopic] || '').trim() &&
               EXCLUDED.indexOf((r[iType] || '').trim()) === -1;
      });

      /* Stats */
      var total    = rows.length;
      var hours    = rows.reduce(function(s, r) { return s + (parseFloat(r[iHours]) || 0); }, 0);
      var audience = rows.reduce(function(s, r) { return s + (parseInt(r[iAudience]) || 0); }, 0);

      var el = document.getElementById('h-total');
      if (el) el.textContent = total;
      el = document.getElementById('h-hours');
      if (el) el.textContent = Math.round(hours);
      el = document.getElementById('h-audience');
      if (el) el.textContent = audience >= 1000 ? (audience/1000).toFixed(1) + 'K' : audience;

      /* Partners leaderboard — count each org (主辦 + 協辦), top 10 */
      var counts = {};
      for (var i = 0; i < rows.length; i++) {
        var orgsInRow = [
          (rows[i][iOrg] || '').trim(),
          iCoOrg1 >= 0 ? (rows[i][iCoOrg1] || '').trim() : '',
          iCoOrg2 >= 0 ? (rows[i][iCoOrg2] || '').trim() : '',
        ];
        for (var p = 0; p < orgsInRow.length; p++) {
          var org = orgsInRow[p];
          if (org) counts[org] = (counts[org] || 0) + 1;
        }
      }
      var ranked = Object.keys(counts)
        .map(function(k) { return [k, counts[k]]; })
        .sort(function(a, b) { return b[1] - a[1]; })
        .slice(0, 10);
      var maxCount = ranked.length ? ranked[0][1] : 1;

      /* Render leaderboard rows */
      var grid = document.getElementById('partners-grid');
      if (!grid) return;
      grid.innerHTML = '';

      for (var j = 0; j < ranked.length; j++) {
        var name = ranked[j][0];
        var cnt  = ranked[j][1];
        var pct  = (cnt / maxCount) * 100;
        var row  = document.createElement('div');
        row.className = 'org-row';
        row.innerHTML =
          '<span class="org-rank' + (j < 3 ? ' org-rank-top' : '') + '">' + String(j + 1).padStart(2, '0') + '</span>' +
          '<span class="org-name">' + name + '</span>' +
          '<span class="org-bar-bg"><span class="org-bar" data-width="' + pct + '"></span></span>' +
          '<span class="org-count">' + cnt + '</span>';
        grid.appendChild(row);
      }

      /* Animate bars */
      var observer = new IntersectionObserver(function(entries) {
        if (entries[0].isIntersecting) {
          grid.querySelectorAll('.org-bar').forEach(function(b) { b.style.width = b.dataset.width + '%'; });
          observer.disconnect();
        }
      }, { threshold: 0.1 });
      observer.observe(grid);
      setTimeout(function() {
        grid.querySelectorAll('.org-bar').forEach(function(b) {
          if (!b.style.width || b.style.width === '0%') b.style.width = b.dataset.width + '%';
        });
      }, 1500);
    })
    .catch(function() {
      /* silent fail */
      var grid = document.getElementById('partners-grid');
      if (grid) grid.innerHTML = '';
    });
})();
</script>
