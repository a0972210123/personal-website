// Known org → domain mapping for logo fetching
const orgDomains: Record<string, string> = {
  '國立臺灣大學': 'ntu.edu.tw',
  '台灣大學': 'ntu.edu.tw',
  '臺灣大學': 'ntu.edu.tw',
  'NTU': 'ntu.edu.tw',
  '國立臺灣科技大學': 'ntust.edu.tw',
  '逢甲大學': 'fcu.edu.tw',
  '國立政治大學': 'nccu.edu.tw',
  '天主教輔仁大學': 'fju.edu.tw',
  '中原大學': 'cycu.edu.tw',
  '澳洲昆士蘭大學': 'uq.edu.au',
  '新北市立新店高中': 'hths.ntpc.edu.tw',
  'Straight A': 'straightatw.com',
  '德國在台協會': 'daad.de',
  'DAAD': 'daad.de',
