        </a>
      </div>
      <div class="hero-photo-wrap">
        <img src="/photo-pointing.jpg" alt="葉淨維 Matt Ye" />
      </div>
    </section>

    <!-- ② Bento Stats -->
    <section style="margin-bottom: var(--spacing-xl)">
      <p class="section-heading">By the numbers</p>
      <div class="bento-grid" style="grid-template-columns: repeat(4,1fr)">
        <div class="bento-card">
          <div class="bento-card-label">Speeches</div>
