        <p class="section-heading">Recent Writing</p>
        <ul class="post-list">
          {posts.map(post => (
            <PostCard
              id={post.id}
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              lang={post.data.lang}
            />
