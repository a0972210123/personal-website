        </ul>
        <a href="/writing" class="section-cta">All posts →</a>
      </section>
    )}

  </div>
</BaseLayout>

<script define:vars={{ CSV_URL, orgDomains }}>
/* Simple CSV parser */
function parseCSVSimple(text) {
  var rows = [];
  var lines = text.replace(/\r/g, '').split('\n');
  for (var li = 0; li < lines.length; li++) {
    var line = lines[li];
    if (!line.trim()) continue;
    var row = [], cur = '', inQ = false;
    for (var i = 0; i < line.length; i++) {
      var c = line[i];
      if (c === '"') { if (inQ && line[i+1]==='"') { cur+='"'; i++; } else inQ=!inQ; }
      else if (c===',' && !inQ) { row.push(cur.trim()); cur=''; }
      else cur+=c;
    }
    row.push(cur.trim());
    rows.push(row);
  }
  return rows;
}

/* Get domain for an org name */
function getDomain(orgName) {
  var keys = Object.keys(orgDomains);
  for (var i = 0; i < keys.length; i++) {
    if (orgName.indexOf(keys[i]) !== -1) return orgDomains[keys[i]];
  }
  return null;
}

/* Shorten org name for display */
function shortName(name) {
  if (!name) return '';
  // Use English abbreviation if present (in parentheses)
  var enMatch = name.match(/\(([A-Z][A-Z\s\-]{1,12})\)/);
  if (enMatch) return enMatch[1];
  // Strip common prefixes
  name = name.replace(/^(國立|社團法人|財團法人|台灣|臺灣)/, '');
  return name.length > 18 ? name.substring(0, 16) + '…' : name;
}

(function () {
  /* Fetch speeches stats for bento */
  fetch(CSV_URL)
    .then(function(r) { return r.text(); })
    .then(function(text) {
      var rows = parseCSVSimple(text).slice(1).filter(function(r) { return r[1] && r[4]; });

      /* Stats */
      var total = rows.length;
      var hours = rows.reduce(function(s, r) { return s + (parseFloat(r[10]) || 0); }, 0);
      var audience = rows.reduce(function(s, r) { return s + (parseInt(r[9]) || 0); }, 0);

      var el = document.getElementById('h-total');
      if (el) el.textContent = total;
      el = document.getElementById('h-hours');
      if (el) el.textContent = Math.round(hours);
      el = document.getElementById('h-audience');
      if (el) el.textContent = audience >= 1000 ? (audience/1000).toFixed(1) + 'K' : audience;

      /* Partners grid: collect unique org names */
      var seen = {};
      var orgs = [];
      for (var i = 0; i < rows.length; i++) {
        var orgRaw = (rows[i][2] || '').trim();
        // Some cells have multiple orgs separated by newlines or spaces - split on newline
        var parts = orgRaw.split(/\n/);
        for (var p = 0; p < parts.length; p++) {
          var org = parts[p].trim();
          if (!org || seen[org]) continue;
          seen[org] = true;
          orgs.push(org);
        }
      }

      /* Sort by frequency */
      var freq = {};
      for (var i = 0; i < rows.length; i++) {
        var o = (rows[i][2] || '').trim().split('\n')[0].trim();
        freq[o] = (freq[o] || 0) + 1;
      }
      orgs.sort(function(a, b) { return (freq[b] || 0) - (freq[a] || 0); });

      /* Render chips */
      var grid = document.getElementById('partners-grid');
      if (!grid) return;
      grid.innerHTML = '';

      for (var j = 0; j < orgs.length; j++) {
        var name = orgs[j];
        if (!name) continue;
        var domain = getDomain(name);
        var chip = document.createElement('span');
        chip.className = 'partner-chip';

        if (domain) {
          var img = document.createElement('img');
          img.src = 'https://www.google.com/s2/favicons?domain=' + domain + '&sz=32';
          img.alt = '';
          img.onerror = function() { this.style.display = 'none'; };
          chip.appendChild(img);
        }

        var label = document.createTextNode(shortName(name));
        chip.appendChild(label);
        grid.appendChild(chip);
      }
    })
    .catch(function() {
      /* silent fail */
      var grid = document.getElementById('partners-grid');
      if (grid) grid.innerHTML = '';
    });
})();
</script>
