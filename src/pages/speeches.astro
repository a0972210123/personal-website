---
import BaseLayout from '../layouts/BaseLayout.astro';
import T from '../components/T.astro';

const SHEET_ID = '1vYSAfnbqFzLNBNcPY5dd8XRxvVozt1IDd-kIqKO5swA';
const CSV_URL = `https://docs.google.com/spreadsheets/d/${SHEET_ID}/gviz/tq?tqx=out:csv&gid=0`;
---
<BaseLayout
  title="Speeches"
  description="葉淨維 Matt Ye 的演講、工作坊、競賽作品集。2020 年至今，涵蓋學術簡報、表達技巧、EMI教學等主題。"
>
  <script slot="head" src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>

  <div class="container-wide">

    <!-- Hero -->
    <section class="speeches-hero">
      <h1><T zh="演講" en="Speeches" /> &amp; <span class="accent-text"><T zh="工作坊" en="Workshops" /></span></h1>
      <p class="subtitle">
        <T zh="2020 年起的演講、工作坊與競賽紀錄。" en="A record of speeches, workshops, and competitions since 2020." />
      </p>
    </section>

    <!-- Bento Stats -->
    <div class="bento-grid" id="bento-stats">
      <div class="bento-card">
        <div class="bento-card-label">Total Events</div>
        <div class="bento-card-num" id="val-total">—</div>
        <div class="bento-card-sub"><T zh="場次累計" en="Total Events" /></div>
      </div>
      <div class="bento-card">
        <div class="bento-card-label">Total Hours</div>
        <div class="bento-card-num" id="val-hours">—</div>
        <div class="bento-card-sub"><T zh="講台時數" en="Total Hours" /></div>
      </div>
      <div class="bento-card">
        <div class="bento-card-label">Audience</div>
        <div class="bento-card-num" id="val-audience">—</div>
        <div class="bento-card-sub"><T zh="觸及人次" en="Audience Reached" /></div>
      </div>
      <div class="bento-card">
        <div class="bento-card-label">Organizations</div>
        <div class="bento-card-num" id="val-orgs">—</div>
        <div class="bento-card-sub"><T zh="合作單位" en="Partner organizations" /></div>
      </div>
      <div class="bento-card">
        <div class="bento-card-label">Languages</div>
        <div class="bento-card-num" id="val-langs">2</div>
        <div class="bento-card-sub"><T zh="中文 · 英文" en="Chinese · English" /></div>
      </div>
      <div class="bento-card">
        <div class="bento-card-label">Since</div>
        <div class="bento-card-num" id="val-since">2020</div>
        <div class="bento-card-sub" id="val-span">—</div>
      </div>
    </div>

    <!-- Charts: 4 Donuts -->
    <section class="charts-section">
      <p class="section-heading"><T zh="類型分佈" en="Distribution breakdown" /></p>
      <div class="charts-grid">
        <div class="chart-card">
          <div class="chart-card-head"><span class="chart-card-title"><T zh="類型" en="Type" /></span><span class="chart-badge" id="badge-type">—</span></div>
          <div class="chart-biggest" id="biggest-type">—</div>
          <div class="chart-wrap"><canvas id="chart-type"></canvas></div>
        </div>
        <div class="chart-card">
          <div class="chart-card-head"><span class="chart-card-title"><T zh="形式" en="Format" /></span><span class="chart-badge" id="badge-mode">—</span></div>
          <div class="chart-biggest" id="biggest-mode">—</div>
          <div class="chart-wrap"><canvas id="chart-mode"></canvas></div>
        </div>
        <div class="chart-card">
          <div class="chart-card-head"><span class="chart-card-title"><T zh="語言" en="Language" /></span><span class="chart-badge" id="badge-lang">—</span></div>
          <div class="chart-biggest" id="biggest-lang">—</div>
          <div class="chart-wrap"><canvas id="chart-lang"></canvas></div>
        </div>
        <div class="chart-card">
          <div class="chart-card-head"><span class="chart-card-title"><T zh="聽眾程度" en="Audience Level" /></span><span class="chart-badge" id="badge-edu">—</span></div>
          <div class="chart-biggest" id="biggest-edu">—</div>
          <div class="chart-wrap"><canvas id="chart-edu"></canvas></div>
        </div>
      </div>

      <!-- Year stacked bar -->
      <div class="year-chart-card">
        <div class="year-chart-head">
          <div>
            <div class="chart-card-title"><T zh="每年場次" en="Events per Year" /></div>
            <div class="year-peak" id="peak-year">—</div>
          </div>
          <div class="chart-legend" id="year-legend"></div>
        </div>
        <div class="year-chart-wrap"><canvas id="chart-year"></canvas></div>
      </div>
    </section>

    <!-- Org Leaderboard -->
    <section class="orgs-section">
      <p class="section-heading"><T zh="主要合作單位" en="Top collaborating organizations" /></p>
      <div class="orgs-filter-row">
        <button class="chip active" data-cat="all"><T zh="全部" en="All" /></button>
        <button class="chip" data-cat="學校">🎓 <T zh="學校" en="Schools" /></button>
        <button class="chip" data-cat="NGO">🌍 NGO</button>
        <button class="chip" data-cat="NPO">🤝 NPO</button>
        <button class="chip" data-cat="政府單位">🏛 <T zh="政府單位" en="Government" /></button>
        <button class="chip" data-cat="企業">🏢 <T zh="企業" en="Companies" /></button>
        <button class="chip" data-cat="學生社團">🎓 <T zh="學生社團" en="Student Clubs" /></button>
        <button class="chip" data-cat="自媒體">📱 <T zh="自媒體" en="Media/Creators" /></button>
      </div>
      <div class="orgs-scroll-wrap">
        <div class="orgs-grid" id="orgs-grid"></div>
      </div>
    </section>

    <!-- Explorer: search + filters -->
    <div class="explorer-bar">
      <div class="search-box">
        <svg class="search-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
        <input type="text" id="search-input" placeholder="搜尋主題、主辦單位…" autocomplete="off" />
      </div>
      <div class="filter-row">
        <span class="filter-label"><T zh="類型" en="Type" /></span>
        <div class="chip-group" id="type-chips"></div>
      </div>
      <div class="filter-row">
        <span class="filter-label"><T zh="形式" en="Format" /></span>
        <div class="chip-group" id="mode-chips"></div>
      </div>
      <div class="filter-row">
        <span class="filter-label"><T zh="語言" en="Language" /></span>
        <div class="chip-group" id="lang-chips"></div>
      </div>
      <div class="filter-row">
        <span class="filter-label"><T zh="年份" en="Year" /></span>
        <div class="chip-group" id="year-chips"></div>
      </div>
    </div>

    <!-- Filtered Stats Strip -->
    <div class="filtered-stats" id="filtered-stats" style="display:none">
      <div class="fstat-item">
        <span class="fstat-num" id="fval-events">—</span>
        <span class="fstat-label"><T zh="場次" en="Events" /></span>
      </div>
      <div class="fstat-divider"></div>
      <div class="fstat-item">
        <span class="fstat-num" id="fval-hours">—</span>
        <span class="fstat-label"><T zh="小時" en="Hours" /></span>
      </div>
      <div class="fstat-divider"></div>
      <div class="fstat-item">
        <span class="fstat-num" id="fval-audience">—</span>
        <span class="fstat-label"><T zh="人次" en="Audience" /></span>
      </div>
    </div>

    <!-- Results meta + sort -->
    <div class="results-meta">
      <span><T zh="顯示" en="Showing" /> <b id="results-count">—</b> <T zh="場活動" en="events" /></span>
      <div class="results-meta-right">
        <select id="sort-select" class="sort-select">
          <option value="date-desc">日期（最新）</option>
          <option value="date-asc">日期（最早）</option>
          <option value="audience-desc">人次（最多）</option>
          <option value="hours-desc">時數（最多）</option>
        </select>
        <button class="clear-btn" id="clear-btn" style="display:none"><T zh="清除篩選" en="Clear filters" /></button>
      </div>
    </div>

    <!-- Cards -->
    <div class="speech-cards-grid" id="cards-grid">
      <div class="data-loading"><T zh="演講資料載入中…" en="Loading speeches data…" /></div>
    </div>

    <!-- Show more -->
    <div class="show-more-row">
      <button class="show-more-btn" id="show-more-btn" style="display:none">
        <T zh="顯示更多" en="Show more" />
      </button>
    </div>

  </div>
</BaseLayout>

<script define:vars={{ CSV_URL }}>
/* ── CSV Parser (robust: handles quoted multi-line cells) ── */
function parseCSV(text) {
  const rows = [];
  let row = [], cur = '', inQ = false;
  const t = text.replace(/\r\n/g, '\n').replace(/\r/g, '\n');
  for (let i = 0; i < t.length; i++) {
    const c = t[i];
    if (c === '"') {
      if (inQ && t[i+1] === '"') { cur += '"'; i++; }
      else inQ = !inQ;
    } else if (c === ',' && !inQ) {
      row.push(cur.trim()); cur = '';
    } else if (c === '\n' && !inQ) {
      row.push(cur.trim());
      if (row.some(v => v)) rows.push(row);
      row = []; cur = '';
    } else {
      cur += c;
    }
  }
  if (cur || row.length) { row.push(cur.trim()); rows.push(row); }
  return rows;
}

function fmtDate(raw) {
  if (!raw) return '';
  const clean = raw.replace(/[^\d/]/g, '');
  const parts = clean.split('/');
  if (parts.length < 3) return raw;
  const [y, m, d] = parts;
  if (!y || y.length !== 4) return raw;
  const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  return `${months[parseInt(m)-1] ?? m} ${parseInt(d)}, ${y}`;
}

function fmtNum(n) {
  if (n >= 1000) return `${(n/1000).toFixed(1)}K`;
  return String(n);
}

/* ── Count-up animation ── */
function countUp(el, finalVal, dur) {
  if (!el || isNaN(finalVal)) return;
  const fmt = finalVal >= 1000
    ? v => `${(v / 1000).toFixed(1)}K`
    : v => String(Math.round(v));
  const start = performance.now();
  const step = now => {
    const t = Math.min((now - start) / dur, 1);
    const ease = 1 - Math.pow(1 - t, 3);
    el.textContent = fmt(finalVal * ease);
    if (t < 1) requestAnimationFrame(step);
    else el.textContent = fmt(finalVal);
  };
  requestAnimationFrame(step);
}

/* ── State ── */
const PAGE_SIZE = 24;
const EXCLUDED_TYPES = new Set(['彩排', '教材製作']);
const PALETTE = ['#8b6cff','#14e0ff','#ff5dd9','#ffd166','#4ade80','#ff7a59','#c8b0ff','#8ee0ff','#ffb3ee'];
let allData = [];
let state = { search: '', types: new Set(), modes: new Set(), langs: new Set(), years: new Set(), sort: 'date-desc', page: 1 };

/* ── Fetch & Init ── */
async function init() {
  try {
    const resp = await fetch(CSV_URL);
    if (!resp.ok) throw new Error(`HTTP ${resp.status}`);
    const text = await resp.text();
    const rows = parseCSV(text);

    const headers = rows[0].map(h => h.toLowerCase().trim());
    const hi = name => headers.findIndex(h => h.includes(name.toLowerCase()));

    const iDate        = hi('日期');
    const iOrg         = hi('主辦單位_zh');
    const iOrgEn       = hi('主辦單位_eng');
    const iOrgType     = hi('主辦單位_類型');
    const iCoOrg1      = hi('協辦單位_1_zh');
    const iCoOrg1En    = hi('協辦單位_1_eng');
    const iCoOrg1Type  = hi('協辦單位_1_類型');
    const iCoOrg2      = hi('協辦單位_2_zh');
    const iCoOrg2En    = hi('協辦單位_2_eng');
    const iCoOrg2Type  = hi('協辦單位_2_類型');
    const iTopic       = hi('主題');
    const iType        = hi('場次類型');
    const iMode        = hi('線上');
    const iLang        = hi('語言');
    const iEdu         = hi('教育程度');
    const iAudience    = hi('人數');
    const iHours       = hi('小時');
    const iYoutubeUrl  = hi('youtube');
    const iUrl         = hi('news, blog');

    allData = rows.slice(1)
      .map(r => ({
        date:        r[iDate]                           ?? '',
        year:        (r[iDate] ?? '').match(/^(\d{4})/)?.[1] ?? '',
        org:         iOrg >= 0        ? (r[iOrg]        ?? '') : '',
        orgEn:       iOrgEn >= 0      ? (r[iOrgEn]      ?? '') : '',
        orgType:     iOrgType >= 0    ? (r[iOrgType]    ?? '') : '',
        coOrg1:      iCoOrg1 >= 0     ? (r[iCoOrg1]     ?? '') : '',
        coOrg1En:    iCoOrg1En >= 0   ? (r[iCoOrg1En]   ?? '') : '',
        coOrg1Type:  iCoOrg1Type >= 0 ? (r[iCoOrg1Type] ?? '') : '',
        coOrg2:      iCoOrg2 >= 0     ? (r[iCoOrg2]     ?? '') : '',
        coOrg2En:    iCoOrg2En >= 0   ? (r[iCoOrg2En]   ?? '') : '',
        coOrg2Type:  iCoOrg2Type >= 0 ? (r[iCoOrg2Type] ?? '') : '',
        topic:       r[iTopic]                          ?? '',
        type:        r[iType]                           ?? '',
        mode:        r[iMode]                           ?? '',
        lang:        r[iLang]                           ?? '',
        edu:         r[iEdu]                            ?? '',
        audience:    parseInt(r[iAudience])  || 0,
        hours:       parseFloat(r[iHours])   || 0,
        youtubeUrl:  iYoutubeUrl >= 0 ? (r[iYoutubeUrl] ?? '') : '',
        url:         iUrl >= 0        ? (r[iUrl]         ?? '') : '',
      }))
      .filter(d => d.date && d.topic && !EXCLUDED_TYPES.has(d.type));

    renderStats();
    renderChips();
    renderCharts();
    initOrgFilters();
    renderOrgLeaderboard();
    renderCards();
  } catch (err) {
    document.getElementById('cards-grid').innerHTML =
      `<div class="data-error">⚠️ 資料載入失敗，請稍後再試。<br><small>${err.message}</small></div>`;
    console.error('Speeches data error:', err);
  }
}

/* ── Stats ── */
function renderStats() {
  const total = allData.length;
  const hours = allData.reduce((s, d) => s + d.hours, 0);
  const audience = allData.reduce((s, d) => s + d.audience, 0);
  const orgs = new Set(
    allData.flatMap(d => [d.org, d.coOrg1, d.coOrg2]).map(s => s.trim()).filter(Boolean)
  ).size;

  countUp(document.getElementById('val-total'),    total,              1400);
  countUp(document.getElementById('val-hours'),    Math.round(hours),  1400);
  countUp(document.getElementById('val-audience'), audience,           1600);
  countUp(document.getElementById('val-orgs'),     orgs,               1200);
  countUp(document.getElementById('val-langs'),    2,                   600);
  document.getElementById('val-span').textContent = `${total} events over 6 yrs`;
}

function renderFilteredStats(filtered) {
  const strip = document.getElementById('filtered-stats');
  if (!strip) return;
  const active = hasActiveFilters();
  strip.style.display = active ? 'flex' : 'none';
  if (!active) return;
  document.getElementById('fval-events').textContent = filtered.length;
  document.getElementById('fval-hours').textContent = Math.round(filtered.reduce((s, d) => s + d.hours, 0));
  document.getElementById('fval-audience').textContent = fmtNum(filtered.reduce((s, d) => s + d.audience, 0));
}

/* ── Charts ── */
function countBy(arr, key) {
  const m = {};
  arr.forEach(r => { const k = r[key] || '未知'; m[k] = (m[k] || 0) + 1; });
  return m;
}

function makeDonut(canvasId, counts, biggestId, badgeId) {
  const ctx = document.getElementById(canvasId);
  if (!ctx) return;
  const labels = Object.keys(counts);
  const values = labels.map(l => counts[l]);
  const total = values.reduce((a, b) => a + b, 0);
  const sorted = labels.map((l, i) => ({ l, v: values[i] })).sort((a, b) => b.v - a.v);
  const biggestEl = document.getElementById(biggestId);
  const badgeEl = document.getElementById(badgeId);
  if (biggestEl) biggestEl.textContent = sorted[0].l + ' · ' + Math.round(sorted[0].v / total * 100) + '%';
  if (badgeEl) badgeEl.textContent = labels.length + ' 類';

  new Chart(ctx, {
    type: 'doughnut',
    data: {
      labels,
      datasets: [{ data: values, backgroundColor: labels.map((_, i) => PALETTE[i % PALETTE.length]), borderWidth: 0, borderRadius: 3, spacing: 1, hoverOffset: 8 }]
    },
    options: {
      cutout: '68%',
      responsive: true, maintainAspectRatio: false,
      animation: { duration: 1200, easing: 'easeOutQuart' },
      plugins: {
        legend: { position: 'bottom', labels: { boxWidth: 8, boxHeight: 8, padding: 8, font: { size: 11 }, usePointStyle: true, pointStyle: 'circle' } },
        tooltip: {
          callbacks: { label: (c) => ' ' + c.label + ' · ' + c.parsed + ' 場 (' + (c.parsed / total * 100).toFixed(1) + '%)' }
        }
      }
    }
  });
}

function renderCharts() {
  const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
  Chart.defaults.color = isDark ? '#8b93bf' : '#666666';
  Chart.defaults.font.family = "-apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif";
  Chart.defaults.font.size = 11;
  Chart.defaults.borderColor = isDark ? 'rgba(255,255,255,.05)' : 'rgba(0,0,0,.06)';

  makeDonut('chart-type', countBy(allData, 'type'), 'biggest-type', 'badge-type');
  makeDonut('chart-mode', countBy(allData, 'mode'), 'biggest-mode', 'badge-mode');
  makeDonut('chart-lang', countBy(allData, 'lang'), 'biggest-lang', 'badge-lang');
  makeDonut('chart-edu',  countBy(allData, 'edu'),  'biggest-edu',  'badge-edu');

  /* Stacked bar by year */
  const years = [...new Set(allData.map(d => d.year).filter(Boolean))].sort();
  const types = [...new Set(allData.map(d => d.type))];
  const peak = years.map(y => ({ y, n: allData.filter(d => d.year === y).length })).sort((a, b) => b.n - a.n)[0];
  const peakEl = document.getElementById('peak-year');
  if (peakEl && peak) peakEl.textContent = `Peak: ${peak.y} · ${peak.n} 場`;

  const legendEl = document.getElementById('year-legend');
  if (legendEl) {
    legendEl.innerHTML = '';
    types.forEach((t, i) => {
      const item = document.createElement('span');
      item.className = 'legend-item';
      item.innerHTML = `<span class="legend-swatch" style="background:${PALETTE[i % PALETTE.length]}"></span>${t}`;
      legendEl.appendChild(item);
    });
  }

  const yearCtx = document.getElementById('chart-year');
  if (yearCtx) {
    new Chart(yearCtx, {
      type: 'bar',
      data: {
        labels: years,
        datasets: types.map((t, i) => ({
          label: t,
          data: years.map(y => allData.filter(d => d.year === y && d.type === t).length),
          backgroundColor: PALETTE[i % PALETTE.length],
          borderRadius: 4, borderSkipped: false, maxBarThickness: 52,
        }))
      },
      options: {
        responsive: true, maintainAspectRatio: false,
        animation: { duration: 1200, easing: 'easeOutQuart' },
        plugins: {
          legend: { display: false },
          tooltip: {
            callbacks: { footer: (items) => '合計 ' + items.reduce((a, b) => a + b.parsed.y, 0) + ' 場' }
          }
        },
        scales: {
          x: { stacked: true, grid: { display: false }, ticks: { font: { size: 12, weight: '600' } } },
          y: { stacked: true, grid: { color: isDark ? 'rgba(255,255,255,.04)' : 'rgba(0,0,0,.06)' }, ticks: { precision: 0, padding: 6 } }
        }
      }
    });
  }
}

/* ── Org Leaderboard ── */
let orgCatFilter = 'all';

function buildOrgMap() {
  // zh → { count, eng, type }
  const map = {};
  allData.forEach(d => {
    [
      { zh: d.org,    eng: d.orgEn,    type: d.orgType    },
      { zh: d.coOrg1, eng: d.coOrg1En, type: d.coOrg1Type },
      { zh: d.coOrg2, eng: d.coOrg2En, type: d.coOrg2Type },
    ].forEach(({ zh, eng, type }) => {
      const name = (zh || '').trim();
      if (!name) return;
      if (!map[name]) map[name] = { count: 0, eng: '', type: '' };
      map[name].count++;
      if (!map[name].eng  && eng)  map[name].eng  = eng.trim();
      if (!map[name].type && type) map[name].type = type.trim();
    });
  });
  return map;
}

function renderOrgLeaderboard(catFilter) {
  if (catFilter !== undefined) orgCatFilter = catFilter;

  const orgMap = buildOrgMap();
  let entries = Object.entries(orgMap).sort((a, b) => b[1].count - a[1].count);

  if (orgCatFilter !== 'all') {
    entries = entries.filter(([, info]) => info.type === orgCatFilter);
  }

  const ranked = entries; /* show all — scrollable container handles overflow */
  const max = ranked[0]?.[1].count || 1;

  const grid = document.getElementById('orgs-grid');
  if (!grid) return;
  grid.innerHTML = '';
  /* Reset scroll position on each filter change */
  const wrap = grid.closest('.orgs-scroll-wrap');
  if (wrap) wrap.scrollTop = 0;

  if (ranked.length === 0) {
    grid.innerHTML = '<div class="data-error" style="font-size:1.1rem">此分類尚無資料</div>';
    return;
  }

  ranked.forEach(([name, info], i) => {
    const pct = (info.count / max) * 100;
    const row = document.createElement('div');
    row.className = 'org-row';
    row.innerHTML = `
      <span class="org-rank${i < 3 ? ' org-rank-top' : ''}">${String(i + 1).padStart(2, '0')}</span>
      <span class="org-name">
        <span class="org-name-zh">${name}</span>
        ${info.eng ? `<span class="org-name-en">${info.eng}</span>` : ''}
      </span>
      <span class="org-bar-bg"><span class="org-bar" data-width="${pct}"></span></span>
      <span class="org-count">${info.count}</span>
    `;
    grid.appendChild(row);
  });

  /* Double-rAF: first frame paints width:0%, second frame triggers CSS transition */
  requestAnimationFrame(() => {
    requestAnimationFrame(() => {
      grid.querySelectorAll('.org-bar').forEach(b => {
        b.style.width = b.dataset.width + '%';
      });
    });
  });
}

/* ── Org Filter Chip Listeners ── */
function initOrgFilters() {
  document.querySelectorAll('[data-cat]').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('[data-cat]').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      renderOrgLeaderboard(btn.dataset.cat);
    });
  });
}

/* ── Filter Chips ── */
function makeChips(containerId, values, stateSet, onChange) {
  const container = document.getElementById(containerId);
  if (!container) return;
  container.innerHTML = '';
  [...values].sort().forEach(val => {
    const btn = document.createElement('button');
    btn.className = 'chip' + (stateSet.has(val) ? ' active' : '');
    btn.textContent = val;
    btn.addEventListener('click', () => {
      stateSet.has(val) ? stateSet.delete(val) : stateSet.add(val);
      btn.classList.toggle('active');
      state.page = 1;
      onChange();
    });
    container.appendChild(btn);
  });
}

function renderChips() {
  const types = new Set(allData.map(d => d.type).filter(Boolean));
  const modes = new Set(allData.map(d => d.mode).filter(Boolean));
  const langs = new Set(allData.map(d => d.lang).filter(Boolean));
  const years = new Set(allData.map(d => d.year).filter(Boolean));

  makeChips('type-chips', types, state.types, renderCards);
  makeChips('mode-chips', modes, state.modes, renderCards);
  makeChips('lang-chips', langs, state.langs, renderCards);
  makeChips('year-chips', [...years].sort(), state.years, renderCards);
}

/* ── Filter + Sort Logic ── */
function applyFilters() {
  const q = state.search.toLowerCase();
  let result = allData.filter(d => {
    if (q && !d.topic.toLowerCase().includes(q) && !d.org.toLowerCase().includes(q) && !d.orgEn.toLowerCase().includes(q)) return false;
    if (state.types.size && !state.types.has(d.type)) return false;
    if (state.modes.size && !state.modes.has(d.mode)) return false;
    if (state.langs.size && !state.langs.has(d.lang)) return false;
    if (state.years.size && !state.years.has(d.year)) return false;
    return true;
  });

  switch (state.sort) {
    case 'date-asc':      result = result.sort((a, b) => a.date.localeCompare(b.date)); break;
    case 'audience-desc': result = result.sort((a, b) => b.audience - a.audience); break;
    case 'hours-desc':    result = result.sort((a, b) => b.hours - a.hours); break;
    default:              result = result.sort((a, b) => b.date.localeCompare(a.date));
  }
  return result;
}

function hasActiveFilters() {
  return state.search || state.types.size || state.modes.size || state.langs.size || state.years.size;
}

/* ── Card Renderer ── */
function cardHTML(d) {
  const typeCls = `badge badge-type-${d.type}`;
  const modeCls = `badge badge-mode-${d.mode}`;
  const linkUrl = d.youtubeUrl || d.url;
  const topicHTML = linkUrl
    ? `<a class="card-topic card-topic-link" href="${linkUrl}" target="_blank" rel="noopener">${d.topic}</a>`
    : `<div class="card-topic">${d.topic}</div>`;
  const coOrgHTML = [
    { zh: d.coOrg1, en: d.coOrg1En },
    { zh: d.coOrg2, en: d.coOrg2En },
  ].filter(o => o.zh).map(o =>
    `<div class="card-org-co">協辦：${o.zh}${o.en ? ` <span class="card-org-co-en">· ${o.en}</span>` : ''}</div>`
  ).join('');
  return `
    <div class="speech-card">
      <div class="card-meta-row">
        <span>${fmtDate(d.date)}</span>
        <span>${d.edu}</span>
      </div>
      ${topicHTML}
      ${d.org ? `<div class="card-org">${d.org}</div>` : ''}
      ${d.orgEn ? `<div class="card-org-en">${d.orgEn}</div>` : ''}
      ${coOrgHTML}
      <div class="card-stats">
        ${d.audience ? `<span><b>${d.audience}</b>人</span>` : ''}
        ${d.hours ? `<span><b>${d.hours}</b>hr</span>` : ''}
      </div>
      <div class="card-badges">
        ${d.type ? `<span class="${typeCls}">${d.type}</span>` : ''}
        ${d.mode ? `<span class="${modeCls}">${d.mode}</span>` : ''}
        ${d.lang ? `<span class="badge badge-lang">${d.lang}</span>` : ''}
      </div>
    </div>
  `;
}

function renderCards() {
  const filtered = applyFilters();
  const visible = filtered.slice(0, state.page * PAGE_SIZE);

  document.getElementById('results-count').textContent = filtered.length;
  document.getElementById('clear-btn').style.display = hasActiveFilters() ? 'block' : 'none';
  renderFilteredStats(filtered);

  const grid = document.getElementById('cards-grid');
  if (filtered.length === 0) {
    grid.innerHTML = '<div class="data-error" style="font-size:2rem">😶<br><br>No results found.</div>';
  } else {
    grid.innerHTML = visible.map(cardHTML).join('');
  }

  const moreBtn = document.getElementById('show-more-btn');
  if (filtered.length > state.page * PAGE_SIZE) {
    moreBtn.style.display = 'block';
    moreBtn.disabled = false;
    moreBtn.textContent = `Show more (${filtered.length - visible.length} remaining)`;
  } else {
    moreBtn.style.display = 'none';
  }
}

/* ── Bilingual search placeholder ── */
function updateSearchPlaceholder() {
  const inp = document.getElementById('search-input');
  if (!inp) return;
  const lang = document.documentElement.getAttribute('data-lang');
  inp.placeholder = lang === 'en' ? 'Search topics, organizers…' : '搜尋主題、主辦單位…';
}
updateSearchPlaceholder();
window.addEventListener('langchange', updateSearchPlaceholder);

/* ── Event Listeners ── */
document.getElementById('search-input')?.addEventListener('input', e => {
  state.search = e.target.value;
  state.page = 1;
  renderCards();
});

document.getElementById('sort-select')?.addEventListener('change', e => {
  state.sort = e.target.value;
  state.page = 1;
  renderCards();
});

document.getElementById('show-more-btn')?.addEventListener('click', () => {
  state.page++;
  renderCards();
});

document.getElementById('clear-btn')?.addEventListener('click', () => {
  state.search = '';
  state.types.clear(); state.modes.clear(); state.langs.clear(); state.years.clear();
  state.page = 1;
  const inp = document.getElementById('search-input');
  if (inp) inp.value = '';
  document.querySelectorAll('.chip.active').forEach(c => c.classList.remove('active'));
  document.getElementById('clear-btn').style.display = 'none';
  renderCards();
});

/* ── Run ── */
init();
</script>
