---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const docs = [
  {
    slug: 'ip-governance-ai',
    title: 'IP 治理與 AI',
    titleEn: 'IP Governance & AI',
    description: '探討人工智慧時代的智慧財產權治理架構，涵蓋著作權、專利、開源授權等核心議題。',
    tags: ['IP 治理', 'AI', '法律'],
  },
];
---
<BaseLayout
  title="One More Step — Matt Ye"
  description="One More Step：葉淨維 Matt Ye 的學習文件集，把複雜的東西搞懂，然後寫下來。"
>
  <section class="oms-hero">
    <a href="/projects" class="back-link">← Side Projects</a>
    <h1>One More <span class="accent-text">Step</span></h1>
    <p class="oms-subtitle">把複雜的東西搞懂，然後寫下來。</p>
  </section>

  <div class="docs-grid">
    {docs.map(doc => (
      <a href={`/projects/one-more-step/${doc.slug}`} class="doc-card">
        <div class="doc-card-body">
          <h2 class="doc-title">{doc.title}</h2>
          <p class="doc-title-en">{doc.titleEn}</p>
          <p class="doc-desc">{doc.description}</p>
        </div>
        <div class="doc-footer">
          <div class="doc-tags">
            {doc.tags.map(tag => <span class="doc-tag">{tag}</span>)}
          </div>
          <span class="doc-link">閱讀 →</span>
        </div>
      </a>
    ))}
  </div>
</BaseLayout>

<style>
  .oms-hero {
    padding: 3rem 0 2rem;
  }

  .back-link {
    display: inline-block;
    font-size: 0.85rem;
    color: var(--color-text-muted);
    text-decoration: none;
    margin-bottom: 1rem;
  }

  .back-link:hover {
    color: var(--color-text);
  }

  .oms-hero h1 {
    font-size: clamp(2rem, 5vw, 2.8rem);
    font-weight: 700;
    margin: 0 0 0.5rem;
  }

  .oms-subtitle {
    color: var(--color-text-muted);
    font-size: 1.05rem;
    margin: 0;
  }

  .docs-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
    padding-bottom: 4rem;
  }

  .doc-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    text-decoration: none;
    color: inherit;
    transition: box-shadow 0.2s, border-color 0.2s;
  }

  .doc-card:hover {
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
    border-color: var(--color-accent);
  }

  .doc-card-body {
    flex: 1;
  }

  .doc-title {
    font-size: 1.1rem;
    font-weight: 600;
    margin: 0 0 0.15rem;
  }

  .doc-title-en {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin: 0 0 0.75rem;
  }

  .doc-desc {
    font-size: 0.92rem;
    color: var(--color-text-muted);
    line-height: 1.65;
    margin: 0;
  }

  .doc-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .doc-tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .doc-tag {
    font-size: 0.72rem;
    background: var(--color-border);
    color: var(--color-text-muted);
    padding: 0.15rem 0.5rem;
    border-radius: 99px;
  }

  .doc-link {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-accent);
    white-space: nowrap;
  }
</style>
