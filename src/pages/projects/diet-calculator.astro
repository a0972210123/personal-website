  .glossary-item b { display: block; color: var(--color-text); font-size: 0.86rem; margin-bottom: 0.2rem; }

  .calc-subheading { font-size: 0.95rem; font-weight: 700; margin: 1.5rem 0 0.8rem; }
  .venue-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 0.9rem; }
  .venue-card {
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: var(--radius-md);
    padding: 1rem 1.2rem;
    box-shadow: var(--card-shadow);
    font-size: 0.85rem;
    line-height: 1.6;
    color: var(--color-text-muted);
  }
  .venue-card p { margin: 0.3rem 0 0; }
  .venue-title { font-size: 0.92rem; font-weight: 700; color: var(--color-text); margin-bottom: 0.3rem; }

  .supp-table-wrap { overflow-x: auto; }
  .supp-table { width: 100%; border-collapse: collapse; font-size: 0.82rem; min-width: 640px; }
  .supp-table th, .supp-table td { text-align: left; padding: 0.7rem 0.8rem; border-bottom: 1px solid var(--color-border); vertical-align: top; }
  .supp-table th { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-text-muted); }
  .supp-table td { color: var(--color-text-muted); line-height: 1.6; }
  .supp-table td:first-child { color: var(--color-text); font-weight: 600; }
  .supp-sub { font-size: 0.74rem; color: var(--color-text-muted); font-weight: 400; }
  .supp-tier { font-weight: 700; white-space: nowrap; }
  .tier-1 { color: #2fbf71; }
  .tier-2 { color: #f5a623; }
  .tier-3 { color: #e5484d; }
</style>

<script>
/* ── Reference data (Taiwan DRI 8th ed. + ISSN 2017 + ACSM/AND/DC 2016) ── */
const DRI = { protein: [10, 35], fat: [20, 30], carb: [50, 65] };

/* Goal → suggested protein g/kg default (must exactly match an <option value> below) */
const PROTEIN_GKG_SUGGEST = {
  bulk_high: '1.8', bulk_low: '1.8',
  maintain: '1.6',
  cut_low: '2.0', cut_high: '2.4',
};

const GOALS = {
  bulk_high: { pct: 1.2, kcal: 500, label: '+20% TDEE 或 +500kcal（取平均）' },
  bulk_low: { pct: 1.1, kcal: 200, label: '+10% TDEE 或 +200kcal（取平均）' },
  maintain: { pct: 1.0, kcal: 0, label: '100% TDEE' },
  cut_low: { pct: 0.9, kcal: -200, label: '-10% TDEE 或 -200kcal（取平均）' },
  cut_high: { pct: 0.8, kcal: -500, label: '-20% TDEE 或 -500kcal（取平均）' },
};

const DIET_TYPES = {
  baseline: { label: '一般飲食（Baseline）', f: 30, c: 55 },
  balanced: { label: '均衡飲食', f: 25, c: 55 },
  dash: { label: '得舒飲食 DASH Diet', f: 27, c: 55 },
  zone: { label: '區域飲食 Zone Diet', f: 30, c: 40 },
  modlowcarb: { label: '中度低醣飲食', f: 35, c: 40 },
  lowcarb: { label: '低醣飲食', f: 40, c: 20 },
  verylowcarb: { label: '極低醣', f: 45, c: 10 },
  verylowcarbketo: { label: '極低醣＋生酮', f: 45, c: 5 },
  keto: { label: '生酮飲食 Keto Diet', f: 70, c: 10 },
  highcarb: { label: '高碳飲食', f: 15, c: 60 },
  carbcycle: { label: '碳循環飲食（Carb Cycling）', f: 35, c: 40 },
};

/* Carb-cycling day-type g/kg — adapted from ACSM/AND/DC 2016 (Thomas et al.) framework
   for general recreational/resistance-trained population (not endurance-athlete figures) */
const CARBCYCLE_GKG = {
  high: { label: '高強度訓練日', gkg: 4.5 },
  low: { label: '低強度訓練日', gkg: 3.5 },
  rest: { label: '休息日', gkg: 2.5 },
};

const DAYS = ['一', '二', '三', '四', '五', '六', '日'];
const DEFAULT_CC_PLAN = ['high', 'low', 'low', 'rest', 'high', 'low', 'rest'];
const SHORT_LABEL = { high: '高強度', low: '低強度', rest: '休息' };

/* Diet types where baseline carbs are already ketosis-range (≤10% kcal) — a full ACSM
   training-day bump would abandon ketosis, so use a small Targeted/Cyclical Keto (TKD/CKD)
   refeed instead: a modest fixed carb addition around training, not a multi-hundred-gram swing. */
const KETO_LIKE = new Set(['keto', 'verylowcarb', 'verylowcarbketo']);
const TKD_BUMP = { rest: 0, low: 25, high: 50 };

/* ── 六大類食物 (Taiwan HPA official food-exchange system) — per-serving macros ──
   豆魚蛋肉 uses the medium-fat average; 乳品 uses the whole/regular average
   (current guidance treats whole vs. low-fat dairy as equally acceptable). */
const FOOD_GROUPS = {
  grain:  { label: '全穀雜糧', example: '¼碗飯／1 片全麥吐司／2 湯匙紫米', protein: 2, fat: 0, carb: 15 },
  protein:{ label: '豆魚蛋肉', example: '1 顆蛋／35g 雞胸肉／80g 嫩豆腐',   protein: 7, fat: 5, carb: 0 },
  dairy:  { label: '乳品',     example: '1 杯（240ml）鮮奶／2 片起司',      protein: 8, fat: 8, carb: 12 },
  veg:    { label: '蔬菜',     example: '100g 生重（約煮熟後半碗）',        protein: 1, fat: 0, carb: 5 },
  fruit:  { label: '水果',     example: '1 個拳頭大小水果／半根香蕉',       protein: 0, fat: 0, carb: 15 },
  fat:    { label: '油脂與堅果種子', example: '1 茶匙油／6–7 顆堅果',       protein: 0, fat: 5, carb: 0 },
};
/* Fixed baseline servings for micronutrient coverage, regardless of calorie target
   (matches the official guide's typical minimums) */
const BASELINE_SERVINGS = { veg: 4, fruit: 3, dairy: 1.5 };

/* ── BMR formulas ── */
function bmrMifflin(w, h, age, sex) {
  return sex === 'male' ? 10 * w + 6.25 * h - 5 * age + 5 : 10 * w + 6.25 * h - 5 * age - 161;
}
function bmrHarrisBenedict(w, h, age, sex) {
  return sex === 'male'
    ? 13.397 * w + 4.799 * h - 5.677 * age + 88.362
    : 9.247 * w + 3.098 * h - 4.33 * age + 447.593;
}
function estimateLBM(w, h, sex) {
  return sex === 'male' ? 0.407 * w + 0.267 * h - 19.2 : 0.252 * w + 0.473 * h - 48.3;
}
function bmrKatch(lbm) { return 370 + 21.6 * lbm; }

function round(n) { return Math.round(n); }
function fmt(n) { return isFinite(n) ? round(n).toLocaleString('en-US') : '—'; }

function driBadge(pct, range) {
  const within = pct >= range[0] - 0.5 && pct <= range[1] + 0.5;
  return within ? '✅' : '⚠️';
}

/* ── Macro calculation: protein-first (g/kg), then fat/carb split remaining calories ── */
function computeMacros(weightKg, targetKcal, proteinGkg, dietType) {
  const proteinG = weightKg * proteinGkg;
  const proteinKcal = proteinG * 4;
  const remainKcal = Math.max(targetKcal - proteinKcal, 0);
  const ratioSum = dietType.f + dietType.c;
  const fatKcal = remainKcal * (dietType.f / ratioSum);
  const carbKcal = remainKcal * (dietType.c / ratioSum);
  return {
    protein: { g: proteinG, kcal: proteinKcal, pct: (proteinKcal / targetKcal) * 100 },
    fat: { g: fatKcal / 9, kcal: fatKcal, pct: (fatKcal / targetKcal) * 100 },
    carb: { g: carbKcal / 4, kcal: carbKcal, pct: (carbKcal / targetKcal) * 100 },
  };
}

/* ── Per-day macro calculation: protein fixed every day; carb adjusted by that day's
   training intensity (universal — applies to every diet type, not just carb-cycling) ── */
function computeDayMacros(weight, targetKcal, proteinGkg, dietKey, dietType, dayType) {
  const proteinG = weight * proteinGkg;
  const proteinKcal = proteinG * 4;
  let carbG;

  if (dietKey === 'carbcycle') {
    carbG = weight * CARBCYCLE_GKG[dayType].gkg;
  } else {
    const base = computeMacros(weight, targetKcal, proteinGkg, dietType);
    if (KETO_LIKE.has(dietKey)) {
      carbG = base.carb.g + TKD_BUMP[dayType];
    } else if (dayType === 'rest') {
      carbG = base.carb.g;
    } else {
      carbG = Math.max(base.carb.g, weight * CARBCYCLE_GKG[dayType].gkg);
    }
  }

  const carbKcal = carbG * 4;
  const fatKcal = Math.max(targetKcal - proteinKcal - carbKcal, 0);
  return { proteinG, proteinKcal, carbG, carbKcal, fatG: fatKcal / 9, fatKcal };
}

/* ── Food-group servings: converts weekly-average macro grams into 六大類食物 servings,
   the same way a dietitian manually builds a food-exchange plan (fixed micronutrient
   baseline first, then allocate the remaining protein/fat/carb need to the flexible groups) ── */
function computeServings(proteinG, fatG, carbG) {
  const veg = BASELINE_SERVINGS.veg, fruit = BASELINE_SERVINGS.fruit, dairy = BASELINE_SERVINGS.dairy;
  const baselineProtein = veg * FOOD_GROUPS.veg.protein + dairy * FOOD_GROUPS.dairy.protein;
  const baselineCarb = veg * FOOD_GROUPS.veg.carb + fruit * FOOD_GROUPS.fruit.carb + dairy * FOOD_GROUPS.dairy.carb;
  const baselineFat = dairy * FOOD_GROUPS.dairy.fat;

  const proteinServings = Math.max(0, Math.round(((proteinG - baselineProtein) / FOOD_GROUPS.protein.protein) * 2) / 2);
  const fatFromProteinGroup = proteinServings * FOOD_GROUPS.protein.fat;
  const fatServings = Math.max(0, Math.round(((fatG - baselineFat - fatFromProteinGroup) / FOOD_GROUPS.fat.fat) * 2) / 2);
  const grainServings = Math.max(0, Math.round(((carbG - baselineCarb) / FOOD_GROUPS.grain.carb) * 2) / 2);

  return { grain: grainServings, protein: proteinServings, dairy, veg, fruit, fat: fatServings };
}

/* Simple additive note: how many extra 全穀雜糧 servings a training day carries vs. the weekly average */
function computeCarbDelta(dayResults, avgCarbG) {
  const maxDay = dayResults.reduce((m, d) => Math.max(m, d.carbG), avgCarbG);
  const extraG = maxDay - avgCarbG;
  return extraG > 5 ? Math.round((extraG / FOOD_GROUPS.grain.carb) * 2) / 2 : 0;
}

/* ── ACSM risk screening ── */
function computeAcsmRisk() {
  let score = 0;
  document.querySelectorAll('#acsm-list input[type=checkbox]').forEach(cb => {
    if (cb.checked) score += parseInt(cb.dataset.acsm, 10);
  });
  const el = document.getElementById('acsm-result');
  el.classList.remove('risk-low', 'risk-mid', 'risk-high');
  if (score <= 0) {
    el.classList.add('risk-low');
    el.textContent = `低風險（分數 ${score}）：無明顯風險因子或少於 2 項，一般可安全開始中低強度運動。`;
  } else if (score <= 2) {
    el.classList.add('risk-mid');
    el.textContent = `中風險（分數 ${score}）：建議在開始較高強度運動或大幅熱量赤字計畫前，先諮詢醫師。`;
  } else {
    el.classList.add('risk-high');
    el.textContent = `高風險（分數 ${score}）：建議先諮詢醫師評估後，再開始運動計畫或調整飲食熱量。`;
  }
}

/* ── Main render ── */
function render() {
  const sex = document.getElementById('in-sex').value;
  const age = parseFloat(document.getElementById('in-age').value) || 0;
  const weight = parseFloat(document.getElementById('in-weight').value) || 0;
  const height = parseFloat(document.getElementById('in-height').value) || 0;
  const bfr = parseFloat(document.getElementById('in-bfr').value);
  const target = parseFloat(document.getElementById('in-target').value) || weight;
  const pal = parseFloat(document.getElementById('in-pal').value) || 1.55;
  const goalKey = document.getElementById('in-goal').value;
  const dietKey = document.getElementById('in-diettype').value;

  if (!weight || !height || !age) return;

  const mifflin = bmrMifflin(weight, height, age, sex);
  const hb = bmrHarrisBenedict(weight, height, age, sex);
  document.getElementById('out-bmr-mifflin').textContent = fmt(mifflin) + ' kcal';
  document.getElementById('out-bmr-hb').textContent = fmt(hb) + ' kcal';

  if (bfr && bfr > 0) {
    const lbm = weight * (100 - bfr) / 100;
    document.getElementById('out-bmr-katch').textContent = fmt(bmrKatch(lbm)) + ' kcal';
    document.getElementById('katch-sub').textContent = `以體脂率換算除脂體重 ${lbm.toFixed(1)} kg`;
  } else {
    const lbmEst = estimateLBM(weight, height, sex);
    document.getElementById('out-bmr-katch').textContent = fmt(bmrKatch(lbmEst)) + ' kcal';
    document.getElementById('katch-sub').textContent = '未輸入體脂率，以身高體重估算除脂體重';
  }

  const tdee = mifflin * pal;
  document.getElementById('out-tdee').textContent = fmt(tdee) + ' kcal';

  const goal = GOALS[goalKey];
  const byPct = tdee * goal.pct;
  const byKcal = tdee + goal.kcal;
  const targetKcal = (byPct + byKcal) / 2;
  document.getElementById('out-target-kcal').textContent = fmt(targetKcal) + ' kcal';
  document.getElementById('target-kcal-sub').textContent = goal.label;

  const deficit = targetKcal - tdee;
  const daysToGoal = deficit !== 0 ? Math.round((Math.abs(target - weight) * 7700) / Math.abs(deficit)) : Infinity;
  document.getElementById('out-days').textContent = isFinite(daysToGoal) ? daysToGoal + ' 天' : '—';

  const feasEl = document.getElementById('feasibility-msg');
  if (targetKcal < mifflin) {
    feasEl.className = 'calc-feasibility bad';
    feasEl.textContent = '⚠️ 目標攝取熱量低於估算 BMR，長期執行可能影響代謝與健康，建議放寬熱量赤字。';
  } else if (Math.abs(deficit) > 550) {
    feasEl.className = 'calc-feasibility warn';
    feasEl.textContent = '可行，但熱量調整幅度較大，建議循序漸進並留意疲勞與恢復狀況。';
  } else {
    feasEl.className = 'calc-feasibility ok';
    feasEl.textContent = '✅ 可行，落在一般建議的溫和熱量調整範圍內。';
  }

  /* Macros — computed per day (universal weekly schedule), then averaged for the summary cards */
  const proteinGkg = parseFloat(document.getElementById('in-protein-gkg').value);
  const dietType = DIET_TYPES[dietKey];
  document.getElementById('diettype-hint').textContent =
    `蛋白質採你選擇的 ${proteinGkg} g/kg 體重／天計算；其餘熱量依「${dietType.label}」的脂肪:碳水 = ${dietType.f}:${dietType.c} 比例分配，並依第 3 節的訓練排程逐日調整碳水。`;

  const dayResults = ccPlan.map(dayType => computeDayMacros(weight, targetKcal, proteinGkg, dietKey, dietType, dayType));
  const avg = key => dayResults.reduce((s, d) => s + d[key], 0) / dayResults.length;
  const proteinG = avg('proteinG'), proteinKcal = avg('proteinKcal');
  const carbG = avg('carbG'), carbKcal = avg('carbKcal');
  const fatG = avg('fatG'), fatKcal = avg('fatKcal');

  document.getElementById('out-protein-g').textContent = round(proteinG) + ' g';
  document.getElementById('out-protein-detail').textContent = `${round(proteinKcal)} kcal · ${((proteinKcal/targetKcal)*100).toFixed(0)}% · ${proteinGkg} g/kg · 每日固定`;
  document.getElementById('dri-protein').textContent = driBadge((proteinKcal/targetKcal)*100, DRI.protein);

  document.getElementById('out-carb-g').textContent = round(carbG) + ' g（週平均）';
  document.getElementById('out-carb-detail').textContent = `${round(carbKcal)} kcal · ${((carbKcal/targetKcal)*100).toFixed(0)}%（依訓練日不同，見下方明細）`;
  document.getElementById('dri-carb').textContent = driBadge((carbKcal/targetKcal)*100, DRI.carb);

  document.getElementById('out-fat-g').textContent = round(fatG) + ' g（週平均）';
  document.getElementById('out-fat-detail').textContent = `${round(fatKcal)} kcal · ${((fatKcal/targetKcal)*100).toFixed(0)}%（彈性項）`;
  document.getElementById('dri-fat').textContent = driBadge((fatKcal/targetKcal)*100, DRI.fat);

  renderWeekGrid(dayResults);
  renderServings(proteinG, fatG, carbG, dayResults);
  renderMealPlan(dayResults);
}

let ccPlan = DEFAULT_CC_PLAN.slice();

/* Section 3 — the schedule picker itself. Built once; independent of any computed values. */
function renderSchedule() {
  const grid = document.getElementById('schedule-grid');
  if (!grid) return;
  grid.innerHTML = ccPlan.map((dayType, i) => `
    <div class="stat-row">
      <div class="stat-row-label"><div class="stat-row-title">週${DAYS[i]}</div></div>
      <select class="schedule-select" data-day="${i}">
        <option value="high" ${dayType === 'high' ? 'selected' : ''}>高強度</option>
        <option value="low" ${dayType === 'low' ? 'selected' : ''}>低強度</option>
        <option value="rest" ${dayType === 'rest' ? 'selected' : ''}>休息</option>
      </select>
    </div>
  `).join('');

  grid.querySelectorAll('select[data-day]').forEach(sel => {
    sel.addEventListener('change', () => {
      ccPlan[parseInt(sel.dataset.day, 10)] = sel.value;
      render();
    });
  });
}

/* Section 5 — read-only 7-day macro breakdown reflecting the schedule above */
function renderWeekGrid(dayResults) {
  const grid = document.getElementById('week-grid');
  if (!grid) return;
  let lowFatDay = false;

  grid.innerHTML = ccPlan.map((dayType, i) => {
    const d = dayResults[i];
    if (d.fatG < 20) lowFatDay = true;
    return `
      <tr>
        <td>週${DAYS[i]}<br><span class="supp-sub">${SHORT_LABEL[dayType]}</span></td>
        <td>${round(d.proteinG)}g</td>
        <td>${round(d.carbG)}g</td>
        <td>${round(d.fatG)}g</td>
      </tr>
    `;
  }).join('');

  document.getElementById('cc-fat-warning').style.display = lowFatDay ? '' : 'none';
}

function renderServings(proteinG, fatG, carbG, dayResults) {
  const grid = document.getElementById('servings-grid');
  if (!grid) return;
  const s = computeServings(proteinG, fatG, carbG);

  const rows = [
    ['grain', s.grain], ['protein', s.protein], ['dairy', s.dairy],
    ['veg', s.veg], ['fruit', s.fruit], ['fat', s.fat],
  ];
  grid.innerHTML = rows.map(([key, count]) => {
    const g = FOOD_GROUPS[key];
    return `
      <div class="stat-row">
        <div class="stat-row-label">
          <div class="stat-row-title">${g.label}</div>
          <div class="stat-row-sub">例如：${g.example}</div>
        </div>
        <div class="stat-row-num">${count} 份</div>
      </div>
    `;
  }).join('');

  const delta = computeCarbDelta(dayResults, carbG);
  const deltaEl = document.getElementById('servings-carb-delta');
  if (delta > 0) {
    deltaEl.style.display = '';
    deltaEl.textContent = `訓練日（碳水最高的一天）比週平均多需要約 +${delta} 份全穀雜糧。`;
  } else {
    deltaEl.style.display = 'none';
  }
}

/* 6b — split each day's already-computed macros evenly across N meals
   (even distribution, per ISSN nutrient timing: Kerksick et al. 2017; Areta et al. 2013) */
function computeMealSplit(dayResults, mealCount) {
  return dayResults.map(d => {
    const meals = [];
    for (let i = 0; i < mealCount; i++) {
      meals.push({
        proteinG: d.proteinG / mealCount,
        carbG: d.carbG / mealCount,
        fatG: d.fatG / mealCount,
      });
    }
    return meals;
  });
}

function renderMealPlan(dayResults) {
  const table = document.getElementById('mealplan-table');
  if (!table) return;
  const mealCount = parseInt(document.getElementById('in-mealcount').value, 10);
  const noteEl = document.getElementById('mealplan-168-note');
  noteEl.style.display = mealCount === 2 ? '' : 'none';

  const weekMeals = computeMealSplit(dayResults, mealCount);
  const mealHeaders = Array.from({ length: mealCount }, (_, i) => `<th>第 ${i + 1} 餐</th>`).join('');
  const rows = ccPlan.map((dayType, i) => {
    const cells = weekMeals[i].map(m =>
      `<td>蛋白 ${round(m.proteinG)}g<br>碳水 ${round(m.carbG)}g<br>脂肪 ${round(m.fatG)}g</td>`
    ).join('');
    return `<tr><td>週${DAYS[i]}<br><span class="supp-sub">${SHORT_LABEL[dayType]}</span></td>${cells}</tr>`;
  }).join('');

  table.innerHTML = `<thead><tr><th>星期</th>${mealHeaders}</tr></thead><tbody>${rows}</tbody>`;
}

document.querySelectorAll('#in-sex, #in-age, #in-weight, #in-height, #in-bfr, #in-target, #in-pal, #in-protein-gkg, #in-diettype, #in-mealcount')
  .forEach(el => el.addEventListener('input', render));

/* Changing Goal auto-suggests a matching protein g/kg default (still overridable afterward) */
document.getElementById('in-goal').addEventListener('input', () => {
  const suggested = PROTEIN_GKG_SUGGEST[document.getElementById('in-goal').value];
  if (suggested != null) document.getElementById('in-protein-gkg').value = suggested;
  render();
});

document.querySelectorAll('#acsm-list input[type=checkbox]').forEach(cb => cb.addEventListener('change', computeAcsmRisk));

renderSchedule();
render();
computeAcsmRisk();
</script>
