  .res-table { table-layout: fixed; }
  .res-table .col-year { width: 5rem; }
  .res-table .col-pm { width: 5.5rem; }
  .res-table .col-del { width: 2.5rem; }
  /* :global — these selects/inputs are injected by renderResidences() via innerHTML,
     so they don't carry Astro's scope attribute; scope stays on the static .res-table. */
  .res-table :global(select), .res-table :global(input) {
    background: var(--color-bg); border: 1px solid var(--color-border); color: var(--color-text);
    padding: 0.4rem 0.5rem; border-radius: var(--radius-sm); font-size: 0.85rem; font-family: var(--font-sans);
    width: 100%; max-width: 100%; min-width: 0; box-sizing: border-box;
  }
  .res-table :global(select) { text-overflow: ellipsis; overflow: hidden; white-space: nowrap; }
  .res-table :global(.res-pm) { white-space: nowrap; }
  .res-pm { white-space: nowrap; color: var(--color-text-muted); }
  .res-del {
    background: transparent; border: none; color: var(--color-text-muted); cursor: pointer;
    font-size: 1rem; padding: 0.2rem 0.4rem; border-radius: var(--radius-sm);
  }
  .res-del:hover { color: #e5484d; background: var(--color-surface); }
  .res-controls { display: flex; justify-content: space-between; align-items: center; gap: 1rem; margin-top: 0.8rem; flex-wrap: wrap; }
  .res-summary { font-size: 0.85rem; color: var(--color-accent); font-weight: 600; margin: 0; }

  /* Results */
  .result-profile {
    font-size: 1rem; font-weight: 700; line-height: 1.6;
    padding: 1rem 1.25rem; border-radius: var(--radius-md);
    border: 1px solid var(--color-border); border-left: 4px solid var(--color-accent);
    background: var(--color-surface); margin-bottom: var(--spacing-md);
  }
  .result-profile.ok { border-left-color: #2fbf71; }
