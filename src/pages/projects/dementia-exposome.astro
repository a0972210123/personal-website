const EXPO_FACTORS = ['hypertension', 'diabetes', 'obesity', 'smoking', 'physical_inactivity'];
const FACTOR_LABEL = { hypertension: ['高血壓', 'Hypertension'], diabetes: ['糖尿病', 'Diabetes'],
  obesity: ['肥胖', 'Obesity'], smoking: ['吸菸', 'Smoking'], physical_inactivity: ['身體活動不足', 'Physical inactivity'] };
const PAF_COMPOSITE = { bins: [20, 24, 28, 32, 36], legendZh: '可調控失智風險 PAF %', legendEn: 'attributable risk PAF %', unitZh: '%', unitEn: '%', decimals: 1 };
const PAF_FACTOR = { bins: [2, 4, 6, 8, 10], legendZh: '單因子 PAF %', legendEn: 'single-factor PAF %', unitZh: '%', unitEn: '%', decimals: 1 };
function isExpo(m) { return m === 'composite' || EXPO_FACTORS.includes(m); }
function expoNat() {   // national exposome value for the current mode+country
  const e = EXPOSOME && EXPOSOME[mapCountry]; if (!e) return null;
  if (mapMode === 'composite') return e.composite_paf_pct;
  const f = e.factors[mapMode]; return f ? f.paf_pct : null;
}
function curBins() {
