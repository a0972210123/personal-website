/* ── Result visuals: radar (category profile) + gauge (brain-age) — inline SVG, no deps ── */
let catView = 'radar';   // 'radar' | 'list'

/* brain-years attributable to each domain: λ·Σln(RR)/ln2·T_double (uncapped, per category) */
function domainYears(r) {
  const lnByCat = {};
  r.factors.forEach(f => { lnByCat[f.cat] = (lnByCat[f.cat] || 0) + Math.log(f.rr); });
  return CATS.map(([key]) => ({
    key, years: LAMBDA * (lnByCat[key] || 0) / Math.log(2) * r.tDouble,
    count: r.factors.filter(f => f.cat === key).length,
  }));
}
function applyCatView() {
  const radar = $('out-radar'), list = $('out-categories');
  if (radar) radar.style.display = catView === 'radar' ? '' : 'none';
  if (list) list.style.display = catView === 'list' ? '' : 'none';
  document.querySelectorAll('.cat-view-btn').forEach(b => b.classList.toggle('is-active', b.dataset.view === catView));
}
function renderRadar(r) {
  const el = $('out-radar');
  if (!el) return;
  const dom = domainYears(r), N = dom.length, cx = 150, cy = 140, R = 86;
  const vals = dom.map(d => Math.max(0, d.years));
  const niceMax = Math.max(2, Math.ceil(Math.max(...vals)));   // outer ring = whole years
  const pt = (i, frac) => {
    const a = (-90 + i * (360 / N)) * Math.PI / 180;
    return [cx + R * frac * Math.cos(a), cy + R * frac * Math.sin(a)];
  };
  const poly = pts => pts.map(p => p[0].toFixed(1) + ',' + p[1].toFixed(1)).join(' ');
  let grid = '';
  for (let k = 1; k <= 3; k++) grid += `<polygon class="radar-ring" points="${poly(dom.map((_, i) => pt(i, k / 3)))}"/>`;
  for (let i = 0; i < N; i++) { const [x, y] = pt(i, 1); grid += `<line class="radar-spoke" x1="${cx}" y1="${cy}" x2="${x.toFixed(1)}" y2="${y.toFixed(1)}"/>`; }
  const dpts = dom.map(d => pt(dom.indexOf(d), Math.min(1, Math.max(0, d.years) / niceMax)));
  const dataPoly = `<polygon class="radar-area" points="${poly(dpts)}"/>`;
  let marks = '', labels = '', valLabels = '';
  dom.forEach((d, i) => {
    const [dx, dy] = dpts[i];
    const nm = L(CAT_SHORT[d.key][0], CAT_SHORT[d.key][1]);
    const yv = Math.max(0, d.years);
    const tip = `${nm}: +${yv.toFixed(1)} ${L('年', 'yr')}` + (d.count ? `（${d.count}）` : '');
    marks += `<circle class="radar-hit" cx="${dx.toFixed(1)}" cy="${dy.toFixed(1)}" r="15"><title>${tip}</title></circle>`;
    marks += `<circle class="radar-dot" cx="${dx.toFixed(1)}" cy="${dy.toFixed(1)}" r="3.5"/>`;
    const [lx, ly] = pt(i, 1.28);
    const anchor = lx > cx + 6 ? 'start' : lx < cx - 6 ? 'end' : 'middle';
    labels += `<text class="radar-label" x="${lx.toFixed(1)}" y="${(ly + 3).toFixed(1)}" text-anchor="${anchor}">${nm}</text>`;
    // small "+x" value beside each non-zero data point
    if (yv >= 0.05) {
      const [vx, vy] = pt(i, Math.min(1, yv / niceMax) + 15 / R);
      const va = vx > cx + 6 ? 'start' : vx < cx - 6 ? 'end' : 'middle';
      valLabels += `<text class="radar-val" x="${vx.toFixed(1)}" y="${(vy + 3).toFixed(1)}" text-anchor="${va}">+${yv.toFixed(1)}</text>`;
    }
  });
  const scale = `<text class="radar-scale" x="4" y="14" text-anchor="start">${L('外圈', 'outer ring')} = +${niceMax} ${L('年', 'yr')}</text>`;
  const empty = r.count === 0 ? `<text class="radar-empty" x="${cx}" y="${cy + 4}" text-anchor="middle">${L('未偵測到可調整因子', 'no modifiable factors')}</text>` : '';
  el.innerHTML = `<svg viewBox="0 0 300 280" role="img" aria-label="${L('各面向風險雷達圖（腦齡年數）', 'risk radar by category (brain-years)')}">${grid}${dataPoly}${marks}${valLabels}${labels}${scale}${empty}</svg>`;
}
function renderGauge(r) {
  const el = $('out-gauge');
  if (!el) return;
  const GMAX = 12, t = Math.max(0, Math.min(1, r.dMid / GMAX));   // GMAX matches the ±12-yr cap
  const color = r.band === 'few' ? '#2fbf71' : r.band === 'several' ? '#f5a623' : '#e5484d';
  const cx = 100, cy = 104, rad = 82;
  const P = deg => [cx + rad * Math.cos(deg * Math.PI / 180), cy + rad * Math.sin(deg * Math.PI / 180)];
  const arc = (a0, a1) => {
    const [x0, y0] = P(a0), [x1, y1] = P(a1);
    return `M ${x0.toFixed(1)} ${y0.toFixed(1)} A ${rad} ${rad} 0 ${Math.abs(a1 - a0) > 180 ? 1 : 0} 1 ${x1.toFixed(1)} ${y1.toFixed(1)}`;
  };
  el.innerHTML = `<svg viewBox="0 0 200 134" role="img" aria-label="${L('腦齡加速儀表', 'brain-age gauge')}">
    <path class="gauge-track" d="${arc(180, 360)}"/>
    <path class="gauge-val" d="${arc(180, 180 + 180 * t)}" style="stroke:${color}"/>
    <text class="gauge-tick" x="14" y="128" text-anchor="middle">0</text>
    <text class="gauge-tick" x="186" y="128" text-anchor="middle">${GMAX}+</text>
  </svg>`;
}

function renderResults(r) {
  // 1) categorical profile (LEAD)
  const profileEl = $('out-profile');
  const bandTxt = { few: L('少數', 'a few'), several: L('數項', 'several'), many: L('多項', 'many') }[r.band];
  const cls = r.band === 'few' ? 'ok' : r.band === 'several' ? 'warn' : 'bad';
  profileEl.className = 'result-profile ' + cls;
  profileEl.innerHTML = r.count === 0
    ? `${L('目前沒有偵測到可調整的風險因子 — 很好！', 'No modifiable risk factors detected — great!')}<span class="rp-sub">${L('持續維持這些好習慣。', 'Keep up these healthy habits.')}</span>`
    : `${L(`你目前有 ${r.count} 項可調整因子（${bandTxt}）。`, `You currently have ${r.count} modifiable factor${r.count > 1 ? 's' : ''} (${bandTxt}).`)}<span class="rp-sub">${L('針對這些因子採取行動，在族群層級與較低的失智風險相關。', 'Acting on these is associated with lower dementia risk at the population level.')}</span>`;

