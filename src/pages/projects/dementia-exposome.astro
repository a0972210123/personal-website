async function loadCountryData(cc) {
  const cfg = MAP_CFG[cc];
  let geo, prev = {}, pm = {}, names = {}, prevMeta = null;
  if (cfg.topo) { const t = await fetch(cfg.topo).then(r => r.json()); geo = window.topojson.feature(t, t.objects[cfg.topoObject]); }
  else { geo = await fetch(cfg.geojson).then(r => r.json()); }
  if (cfg.prev) { const p = await fetch(cfg.prev).then(r => r.ok ? r.json() : null).catch(() => null); if (p) { Object.assign(prev, p.byTown || {}); prevMeta = p.meta || null; } }
  if (cfg.pm) {
    const d = await fetch(cfg.pm).then(r => r.json());
    if (d.districts) for (const [k, v] of Object.entries(d.districts)) pm[k] = v.pm25;
    else if (d.units) Object.assign(pm, d.units);
  }
  geo.features.forEach(f => {
    const p = f.properties, code = p[cfg.codeProp];
    names[code] = cc === 'tw'
      ? { zh: (p.COUNTYNAME || '') + p.TOWNNAME, en: (p.TOWNENG || p.TOWNNAME) + (p.COUNTYENG ? ', ' + p.COUNTYENG : '') }
      : { zh: p.nameLocal || p.name || code, en: p.name || code };
  });
  return { geo, prev, pm, names, cfg, prevMeta };
}
