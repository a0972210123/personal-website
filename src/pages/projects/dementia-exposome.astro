function renderResults(r) {
  // 1) categorical profile (LEAD)
  const profileEl = $('out-profile');
  const bandTxt = { few: L('少數', 'a few'), several: L('數項', 'several'), many: L('多項', 'many') }[r.band];
  const cls = r.band === 'few' ? 'ok' : r.band === 'several' ? 'warn' : 'bad';
  profileEl.className = 'result-profile ' + cls;
  profileEl.innerHTML = r.count === 0
    ? `${L('目前沒有偵測到可調整的風險因子 — 很好！', 'No modifiable risk factors detected — great!')}<span class="rp-sub">${L('持續維持這些好習慣。', 'Keep up these healthy habits.')}</span>`
    : `${L(`你目前有 ${r.count} 項可調整因子（${bandTxt}）。`, `You currently have ${r.count} modifiable factor${r.count > 1 ? 's' : ''} (${bandTxt}).`)}<span class="rp-sub">${L('針對這些因子採取行動，在族群層級與較低的失智風險相關。', 'Acting on these is associated with lower dementia risk at the population level.')}</span>`;

  // 2) brain-age gap (secondary, clearly educational) + a transparent derivation
  $('out-brainage').textContent = `≈ +${r.dMid.toFixed(1)} ${L('年', 'yr')}`;
  $('out-brainage-caption').textContent = L(
    `估計範圍 +${r.dLo.toFixed(1)} 到 +${r.dHi.toFixed(1)} 年${r.capped ? '（已達上限）' : ''}。這是教育性比喻，非影像量測的真實腦齡，也不是個人預測。`,
    `Estimated range +${r.dLo.toFixed(1)} to +${r.dHi.toFixed(1)} yr${r.capped ? ' (capped)' : ''}. An educational illustration — not a measured brain age, and not a personal prediction.`
  );
  const frows = r.factors.map(f => {
    const lab = FACTOR_LABELS[f.key] ? L(FACTOR_LABELS[f.key][0], FACTOR_LABELS[f.key][1]) : f.key;
    const extra = f.key === 'pm25' && r.meanPM != null ? `（${r.meanPM.toFixed(1)} µg/m³）` : '';
    return `<li>${lab}${extra} — RR ${f.rr.toFixed(2)}</li>`;
  }).join('');
  $('out-brainage-detail').innerHTML = `<details class="ba-detail"><summary>${L('如何算出這個數字？', 'How is this number derived?')}</summary><div class="ba-detail-body">
    <p>${L('納入計算的因子與其相對風險（RR，主要來自 2024 Lancet 委員會）：', 'Factors included and their relative risks (RR, mainly the 2024 Lancet Commission):')}</p>
    <ul class="ba-factors">${frows || `<li>${L('（目前沒有可調整因子）', '(no modifiable factors)')}</li>`}</ul>
    <ol class="ba-steps">
      <li>${L(`各因子 RR 相乘 → 原始合併 RR ≈ <strong>${r.rrProd.toFixed(2)}</strong>`, `Multiply the RRs → raw combined RR ≈ <strong>${r.rrProd.toFixed(2)}</strong>`)}</li>
      <li>${L(`乘上重疊縮減係數 λ = ${r.lambda}（因子彼此相關，直接相乘會高估；λ 近似 Lancet 委員會的 communality 調整）→ 有效 RR = 原始RR<sup>${r.lambda}</sup> ≈ <strong>${r.rrEff.toFixed(2)}</strong>`, `Apply overlap-shrinkage λ = ${r.lambda} (factors are correlated; multiplying raw RRs overstates risk — λ approximates the Commission's communality adjustment) → effective RR = rawRR<sup>${r.lambda}</sup> ≈ <strong>${r.rrEff.toFixed(2)}</strong>`)}</li>
      <li>${L(`換算成腦齡：log₂(有效 RR) × ${r.tDouble} ≈ <strong>+${r.dMid.toFixed(1)} 年</strong>${r.capped ? '（已達上限）' : ''}。失智風險每約 ${r.tDouble} 年翻倍，log₂ 把「風險倍數」換算成「相當於老了幾年」（上限約 ±12 年）。`, `Convert to brain-years: log₂(effective RR) × ${r.tDouble} ≈ <strong>+${r.dMid.toFixed(1)} yr</strong>${r.capped ? ' (capped)' : ''}. Dementia risk roughly doubles every ${r.tDouble} years; log₂ turns the risk multiple into "years older" (capped at about ±12 yr).`)}</li>
    </ol>
    <p class="ba-detail-note">${L('λ = 0.6 與 ±12 年上限是本工具為避免高估設的參數（非已發表常數）。這是教育性估計，非個人預測。', 'λ = 0.6 and the ±12-yr cap are this tool\'s parameters to avoid overstatement (not published constants). Educational estimate, not a personal prediction.')}</p>
  </div></details>`;

  // 3) by category
  const catCount = {};
  r.factors.forEach(f => { catCount[f.cat] = (catCount[f.cat] || 0) + 1; });
  $('out-categories').innerHTML = CATS.map(([key, zh, en]) => {
    const n = catCount[key] || 0;
    const badge = n === 0 ? '✅' : '⚠️';
    const sub = n === 0
      ? L('無明顯因子', 'no notable factor')
      : L(`${n} 項因子`, `${n} factor${n > 1 ? 's' : ''}`);
    return `<div class="stat-row">
      <div class="stat-row-label">
        <div class="stat-row-title">${L(zh, en)}</div>
        <div class="stat-row-sub">${sub}</div>
      </div>
      <div class="stat-row-num"><span class="cat-badge">${badge}</span></div>
    </div>`;
  }).join('');

  // 4) exposome / PM2.5 detail — WHO guideline → your annual avg → cumulative comparison → provenance
  const ex = $('out-exposome');
  if (r.res) {
    ex.style.display = '';
    const mult = (r.meanPM / PM_REF).toFixed(1);
    const yourCum = Math.round(r.res.dose);
    const whoCum = PM_REF * r.res.years;
    ex.innerHTML = L(
      `🌫️ <strong>WHO 建議年均 PM2.5 ≤ ${PM_REF} µg/m³。</strong><br>` +
      `你的時間加權年均暴露 ≈ <strong>${r.meanPM.toFixed(1)} µg/m³</strong>，約為 WHO 建議的 <strong>${mult}×</strong>。<br>` +
      `在約 ${r.res.years} 年的居住史中，你的估計累積暴露 ≈ <strong>${yourCum.toLocaleString()} µg/m³·年</strong>；` +
      `同樣年數下、符合 WHO 標準者僅 ${whoCum.toLocaleString()} µg/m³·年 —— 你約為其 <strong>${mult}×</strong>。<br>` +
      `<em>PM2.5 採用 ACAG 衛星逐年資料（V6.GL.03，1998–2024）；1998 年以前的居住年份沿用 1998 年數值估計。</em>`,
      `🌫️ <strong>WHO guideline: annual PM2.5 ≤ ${PM_REF} µg/m³.</strong><br>` +
      `Your time-weighted annual exposure ≈ <strong>${r.meanPM.toFixed(1)} µg/m³</strong>, about <strong>${mult}×</strong> the WHO guideline.<br>` +
      `Over ~${r.res.years} years of residence, your estimated cumulative exposure ≈ <strong>${yourCum.toLocaleString()} µg/m³·years</strong>; ` +
      `someone meeting the WHO guideline for the same span would be just ${whoCum.toLocaleString()} µg/m³·years — you are about <strong>${mult}×</strong> that.<br>` +
      `<em>PM2.5 uses ACAG satellite annual data (V6.GL.03, 1998–2024); residence years before 1998 reuse the 1998 value.</em>`
    );
  } else { ex.style.display = 'none'; }

  // 5) actions
  const seen = new Set();
  const items = r.factors.map(f => f.key).filter(k => { if (seen.has(k) || !ACTIONS[k]) return false; seen.add(k); return true; });
  $('out-actions').innerHTML = items.length === 0
    ? `<li>${L('沒有需要優先處理的可調整因子 — 繼續保持健康的生活型態與環境。', 'No priority modifiable factors — keep up a healthy lifestyle and environment.')}</li>`
    : items.map(k => { const a = ACTIONS[k]; return `<li><span class="act-cat">${L(a[0], a[1])}</span>${L(a[2], a[3])}</li>`; }).join('');
}

/* ── Wizard navigation ── */
let currentStep = 1;
let lastResult = null;
function showStep(n) {
  currentStep = n;
  document.querySelectorAll('.wizard-step').forEach(s => s.classList.toggle('is-active', +s.dataset.step === n));
  document.querySelectorAll('.wizard-steps li').forEach(li => {
    const s = +li.dataset.step;
    li.classList.toggle('is-active', s === n);
    li.classList.toggle('is-done', s < n);
  });
  if (n === 4) { lastResult = computeResult(); renderResults(lastResult); }
  const wiz = document.querySelector('.wizard');
  if (wiz) window.scrollTo({ top: wiz.getBoundingClientRect().top + window.scrollY - 20, behavior: 'smooth' });
}

