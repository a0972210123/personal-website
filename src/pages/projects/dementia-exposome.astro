    border: 1px solid var(--color-accent); background: var(--color-accent); color: #fff;
  }
  .wz-btn:hover { background: var(--color-accent-hover); border-color: var(--color-accent-hover); }
  .wz-btn.wz-back { background: transparent; color: var(--color-text-muted); border-color: var(--color-border); }
  .wz-btn.wz-back:hover { color: var(--color-text); background: var(--color-surface); }
  .wz-btn.wz-ghost { background: transparent; color: var(--color-accent); }
  .wz-btn.wz-ghost:hover { background: var(--color-surface); }

  /* Residence table */
  .supp-table-wrap { overflow-x: auto; }
  .supp-table { width: 100%; border-collapse: collapse; font-size: 0.85rem; min-width: 460px; }
  .supp-table th, .supp-table td { text-align: left; padding: 0.6rem 0.7rem; border-bottom: 1px solid var(--color-border); vertical-align: middle; }
  .supp-table th { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-text-muted); }
  /* Fixed layout so the 246-country picker can't stretch the Country column;
