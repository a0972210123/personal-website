/* readable labels for the brain-age calculation breakdown */
const FACTOR_LABELS = {
  education: ['教育程度較低', 'Less education'], hearing: ['聽力損失（未矯治）', 'Hearing loss (untreated)'],
  vision: ['視力損失（未矯治）', 'Vision loss (untreated)'], htn: ['高血壓', 'Hypertension'],
