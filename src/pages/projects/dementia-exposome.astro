/* ── Choropleth map (Leaflet + topojson-client, vendored) — country switcher.
     Taiwan: town-level, prevalence + PM2.5. Japan/Korea: admin-1, PM2.5 only
     (prevalence needs gov population/survey data — see data-download-points.md). ── */
let map = null, geoLayer = null, legendCtl = null;
let mapCountry = 'tw', mapMode = 'prevalence';
let GEO = null;                    // current FeatureCollection
let VAL = { prev: {}, pm: {} };    // current country: code -> value
let NAMES = {};                    // current country: code -> {zh, en}
const PREV_BINS = [12, 14, 16, 18, 20];   // modelled dementia per 1,000 residents
const PM_BINS = [12, 15, 18, 21, 24];      // PM2.5 µg/m³
const RAMP = ['#ffeda0', '#fed976', '#feb24c', '#fd8d3c', '#f03b20', '#bd0026'];
const MAP_CFG = {
  tw: { topo: '/data/geo/tw-districts.topo.json', topoObject: 'towns', codeProp: 'TOWNCODE',
        layers: ['prevalence', 'pm25'], fit: [[21.9, 119.3], [25.35, 122.05]],
        prev: '/data/dementia/tw-dementia-modelled.json', pm: '/data/pm25/tw-district-pm25.json' },
  jp: { geojson: '/data/geo/jp-admin1.geojson', codeProp: 'code', layers: ['pm25'],
        pm: '/data/pm25/jp-admin1-pm25.json' },
  kr: { geojson: '/data/geo/kr-admin1.geojson', codeProp: 'code', layers: ['pm25'],
        pm: '/data/pm25/kr-admin1-pm25.json' },
};

function codeOf(f) { return f.properties[MAP_CFG[mapCountry].codeProp]; }
function valueFor(code) { return mapMode === 'prevalence' ? VAL.prev[code] : VAL.pm[code]; }
function colorFor(v) {
  if (v == null) return '#e6e6e6';
  const bins = mapMode === 'prevalence' ? PREV_BINS : PM_BINS;
  let i = 0; while (i < bins.length && v > bins[i]) i++;
  return RAMP[i];
}
function styleFn(f) { return { fillColor: colorFor(valueFor(codeOf(f))), weight: 0.4, color: '#fff', fillOpacity: 0.82 }; }
function unitName(f) { const n = NAMES[codeOf(f)]; return n ? L(n.zh, n.en) : (f.properties.name || codeOf(f)); }
function tooltipFor(f) {
  const code = codeOf(f), name = unitName(f);
  if (mapMode === 'prevalence') {
    const v = VAL.prev[code];
    return `<b>${name}</b><br>${L('失智盛行（估計）', 'Dementia (modelled)')}: ${v != null ? v.toFixed(1) : '—'} ${L('／千人', 'per 1,000')}`;
  }
  const v = VAL.pm[code];
  return `<b>${name}</b><br>PM2.5: ${v != null ? v.toFixed(1) : '—'} µg/m³`;
}
function buildLegend() {
  if (!map) return;
  if (legendCtl) map.removeControl(legendCtl);
  legendCtl = window.L.control({ position: 'bottomright' });
  legendCtl.onAdd = () => {
    const div = window.L.DomUtil.create('div', 'map-legend');
    const bins = mapMode === 'prevalence' ? PREV_BINS : PM_BINS;
    const unit = mapMode === 'prevalence' ? L('失智／千人', 'dementia /1,000') : 'PM2.5 µg/m³';
    const edges = [0, ...bins];
    let html = `<b>${unit}</b><br>`;
    for (let i = 0; i < RAMP.length; i++) {
      const label = bins[i] != null ? `${edges[i]}–${bins[i]}` : `>${edges[edges.length - 1]}`;
      html += `<i style="background:${RAMP[i]}"></i>${label}<br>`;
    }
    div.innerHTML = html;
    return div;
  };
  legendCtl.addTo(map);
}
function syncModeButtons() {
  const layers = MAP_CFG[mapCountry].layers;
  document.querySelectorAll('.map-btn').forEach(b => {
    const on = layers.includes(b.dataset.mode);
    b.disabled = !on;
    b.classList.toggle('is-disabled', !on);
    b.classList.toggle('is-active', on && b.dataset.mode === mapMode);
  });
  const note = $('map-prev-note');
  if (note) note.style.display = layers.includes('prevalence') ? 'none' : '';
}
function applyMode() {
  if (!geoLayer) return;
  geoLayer.setStyle(styleFn);
  geoLayer.eachLayer(l => l.setTooltipContent(tooltipFor(l.feature)));
  buildLegend();
  syncModeButtons();
}
async function loadCountryData(cc) {
  const cfg = MAP_CFG[cc];
  let geo, prev = {}, pm = {}, names = {};
  if (cfg.topo) { const t = await fetch(cfg.topo).then(r => r.json()); geo = window.topojson.feature(t, t.objects[cfg.topoObject]); }
  else { geo = await fetch(cfg.geojson).then(r => r.json()); }
  if (cfg.prev) { const p = await fetch(cfg.prev).then(r => r.json()); Object.assign(prev, p.byTown || {}); }
  if (cfg.pm) {
    const d = await fetch(cfg.pm).then(r => r.json());
    if (d.districts) for (const [k, v] of Object.entries(d.districts)) pm[k] = v.pm25;
    else if (d.units) Object.assign(pm, d.units);
  }
  geo.features.forEach(f => {
    const p = f.properties, code = p[cfg.codeProp];
    names[code] = cc === 'tw'
      ? { zh: (p.COUNTYNAME || '') + p.TOWNNAME, en: (p.TOWNENG || p.TOWNNAME) + (p.COUNTYENG ? ', ' + p.COUNTYENG : '') }
      : { zh: p.nameLocal || p.name || code, en: p.name || code };
  });
  return { geo, prev, pm, names, cfg };
}
async function drawCountry(cc) {
  const d = await loadCountryData(cc);
  mapCountry = cc; GEO = d.geo; VAL = { prev: d.prev, pm: d.pm }; NAMES = d.names;
  if (!d.cfg.layers.includes(mapMode)) mapMode = d.cfg.layers[0];
  if (geoLayer) { map.removeLayer(geoLayer); geoLayer = null; }
  geoLayer = window.L.geoJSON(GEO, {
    style: styleFn,
    onEachFeature: (f, layer) => layer.bindTooltip(tooltipFor(f), { sticky: true }),
  }).addTo(map);
  if (d.cfg.fit) map.fitBounds(d.cfg.fit); else map.fitBounds(geoLayer.getBounds(), { padding: [8, 8] });
  buildLegend();
  syncModeButtons();
  setTimeout(() => map && map.invalidateSize(), 150);
}
async function initMap() {
  const el = $('map');
  if (!el || !window.L || !window.topojson) return;
  try {
    map = window.L.map(el, { scrollWheelZoom: false, attributionControl: true });
    map.attributionControl.setPrefix(false).addAttribution(
      L('界線 © NLSC／taiwan-atlas · Natural Earth｜PM2.5 © ACAG｜失智盛行率為模型估計值',
        'Boundaries © NLSC/taiwan-atlas · Natural Earth · PM2.5 © ACAG · dementia = modelled estimate'));
    await drawCountry('tw');
    document.querySelectorAll('.map-btn').forEach(b => b.addEventListener('click', () => {
      if (b.disabled) return;
      mapMode = b.dataset.mode; applyMode();
    }));
    const cs = $('map-country');
    if (cs) cs.addEventListener('change', () => drawCountry(cs.value));
  } catch (e) {
    console.error('map init failed:', e);
    el.innerHTML = `<p class="map-fail">${L('地圖資料載入失敗。', 'Map data failed to load.')}</p>`;
  }
}
function relabelMap() { if (map && geoLayer) applyMode(); }

/* ── Init ── */
async function init() {
  document.querySelectorAll('[data-goto]').forEach(b => b.addEventListener('click', () => showStep(+b.dataset.goto)));
  const addBtn = $('res-add');
  if (addBtn) addBtn.addEventListener('click', () => {
    const last = residences[residences.length - 1] || { country: 'TW', place: '63000', to: 2000 };
    residences.push({ country: last.country, place: last.place, from: last.to || 2000, to: 2026 });
    renderResidences();
  });
  // load real PM2.5 — Taiwan county series + world country series (ACAG) — in parallel
  try {
    const [cty, world] = await Promise.all([
      fetch('/data/pm25/tw-county-pm25.json').then(r => r.json()),
      fetch('/data/pm25/world-country-pm25.json').then(r => r.json()).catch(() => null),
    ]);
    COUNTY_PM = cty;
    COUNTY_LIST = Object.entries(COUNTY_PM.counties)
      .map(([code, c]) => [code, c.name, c.nameEn])
      .sort((a, b) => a[1].localeCompare(b[1], 'zh-Hant'));
    WORLD_PM = world;
  } catch (e) { COUNTY_LIST = FALLBACK_COUNTIES.slice(); }
  buildCountryList();
  if (!COUNTY_LIST.some(c => c[0] === residences[0].place)) residences[0].place = (COUNTY_LIST[0] || ['63000'])[0];

  applyOptionLangs();
  renderResidences();
  window.addEventListener('langchange', () => {
    applyOptionLangs();
    renderResidences();
    if (currentStep === 4 && lastResult) renderResults(lastResult);
    relabelMap();
  });
  initMap();
}
init();
</script>
