<script>
/* ── i18n helpers (mirror the site-wide data-lang + langchange pattern) ── */
const lang = () => document.documentElement.getAttribute('data-lang') === 'en' ? 'en' : 'zh';
const L = (zh, en) => lang() === 'en' ? en : zh;
const $ = (id) => document.getElementById(id);
const val = (id) => { const el = $(id); return el ? el.value : ''; };

/* ── Verified constants (dementia-exposome research round 3-D §2) ──
   Relative risks: 2024 Lancet Commission (Livingston 2024) + underlying meta-analyses.
   PM2.5 handled continuously (Lancet Planetary Health 2025, ~HR 1.08 per 5 µg/m³);
   the Lancet categorical air-pollution factor is intentionally NOT added (no double-count). */
const RR = {
  education: 1.6,   // less/no education
  hearing: 1.37,    // untreated hearing loss (2024 re-meta)
  vision: 1.47,     // untreated vision loss (Shang 2021)
  htn: 1.6,
  diabetes: 1.5,
  obesity: 1.6,
  inactive: 1.4,
  depression: 1.96, // 2024 re-meta
  isolation: 1.6,
  alcohol: 1.2,     // > 21 units/week
  tbi: 1.8,
  smokingCurrent: 1.6,
};
const RR_SMOKING_FORMER = Math.exp(0.5 * Math.log(RR.smokingCurrent)); // ~1.26, halfway on log axis
const LDL_RR_PER_MMOL = 1.08;   // per +1 mmol/L LDL-C (Lancet 2024 meta of 3 UK cohorts)
const LDL_REF = 2.6;            // mmol/L reference (≈ 100 mg/dL)
const LDL_MGDL_TO_MMOL = 0.0259; // mg/dL → mmol/L (TW/US labs report mg/dL)
const PM_REF = 5;              // WHO 2021 guideline µg/m³
const PM_RR_PER_5 = 1.08;      // per +5 µg/m³
const LAMBDA = 0.6;            // overlap shrinkage (approximates the Commission's communality adjustment)
const CAP_LN = Math.log(4.5);  // cap combined RR (~ +12 brain-years)
const T_DOUBLE = 5.5;          // dementia risk doubling time (yr); band 5.0–6.3

/* ── Real PM2.5 data (ACAG V6.GL.03; fetched from /data) ──
   Taiwan: county × year series (finer). Other countries: national × year series. */
let COUNTY_PM = null;        // { year0, year1, counties: {CODE:{name,nameEn,values:[…]}} }
let COUNTY_LIST = [];        // [[code, zh, en], …] Taiwan counties, built from data
let WORLD_PM = null;         // { year0, year1, countries: {Name:{values:[…]}} }
let COUNTRY_LIST = [];       // [[value, zh, en], …] country picker; 'TW' first
const FALLBACK_COUNTIES = [
  ['63000', '臺北市', 'Taipei City'], ['65000', '新北市', 'New Taipei City'],
  ['66000', '臺中市', 'Taichung City'], ['64000', '高雄市', 'Kaohsiung City'],
];
/* zh names for common countries (English name is used otherwise) */
const COUNTRY_ZH = {
  'Japan': '日本', 'South Korea': '南韓', 'Korea, Rep.': '南韓', 'China': '中國', 'Hong Kong': '香港',
  'Macao': '澳門', 'Singapore': '新加坡', 'Malaysia': '馬來西亞', 'Thailand': '泰國', 'Vietnam': '越南',
  'Viet Nam': '越南', 'Philippines': '菲律賓', 'Indonesia': '印尼', 'India': '印度', 'United States': '美國',
  'Canada': '加拿大', 'United Kingdom': '英國', 'Germany': '德國', 'France': '法國', 'Australia': '澳洲',
  'New Zealand': '紐西蘭', 'Netherlands': '荷蘭', 'Switzerland': '瑞士', 'Sweden': '瑞典', 'Italy': '義大利',
  'Spain': '西班牙', 'Austria': '奧地利',
};
const PM_FALLBACK = 18;      // µg/m³ when a series is missing / a fetch failed

function countryLabel(name) { return L(COUNTRY_ZH[name] || name, name); }
function buildCountryList() {
  const list = [['TW', '臺灣', 'Taiwan']];
  if (WORLD_PM) {
    Object.keys(WORLD_PM.countries).filter(n => n !== 'Taiwan')
      .sort((a, b) => countryLabel(a).localeCompare(countryLabel(b), 'zh-Hant'))
      .forEach(n => list.push([n, COUNTRY_ZH[n] || n, n]));
  }
  COUNTRY_LIST = list;
}
function optionsFrom(list, selected) {
  return list.map(([v, zh, en]) =>
    `<option value="${v}" ${v === selected ? 'selected' : ''}>${L(zh, en)}</option>`
  ).join('');
}
function countyOptions(selected) { return optionsFrom(COUNTY_LIST.length ? COUNTY_LIST : FALLBACK_COUNTIES, selected); }
function countryOptions(selected) { return optionsFrom(COUNTRY_LIST.length ? COUNTRY_LIST : [['TW', '臺灣', 'Taiwan']], selected); }

/* ── Auto-detect the visitor's country to pre-fill the first residence (soft default). ──
   Signal priority: Cloudflare edge (same-origin, IP-based) → browser locale → timezone.
   All client-side; the only network call is same-origin /cdn-cgi/trace (no third party,
   no API key, no geolocation prompt). Result is just a dropdown default the user can change. */
const ISO_NAME_OVERRIDE = {  // ISO alpha-2 → the name ACAG (world-country-pm25.json) uses, where it differs from Intl.DisplayNames('en')
  MM: 'Myanmar', HK: 'Hong Kong', MO: 'Macao', TR: 'Turkey', CZ: 'Czech Republic',
};
const TZ_COUNTRY = {  // tertiary fallback only (used when both trace and locale give nothing)
  'Asia/Taipei': 'TW', 'Asia/Tokyo': 'JP', 'Asia/Seoul': 'KR', 'Asia/Shanghai': 'CN',
  'Asia/Hong_Kong': 'HK', 'Asia/Macau': 'MO', 'Asia/Singapore': 'SG', 'Asia/Bangkok': 'TH',
  'Asia/Kuala_Lumpur': 'MY', 'Asia/Jakarta': 'ID', 'Asia/Manila': 'PH', 'Asia/Ho_Chi_Minh': 'VN',
  'Asia/Kolkata': 'IN', 'Asia/Dubai': 'AE', 'Europe/London': 'GB', 'Europe/Paris': 'FR',
  'Europe/Berlin': 'DE', 'Europe/Madrid': 'ES', 'Europe/Rome': 'IT', 'Europe/Amsterdam': 'NL',
  'America/New_York': 'US', 'America/Chicago': 'US', 'America/Los_Angeles': 'US', 'America/Denver': 'US',
  'America/Toronto': 'CA', 'America/Vancouver': 'CA', 'Australia/Sydney': 'AU', 'Pacific/Auckland': 'NZ',
};
async function detectCountryIso() {
  // 1) Cloudflare edge — returns "loc=XX" on the live pages.dev/mattye.dev; 404s on localhost.
  try {
    const ctrl = new AbortController();
    const t = setTimeout(() => ctrl.abort(), 1500);
    const txt = await fetch('/cdn-cgi/trace', { signal: ctrl.signal }).then(r => (r.ok ? r.text() : ''));
    clearTimeout(t);
    const m = txt.match(/^loc=([A-Z]{2})/m);
    if (m) return m[1];
  } catch (e) { /* offline / aborted / not on Cloudflare → fall through */ }
  // 2) Browser locale region (offline, explicit region only — avoid maximize() misfires)
  try {
    const langs = (navigator.languages && navigator.languages.length) ? navigator.languages : [navigator.language];
    for (const l of langs) { if (!l) continue; const r = new Intl.Locale(l).region; if (r) return r; }
  } catch (e) { /* Intl.Locale unsupported */ }
  // 3) Timezone (offline)
  try {
    const tz = Intl.DateTimeFormat().resolvedOptions().timeZone;
    if (tz && TZ_COUNTRY[tz]) return TZ_COUNTRY[tz];
  } catch (e) { /* no Intl */ }
  return null;
}
/* ISO alpha-2 → a residence-dropdown value ('TW', or an ACAG country name present in COUNTRY_LIST); null if unknown */
function isoToCountryValue(iso) {
  if (!iso) return null;
  iso = iso.toUpperCase();
  if (iso === 'TW') return 'TW';
  if (!WORLD_PM || !WORLD_PM.countries) return null;
  let name = ISO_NAME_OVERRIDE[iso];
  if (!name) { try { name = new Intl.DisplayNames(['en'], { type: 'region' }).of(iso); } catch (e) { return null; } }
  if (!name) return null;
  if (WORLD_PM.countries[name]) return name;                                   // exact
  const norm = s => s.toLowerCase().replace(/\s+sar\s+china$/, '').replace(/\s*\(.*\)$/, '').trim();
  const target = norm(name);
  return Object.keys(WORLD_PM.countries).find(k => norm(k) === target) || null; // normalized
}

/* average a year-indexed series over a residence span (years clamped; pre-1998 reuses the first value) */
function avgSeries(series, year0, year1, from, to) {
  let a = Math.min(Math.max(Number(from) || year0, year0), year1);
  let b = Math.min(Math.max(Number(to) || year1, year0), year1);
  if (b < a) { const t = a; a = b; b = t; }
  let sum = 0, n = 0;
  for (let y = a; y <= b; y++) { const v = series[y - year0]; if (v != null) { sum += v; n++; } }
  return n ? sum / n : null;
}

/* PM2.5 for a residence (country + optional TW county) averaged over a span */
function pmForSpan(country, place, from, to) {
  const years = Math.max(1, (Number(to) || 0) - (Number(from) || 0));
  let mean = null;
  if (country === 'TW') {
    const c = COUNTY_PM && COUNTY_PM.counties[place];
    if (c) mean = avgSeries(c.values, COUNTY_PM.year0, COUNTY_PM.year1, from, to);
  } else if (WORLD_PM && WORLD_PM.countries[country]) {
    mean = avgSeries(WORLD_PM.countries[country].values, WORLD_PM.year0, WORLD_PM.year1, from, to);
  }
  return { mean: mean == null ? PM_FALLBACK : mean, years };
}

/* ── Residence state (module-scope array, mutated in place — the diet-calc ccPlan pattern) ── */
let residences = [{ country: 'TW', place: '63000', from: 1990, to: 2020 }];

function renderResidences() {
  const grid = $('res-grid');
  if (!grid) return;
  grid.innerHTML = residences.map((r, i) => {
    const pm = pmForSpan(r.country, r.place, r.from, r.to).mean;
    const region = r.country === 'TW'
      ? `<select class="res-place" data-idx="${i}">${countyOptions(r.place)}</select>`
      : `<span class="res-nat">${L('全國', 'nationwide')}</span>`;
    return `<tr>
      <td><select class="res-country" data-idx="${i}">${countryOptions(r.country)}</select></td>
      <td>${region}</td>
      <td><input class="res-from" type="number" data-idx="${i}" value="${r.from}" min="1930" max="2026" step="1" /></td>
      <td><input class="res-to" type="number" data-idx="${i}" value="${r.to}" min="1930" max="2026" step="1" /></td>
      <td class="res-pm">${pm.toFixed(1)} µg/m³</td>
      <td>${residences.length > 1 ? `<button type="button" class="res-del" data-idx="${i}" title="${L('移除', 'Remove')}">✕</button>` : ''}</td>
    </tr>`;
  }).join('');

  grid.querySelectorAll('.res-country').forEach(sel => sel.addEventListener('change', () => {
    const r = residences[+sel.dataset.idx];
    r.country = sel.value;
    if (r.country === 'TW' && !COUNTY_LIST.some(c => c[0] === r.place)) r.place = (COUNTY_LIST[0] || ['63000'])[0];
    renderResidences();
  }));
  grid.querySelectorAll('.res-place').forEach(sel => sel.addEventListener('change', () => {
    residences[+sel.dataset.idx].place = sel.value; renderResidences();
  }));
  grid.querySelectorAll('.res-from').forEach(inp => inp.addEventListener('change', () => {
    residences[+inp.dataset.idx].from = parseInt(inp.value, 10) || 0; renderResidences();
  }));
  grid.querySelectorAll('.res-to').forEach(inp => inp.addEventListener('change', () => {
    residences[+inp.dataset.idx].to = parseInt(inp.value, 10) || 0; renderResidences();
  }));
  grid.querySelectorAll('.res-del').forEach(btn => btn.addEventListener('click', () => {
    residences.splice(+btn.dataset.idx, 1); renderResidences();
  }));
  updateResSummary();
}

function residenceStats() {
  let wsum = 0, w = 0, dose = 0;
  residences.forEach(r => {
    const { mean, years } = pmForSpan(r.country, r.place, r.from, r.to);
    wsum += years * mean; w += years; dose += years * mean;
  });
  return w > 0 ? { mean: wsum / w, years: w, dose } : null;
}

function updateResSummary() {
  const el = $('res-summary'); if (!el) return;
  const s = residenceStats();
  el.textContent = s
    ? L(`時間加權平均 PM2.5 ≈ ${s.mean.toFixed(1)} µg/m³`, `Time-weighted mean PM2.5 ≈ ${s.mean.toFixed(1)} µg/m³`)
    : '';
}

/* ── Scoring engine: pure compute → result object (renderer is separate so radar/meters can plug in later) ── */
function computeResult() {
  const factors = []; // { cat, rr, key }
  const add = (cat, rr, key) => { if (rr > 1.0001) factors.push({ cat, rr, key }); };

  if (val('in-education') === 'primary') add('social', RR.education, 'education');
  if (val('in-hearing') === 'untreated') add('sensory', RR.hearing, 'hearing');
  if (val('in-vision') === 'untreated') add('sensory', RR.vision, 'vision');
  if (val('in-htn') === 'yes') add('cardio', RR.htn, 'htn');
  if (val('in-diabetes') === 'yes') add('cardio', RR.diabetes, 'diabetes');
  if (val('in-bmi') === 'obese') add('cardio', RR.obesity, 'obesity');
  if (val('in-inactive') === 'inactive') add('cardio', RR.inactive, 'inactive');

  // LDL: continuous per-mmol/L if a value is given (mg/dL converted), else categorical "high"
  const ldlNum = parseFloat(val('in-ldl'));
  const ldlUnit = val('in-ldl-unit') || 'mgdl';
  let ldlRR = 1, ldl = null;
  if (!isNaN(ldlNum) && ldlNum > 0) {
    const ldlMmol = ldlUnit === 'mmol' ? ldlNum : ldlNum * LDL_MGDL_TO_MMOL;
    if (ldlMmol > 0.5 && ldlMmol < 15) {   // plausibility guard (ignore mis-typed values)
      ldlRR = Math.pow(LDL_RR_PER_MMOL, Math.max(0, ldlMmol - LDL_REF));
      ldl = { num: ldlNum, unit: ldlUnit, mmol: ldlMmol };
    }
  } else if (val('in-cholesterol') === 'high') ldlRR = LDL_RR_PER_MMOL; // ~ +1 mmol/L above reference
  add('cardio', ldlRR, 'ldl');

  if (val('in-depression') === 'yes') add('mental', RR.depression, 'depression');
  if (val('in-isolation') === 'isolated') add('social', RR.isolation, 'isolation');

  const smk = val('in-smoking');
  if (smk === 'current') add('lifestyle', RR.smokingCurrent, 'smoking');
  else if (smk === 'former') add('lifestyle', RR_SMOKING_FORMER, 'smoking-former');
  if (val('in-alcohol') === 'heavy') add('lifestyle', RR.alcohol, 'alcohol');
  if (val('in-tbi') === 'yes') add('lifestyle', RR.tbi, 'tbi');

  // PM2.5 — continuous (the anchor exposome feature)
  const res = residenceStats();
  let pmRR = 1, meanPM = null;
  if (res) { meanPM = res.mean; pmRR = Math.pow(PM_RR_PER_5, Math.max(0, (meanPM - PM_REF) / 5)); }
  add('exposome', pmRR, 'pm25');

  // Combine with overlap shrinkage + cap
  const lnSum = factors.reduce((s, f) => s + Math.log(f.rr), 0);
  const lnEffRaw = LAMBDA * lnSum;
  const capped = lnEffRaw > CAP_LN;
  const lnEff = Math.min(lnEffRaw, CAP_LN);
  const log2rr = lnEff / Math.log(2);
  const dMid = log2rr * T_DOUBLE;
  const dLo = log2rr * 5.0;
  const dHi = log2rr * 6.3;

  const count = factors.length;
  const band = count <= 2 ? 'few' : count <= 5 ? 'several' : 'many';

  return { factors, meanPM, res, ldl, dMid, dLo, dHi, capped, count, band,
           rrProd: Math.exp(lnSum), rrEff: Math.exp(lnEff), lambda: LAMBDA, tDouble: T_DOUBLE };
}

