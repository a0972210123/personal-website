    const k = 0.3;
    grot[0] += (e.clientX - gLast[0]) * k;
    grot[1] = Math.max(-90, Math.min(90, grot[1] - (e.clientY - gLast[1]) * k));
    gLast = [e.clientX, e.clientY];
    gproj.rotate(grot); gDraw();
    return;
  }
  const found = gFeatureAt(e.clientX, e.clientY);
  if (found !== ghover) { ghover = found; gDraw(); }
  const tip = $('globe-tip'), rect = gcanvas.getBoundingClientRect();
  if (found) {
    const m = gMetric(), v = found.properties[m.prop], drill = ccOfFeature(found);
    tip.innerHTML = `<b>${found.properties.name}</b><br>${L(m.zh, m.en)}: `
      + (v == null ? L('無資料', 'no data') : `${(+v).toFixed(m.dec)} ${m.unit}`)
      + (drill ? `<br><span style="opacity:.7">${L('點擊看行政區細節', 'click for admin-1 detail')}</span>` : '');
    tip.hidden = false;
    tip.style.left = Math.min(gW - 160, e.clientX - rect.left + 12) + 'px';
    tip.style.top = (e.clientY - rect.top + 12) + 'px';
  } else { tip.hidden = true; }
}
function setupGlobe() {
  if (gcanvas) return;
  gcanvas = $('map-globe'); gctx = gcanvas.getContext('2d');
  gproj = window.d3.geoOrthographic().precision(0.5);
  gpath = window.d3.geoPath(gproj, gctx);
  ggrat = window.d3.geoGraticule10();
  gproj.rotate(grot);
  // Pointer handlers live on the canvas (not the stage) so overlay controls — the spin
  // button, legend, tooltip — never trigger a drag or drill.
  gcanvas.addEventListener('pointerdown', (e) => {
    gdrag = true; gspin = false; updateSpinBtn(); gDownXY = [e.clientX, e.clientY]; gLast = [e.clientX, e.clientY];
    try { gcanvas.setPointerCapture(e.pointerId); } catch (x) { /* ignore */ }
  });
  gcanvas.addEventListener('pointermove', gPointerMove);
  gcanvas.addEventListener('pointerup', (e) => {
    gdrag = false;
    const moved = gDownXY ? Math.hypot(e.clientX - gDownXY[0], e.clientY - gDownXY[1]) : 99;
    gLast = null; gDownXY = null;
    if (moved < 5) {   // a tap, not a drag → drill down
      const f = gFeatureAt(e.clientX, e.clientY), cc = f && ccOfFeature(f);
      if (cc) { const cs = $('map-country'); if (cs) cs.value = cc; selectView(cc); }
    }
  });
  gcanvas.addEventListener('pointerleave', () => { ghover = null; const t = $('globe-tip'); if (t) t.hidden = true; });
  const spinBtn = $('globe-spin');
  if (spinBtn) spinBtn.addEventListener('click', () => { gspin = !gspin; updateSpinBtn(); });
  window.addEventListener('resize', () => { if (inWorld()) gResize(); });
  new MutationObserver(() => { if (inWorld()) gDraw(); })
    .observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });
}
async function enterWorld() {
  mapCountry = 'world';
  if (mapMode !== 'pm25' && mapMode !== 'composite') mapMode = 'pm25';
  const mapEl = $('map'), stage = $('globe-stage');
  if (mapEl) mapEl.hidden = true;
  if (stage) stage.hidden = false;
  gZoom = 1; gspin = true;                       // fresh globe view: reset zoom, resume auto-spin
  const zslider = $('map-zoom'); if (zslider) zslider.value = 0;
  if (!worldGeo) {
    const g = await fetch('/data/geo/world-globe.geojson').then(r => r.ok ? r.json() : null).catch(() => null);
    worldGeo = g ? g.features : [];
    setupGlobe();
  }
  gResize(); gLegendBuild(); updateSpinBtn();
  if (!graf) gTickLoop();
  syncModeButtons(); renderMethodBox();
}
function selectView(v) {
  if (v === 'world') { enterWorld(); return; }
  const stage = $('globe-stage'), mapEl = $('map');
  if (stage) stage.hidden = true;
  if (mapEl) mapEl.hidden = false;
  if (map) map.invalidateSize();   // re-read size now #map is visible again, before fitBounds
  drawCountry(v);
}
async function initMap() {
  const el = $('map');
  if (!el || !window.L || !window.topojson) return;
  try {
    map = window.L.map(el, { scrollWheelZoom: false, attributionControl: true });
    map.attributionControl.setPrefix(false).addAttribution(
      L('界線 © NLSC／taiwan-atlas · Natural Earth｜PM2.5 © ACAG｜失智盛行率為模型估計值',
        'Boundaries © NLSC/taiwan-atlas · Natural Earth · PM2.5 © ACAG · dementia = modelled estimate'));
    EXPOSOME = await fetch('/data/exposome/exposome.json').then(r => r.ok ? r.json() : null).then(d => d && d.countries).catch(() => null);
    MCI_NAT = await fetch('/data/mci/mci-national.json').then(r => r.ok ? r.json() : null).then(d => d && d.countries).catch(() => null);
    // Default landing = the global globe overview (marquee view; the country switcher's
    // first option). Drilling into a country lazily builds its Leaflet admin-1 map.
    await enterWorld();
    document.querySelectorAll('.map-btn').forEach(b => b.addEventListener('click', () => {
      if (b.disabled) return;
      mapMode = b.dataset.mode;
      if (inWorld()) { gLegendBuild(); gDraw(); syncModeButtons(); renderMethodBox(); }
      else applyMode();
    }));
    const fsel = $('map-factor');   // single-factor PAF picker (country view only)
    if (fsel) fsel.addEventListener('change', () => { if (fsel.value && !inWorld()) { mapMode = fsel.value; applyMode(); } });
    const cs = $('map-country');
    if (cs) cs.addEventListener('change', () => selectView(cs.value));
    const zoom = $('map-zoom');   // universal zoom: drives the globe's scale or Leaflet's zoom
    if (zoom) zoom.addEventListener('input', () => {
      const v = +zoom.value;
      if (inWorld()) gSetZoom(1 + v / 100 * 3);                                     // globe 1×–4×
      else if (map && leafFitZoom != null) map.setZoom(leafFitZoom + v / 100 * 5);  // Leaflet fit .. fit+5
    });
    map.on('zoomend', () => {   // keep the slider in sync when Leaflet's own +/- buttons are used
      if (inWorld() || leafFitZoom == null) return;
      const z = $('map-zoom'); if (z) z.value = Math.max(0, Math.min(100, (map.getZoom() - leafFitZoom) / 5 * 100));
    });
  } catch (e) {
    console.error('map init failed:', e);
    el.innerHTML = `<p class="map-fail">${L('地圖資料載入失敗。', 'Map data failed to load.')}</p>`;
  }
}
function relabelMap() {
  if (inWorld()) { gLegendBuild(); renderMethodBox(); updateSpinBtn(); gDraw(); }
  else if (map && geoLayer) applyMode();
}

/* ── Init ── */
/* LDL unit: mg/dL (default) vs mmol/L — update the input's range/placeholder, and
   convert the typed value when the unit changes so the number stays meaningful. */
const LDL_MMOL_COUNTRIES = new Set(['GB', 'HK', 'AU', 'NZ', 'CA', 'IE']);
function applyLdlUnit() {
  const sel = $('in-ldl-unit'), inp = $('in-ldl');
  if (!sel || !inp) return;
  if (sel.value === 'mmol') { inp.min = '1'; inp.max = '8'; inp.step = '0.1'; inp.placeholder = '3.4'; }
  else { inp.min = '40'; inp.max = '300'; inp.step = '1'; inp.placeholder = '130'; }
}
function onLdlUnitChange() {
  const sel = $('in-ldl-unit'), inp = $('in-ldl');
  const v = parseFloat(inp.value);
  if (!isNaN(v) && v > 0) {   // sel.value is the NEW unit → convert from the old one
    inp.value = sel.value === 'mmol' ? (v * LDL_MGDL_TO_MMOL).toFixed(2) : String(Math.round(v / LDL_MGDL_TO_MMOL));
  }
  applyLdlUnit();
}

/* ── Data-provenance / coverage table (tabs = data type, rows = every country) ── */
let DP = null, dpType = 'aging', dpOnlyData = false;
const _dpDN = {};
function dpName(iso) {
  const lg = lang() === 'en' ? 'en' : 'zh-Hant';
  if (!(lg in _dpDN)) { try { _dpDN[lg] = new Intl.DisplayNames([lg], { type: 'region' }); } catch (e) { _dpDN[lg] = null; } }
  try { return (_dpDN[lg] && _dpDN[lg].of(iso)) || iso; } catch (e) { return iso; }
}
function dpBadge(s) {
  const m = { live: ['✅', 'dp-live'], seed: ['◐', 'dp-seed'], identified: ['○', 'dp-id'], none: ['—', 'dp-none'] };
  const [sym, cls] = m[s] || m.none;
  return `<span class="dp-badge ${cls}" title="${s}">${sym}</span>`;
}
function dpCell(o, k) {
  const src = o[k + 'Src'], url = o[k + 'Url'], yr = o[k + 'Year'];
  const s = (!src || src === '—') ? '—' : (url ? `<a href="${url}" target="_blank" rel="noopener">${src}</a>` : src);
  return { src: s, yr: yr || '—' };
}
function renderDpTable() {
  if (!DP) return;
  const t = DP.types.find(x => x.key === dpType) || DP.types[0];
  const q = ($('dp-filter') ? $('dp-filter').value : '').trim().toLowerCase();
  const rows = DP.iso.map(iso => ({ iso, name: dpName(iso), o: (DP.overrides[iso] && DP.overrides[iso][dpType]) || t.default }))
    .filter(r => !q || r.name.toLowerCase().includes(q) || r.iso.toLowerCase().includes(q))
    .filter(r => !dpOnlyData || r.o.status === 'live' || r.o.status === 'seed')
    .sort((a, b) => a.name.localeCompare(b.name, lang() === 'en' ? 'en' : 'zh-Hant'));
  const head = `<tr><th>${L('國家/地區', 'Country')}</th><th>${L('國家級來源', 'National source')}</th><th>${L('年份', 'Year')}</th>`
    + `<th>${L('省縣級來源', 'Sub-national source')}</th><th>${L('年份', 'Year')}</th><th>${L('狀態', 'Status')}</th></tr>`;
  const body = rows.map(r => {
    const n = dpCell(r.o, 'nat'), s = dpCell(r.o, 'sub');
    return `<tr><td class="dp-country">${r.name}</td><td>${n.src}</td><td class="dp-yr">${n.yr}</td>`
      + `<td>${s.src}</td><td class="dp-yr">${s.yr}</td><td>${dpBadge(r.o.status)}</td></tr>`;
  }).join('');
  $('dp-table-wrap').innerHTML = `<table class="dp-table"><thead>${head}</thead><tbody>${body}</tbody></table>`;
  const cnt = $('dp-count'); if (cnt) cnt.textContent = `${rows.length} ${L('個國家/地區', 'countries/areas')}`;
}
function renderProvenance() {
  if (!DP) return;
  $('dp-tabs').innerHTML = DP.types.map(t =>
    `<button type="button" class="dp-tab${t.key === dpType ? ' is-active' : ''}" data-key="${t.key}">${L(t.zh, t.en)}</button>`).join('');
  const f = $('dp-filter'); if (f) f.placeholder = L('篩選國家…', 'Filter countries…');
  renderDpTable();
}
async function setupProvenance() {
  DP = await fetch('/data/data-provenance.json').then(r => r.ok ? r.json() : null).catch(() => null);
  if (!DP) return;
  const tabs = $('dp-tabs');
  if (tabs) tabs.addEventListener('click', e => { const b = e.target.closest('[data-key]'); if (!b) return; dpType = b.dataset.key; renderProvenance(); });
  const f = $('dp-filter'); if (f) f.addEventListener('input', renderDpTable);
  const oc = $('dp-only-data'); if (oc) oc.addEventListener('change', () => { dpOnlyData = oc.checked; renderDpTable(); });
  renderProvenance();
}

async function init() {
  document.querySelectorAll('[data-goto]').forEach(b => b.addEventListener('click', () => showStep(+b.dataset.goto)));
  document.querySelectorAll('.wizard-steps li').forEach(li => {
    li.setAttribute('role', 'button');
    li.setAttribute('tabindex', '0');
    const go = () => showStep(+li.dataset.step);
    li.addEventListener('click', go);
    li.addEventListener('keydown', e => {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); go(); }
    });
  });
  document.querySelectorAll('.cat-view-btn').forEach(b => b.addEventListener('click', () => { catView = b.dataset.view; applyCatView(); }));
  const addBtn = $('res-add');
  if (addBtn) addBtn.addEventListener('click', () => {
    const last = residences[residences.length - 1] || { country: 'TW', place: '63000', to: 2000 };
    residences.push({ country: last.country, place: last.place, from: last.to || 2000, to: 2026 });
    renderResidences();
  });
  // load real PM2.5 — Taiwan county series + world country series (ACAG) — plus geo-detect, in parallel
  let detectedIso = null;
  try {
    const [cty, world, iso] = await Promise.all([
      fetch('/data/pm25/tw-county-pm25.json').then(r => r.json()),
      fetch('/data/pm25/world-country-pm25.json').then(r => r.json()).catch(() => null),
      detectCountryIso().catch(() => null),
    ]);
    COUNTY_PM = cty;
    COUNTY_LIST = Object.entries(COUNTY_PM.counties)
      .map(([code, c]) => [code, c.name, c.nameEn])
      .sort((a, b) => a[1].localeCompare(b[1], 'zh-Hant'));
    WORLD_PM = world;
    detectedIso = iso;
  } catch (e) { COUNTY_LIST = FALLBACK_COUNTIES.slice(); }
  buildCountryList();
  // Soft-default the first residence to the visitor's country (overridable; only the untouched default row).
  const detectedCountry = isoToCountryValue(detectedIso);
  if (detectedCountry && detectedCountry !== residences[0].country) {
    residences[0].country = detectedCountry;
    if (detectedCountry !== 'TW') residences[0].place = '';  // non-TW rows show "nationwide"; place unused
  }
  if (residences[0].country === 'TW' && !COUNTY_LIST.some(c => c[0] === residences[0].place)) {
    residences[0].place = (COUNTY_LIST[0] || ['63000'])[0];
  }
  // LDL unit: default to mmol/L for countries that report it, else mg/dL; wire the toggle.
  const ldlUnitSel = $('in-ldl-unit');
  if (ldlUnitSel) {
    if (detectedIso && LDL_MMOL_COUNTRIES.has(String(detectedIso).toUpperCase())) ldlUnitSel.value = 'mmol';
    ldlUnitSel.addEventListener('change', onLdlUnitChange);
    applyLdlUnit();
  }

  applyOptionLangs();
  renderResidences();
  window.addEventListener('langchange', () => {
    applyOptionLangs();
    renderResidences();
    if (currentStep === 4 && lastResult) renderResults(lastResult);
    relabelMap();
    renderProvenance();
  });
  initMap();
  setupProvenance();
}
init();
</script>
