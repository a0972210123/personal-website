    `Estimated range +${r.dLo.toFixed(1)} to +${r.dHi.toFixed(1)} yr${r.capped ? ' (capped)' : ''}. An educational illustration — not a measured brain age, and not a personal prediction.`
  );
  const frows = r.factors.map(f => {
    const lab = FACTOR_LABELS[f.key] ? L(FACTOR_LABELS[f.key][0], FACTOR_LABELS[f.key][1]) : f.key;
    const extra = f.key === 'pm25' && r.meanPM != null ? `（${r.meanPM.toFixed(1)} µg/m³）` : '';
    return `<li>${lab}${extra} — RR ${f.rr.toFixed(2)}</li>`;
  }).join('');
  $('out-brainage-detail').innerHTML = `<details class="ba-detail"><summary>${L('如何算出這個數字？', 'How is this number derived?')}</summary><div class="ba-detail-body">
    <p>${L('納入計算的因子與其相對風險（RR，主要來自 2024 Lancet 委員會）：', 'Factors included and their relative risks (RR, mainly the 2024 Lancet Commission):')}</p>
    <ul class="ba-factors">${frows || `<li>${L('（目前沒有可調整因子）', '(no modifiable factors)')}</li>`}</ul>
    <ol class="ba-steps">
      <li>${L(`各因子 RR 相乘 → 原始合併 RR ≈ <strong>${r.rrProd.toFixed(2)}</strong>`, `Multiply the RRs → raw combined RR ≈ <strong>${r.rrProd.toFixed(2)}</strong>`)}</li>
      <li>${L(`乘上重疊縮減係數 λ = ${r.lambda}（因子彼此相關，直接相乘會高估；λ 近似 Lancet 委員會的 communality 調整）→ 有效 RR = 原始RR<sup>${r.lambda}</sup> ≈ <strong>${r.rrEff.toFixed(2)}</strong>`, `Apply overlap-shrinkage λ = ${r.lambda} (factors are correlated; multiplying raw RRs overstates risk — λ approximates the Commission's communality adjustment) → effective RR = rawRR<sup>${r.lambda}</sup> ≈ <strong>${r.rrEff.toFixed(2)}</strong>`)}</li>
      <li>${L(`換算成腦齡：log₂(有效 RR) × ${r.tDouble} ≈ <strong>+${r.dMid.toFixed(1)} 年</strong>${r.capped ? '（已達上限）' : ''}。失智風險每約 ${r.tDouble} 年翻倍，log₂ 把「風險倍數」換算成「相當於老了幾年」（上限約 ±12 年）。`, `Convert to brain-years: log₂(effective RR) × ${r.tDouble} ≈ <strong>+${r.dMid.toFixed(1)} yr</strong>${r.capped ? ' (capped)' : ''}. Dementia risk roughly doubles every ${r.tDouble} years; log₂ turns the risk multiple into "years older" (capped at about ±12 yr).`)}</li>
    </ol>
    <p class="ba-detail-note">${L('λ = 0.6 與 ±12 年上限是本工具為避免高估設的參數（非已發表常數）。這是教育性估計，非個人預測。', 'λ = 0.6 and the ±12-yr cap are this tool\'s parameters to avoid overstatement (not published constants). Educational estimate, not a personal prediction.')}</p>
  </div></details>`;

  // 3) by category
  const catCount = {};
  r.factors.forEach(f => { catCount[f.cat] = (catCount[f.cat] || 0) + 1; });
  $('out-categories').innerHTML = CATS.map(([key, zh, en]) => {
    const n = catCount[key] || 0;
    const badge = n === 0 ? '✅' : '⚠️';
    const sub = n === 0
      ? L('無明顯因子', 'no notable factor')
      : L(`${n} 項因子`, `${n} factor${n > 1 ? 's' : ''}`);
    return `<div class="stat-row">
      <div class="stat-row-label">
        <div class="stat-row-title">${L(zh, en)}</div>
        <div class="stat-row-sub">${sub}</div>
      </div>
      <div class="stat-row-num"><span class="cat-badge">${badge}</span></div>
    </div>`;
  }).join('');
  renderGauge(r);
  renderRadar(r);
  applyCatView();

  // 4) exposome / PM2.5 detail — WHO guideline → your annual avg → cumulative comparison → provenance
  const ex = $('out-exposome');
  if (r.res) {
    ex.style.display = '';
    const mult = (r.meanPM / PM_REF).toFixed(1);
    const yourCum = Math.round(r.res.dose);
    const whoCum = PM_REF * r.res.years;
    ex.innerHTML = L(
      `🌫️ <strong>WHO 建議年均 PM2.5 ≤ ${PM_REF} µg/m³。</strong><br>` +
      `你的時間加權年均暴露 ≈ <strong>${r.meanPM.toFixed(1)} µg/m³</strong>，約為 WHO 建議的 <strong>${mult}×</strong>。<br>` +
      `在約 ${r.res.years} 年的居住史中，你的估計累積暴露 ≈ <strong>${yourCum.toLocaleString()} µg/m³·年</strong>；` +
      `同樣年數下、符合 WHO 標準者僅 ${whoCum.toLocaleString()} µg/m³·年 —— 你約為其 <strong>${mult}×</strong>。<br>` +
      `<em>PM2.5 採用 ACAG 衛星逐年資料（V6.GL.03，1998–2024）；1998 年以前的居住年份沿用 1998 年數值估計。</em>`,
      `🌫️ <strong>WHO guideline: annual PM2.5 ≤ ${PM_REF} µg/m³.</strong><br>` +
      `Your time-weighted annual exposure ≈ <strong>${r.meanPM.toFixed(1)} µg/m³</strong>, about <strong>${mult}×</strong> the WHO guideline.<br>` +
      `Over ~${r.res.years} years of residence, your estimated cumulative exposure ≈ <strong>${yourCum.toLocaleString()} µg/m³·years</strong>; ` +
      `someone meeting the WHO guideline for the same span would be just ${whoCum.toLocaleString()} µg/m³·years — you are about <strong>${mult}×</strong> that.<br>` +
      `<em>PM2.5 uses ACAG satellite annual data (V6.GL.03, 1998–2024); residence years before 1998 reuse the 1998 value.</em>`
    );
  } else { ex.style.display = 'none'; }

  // 5) actions
  const seen = new Set();
  const items = r.factors.map(f => f.key).filter(k => { if (seen.has(k) || !ACTIONS[k]) return false; seen.add(k); return true; });
  const yourVal = (k) => {
    if (k === 'pm25' && r.meanPM != null) return `${r.meanPM.toFixed(1)} µg/m³`;
    if (k === 'ldl' && r.ldl) return `${r.ldl.num} ${r.ldl.unit === 'mmol' ? 'mmol/L' : 'mg/dL'}`;
    return '';
  };
  $('out-actions').innerHTML = items.length === 0
    ? `<li class="act-none">${L('沒有需要優先處理的可調整因子 — 繼續保持健康的生活型態與環境。', 'No priority modifiable factors — keep up a healthy lifestyle and environment.')}</li>`
    : items.map(k => {
        const a = ACTIONS[k], info = FACTOR_INFO[k];
        const name = FACTOR_LABELS[k] ? L(FACTOR_LABELS[k][0], FACTOR_LABELS[k][1]) : k;
        const you = yourVal(k);
        return `<li>
          <div class="act-head"><strong>${name}</strong>${you ? `<span class="act-you">${L('你的值', 'yours')}: ${you}</span>` : ''}</div>
          ${info ? `<div class="act-ref">${L(info[0], info[1])}</div>` : ''}
          ${info ? `<div class="act-why">${L(info[2], info[3])}</div>` : ''}
          <div class="act-do"><span class="act-cat">${L(a[0], a[1])}</span>${L(a[2], a[3])}</div>
        </li>`;
      }).join('');
}

/* ── Wizard navigation ── */
let currentStep = 1;
let lastResult = null;
function showStep(n) {
  currentStep = n;
  document.querySelectorAll('.wizard-step').forEach(s => s.classList.toggle('is-active', +s.dataset.step === n));
  document.querySelectorAll('.wizard-steps li').forEach(li => {
    const s = +li.dataset.step;
    li.classList.toggle('is-active', s === n);
    li.classList.toggle('is-done', s < n);
  });
  if (n === 4) { lastResult = computeResult(); renderResults(lastResult); }
  const wiz = document.querySelector('.wizard');
  if (wiz) window.scrollTo({ top: wiz.getBoundingClientRect().top + window.scrollY - 20, behavior: 'smooth' });
}

/* ── Language re-render ── */
function applyOptionLangs() {
  const en = lang() === 'en';
  document.querySelectorAll('select option[data-en]').forEach(o => { o.textContent = en ? o.dataset.en : o.dataset.zh; });
  document.querySelectorAll('select optgroup[data-en]').forEach(g => { g.label = en ? g.dataset.en : g.dataset.zh; });
}

/* ── Choropleth map (Leaflet + topojson-client, vendored) — country switcher.
     Taiwan: town-level, prevalence + PM2.5. Japan/Korea: admin-1, PM2.5 only
     (prevalence needs gov population/survey data — see data-download-points.md). ── */
let map = null, geoLayer = null, legendCtl = null;
let mapCountry = 'tw', mapMode = 'prevalence';
let GEO = null;                    // current FeatureCollection
let VAL = { prev: {}, pm: {} };    // current country: code -> value
let NAMES = {};                    // current country: code -> {zh, en}
const PREV_BINS = [12, 14, 16, 18, 20];   // modelled dementia per 1,000 residents
// WHO-aligned global scale (AQG 5; interim targets 10/15/25/35) so clean East Asia
// and heavily polluted China/India are both legible on one comparable ramp.
const PM_BINS = [5, 10, 15, 25, 35];       // PM2.5 µg/m³
const RAMP = ['#ffeda0', '#fed976', '#feb24c', '#fd8d3c', '#f03b20', '#bd0026'];
// Prevalence metrics differ by source (all "modelled estimate"): TW = cases per 1,000
// all-ages; CN/IN = published % among 50+/60+. Each country carries its own label + bins.
const PREV_TW = { bins: PREV_BINS, tipZh: '失智盛行（估計）', tipEn: 'Dementia (modelled)',
  unitZh: '／千人', unitEn: 'per 1,000', legendZh: '失智／千人', legendEn: 'dementia /1,000', decimals: 1 };
const PREV_CN = { bins: [3, 5, 7, 9, 11], tipZh: '失智盛行率（50+）', tipEn: 'Dementia prevalence (50+)',
  unitZh: '%', unitEn: '%', legendZh: '失智盛行率 50+ %', legendEn: 'prevalence 50+ %', decimals: 1 };
const PREV_IN = { bins: [5, 6, 7, 8, 9], tipZh: '失智盛行率（60+）', tipEn: 'Dementia prevalence (60+)',
  unitZh: '%', unitEn: '%', legendZh: '失智盛行率 60+ %', legendEn: 'prevalence 60+ %', decimals: 1 };
const MAP_CFG = {
  tw: { topo: '/data/geo/tw-districts.topo.json', topoObject: 'towns', codeProp: 'TOWNCODE',
        layers: ['prevalence', 'pm25'], fit: [[21.9, 119.3], [25.35, 122.05]], prevMetric: PREV_TW,
        prev: '/data/dementia/tw-dementia-modelled.json', pm: '/data/pm25/tw-district-pm25.json' },
  jp: { geojson: '/data/geo/jp-admin1.geojson', codeProp: 'code', layers: ['pm25'],
        pm: '/data/pm25/jp-admin1-pm25.json' },
  kr: { geojson: '/data/geo/kr-admin1.geojson', codeProp: 'code', layers: ['pm25'],
        pm: '/data/pm25/kr-admin1-pm25.json' },
  // CN/IN: prevalence metric is READY; to enable once scripts/_data_in prevalence CSV is
  // built into cn/in-modelled.json, add   prev: '/data/dementia/{cn,in}-modelled.json'   and
  // 'prevalence' to layers (see data-download-points.md).
  cn: { geojson: '/data/geo/cn-admin1.geojson', codeProp: 'code', layers: ['pm25'],
        prevMetric: PREV_CN, pm: '/data/pm25/cn-admin1-pm25.json' },
  us: { geojson: '/data/geo/us-admin1.geojson', codeProp: 'code', layers: ['pm25'],
        pm: '/data/pm25/us-admin1-pm25.json' },
  in: { geojson: '/data/geo/in-admin1.geojson', codeProp: 'code', layers: ['pm25'],
        prevMetric: PREV_IN, pm: '/data/pm25/in-admin1-pm25.json' },
  ...Object.fromEntries(['th', 'vn', 'id', 'ph', 'my', 'pk', 'bd', 'mm', 'gb', 'de', 'fr',
    'it', 'es', 'pl', 'ca', 'br', 'mx', 'au', 'nz', 'tr', 'ir'].map(cc => [cc,
    { geojson: `/data/geo/${cc}-admin1.geojson`, codeProp: 'code', layers: ['pm25'],
      pm: `/data/pm25/${cc}-admin1-pm25.json` }])),
};
function curPrev() { return MAP_CFG[mapCountry].prevMetric || PREV_TW; }

function codeOf(f) { return f.properties[MAP_CFG[mapCountry].codeProp]; }
function valueFor(code) { return mapMode === 'prevalence' ? VAL.prev[code] : VAL.pm[code]; }
function colorFor(v) {
  if (v == null) return document.documentElement.getAttribute('data-theme') === 'dark' ? '#2b3050' : '#e6e6e6';
  const bins = mapMode === 'prevalence' ? curPrev().bins : PM_BINS;
  let i = 0; while (i < bins.length && v > bins[i]) i++;
  return RAMP[i];
}
function styleFn(f) { return { fillColor: colorFor(valueFor(codeOf(f))), weight: 0.4, color: '#fff', fillOpacity: 0.82 }; }
function unitName(f) { const n = NAMES[codeOf(f)]; return n ? L(n.zh, n.en) : (f.properties.name || codeOf(f)); }
function tooltipFor(f) {
  const code = codeOf(f), name = unitName(f);
  if (mapMode === 'prevalence') {
    const p = curPrev(), v = VAL.prev[code];
    return `<b>${name}</b><br>${L(p.tipZh, p.tipEn)}: ${v != null ? v.toFixed(p.decimals) : '—'} ${L(p.unitZh, p.unitEn)}`;
  }
  const v = VAL.pm[code];
  return `<b>${name}</b><br>PM2.5: ${v != null ? v.toFixed(1) : '—'} µg/m³`;
}
function buildLegend() {
  if (!map) return;
  if (legendCtl) map.removeControl(legendCtl);
  legendCtl = window.L.control({ position: 'bottomright' });
  legendCtl.onAdd = () => {
    const div = window.L.DomUtil.create('div', 'map-legend');
    const p = curPrev();
    const bins = mapMode === 'prevalence' ? p.bins : PM_BINS;
    const unit = mapMode === 'prevalence' ? L(p.legendZh, p.legendEn) : 'PM2.5 µg/m³';
    const edges = [0, ...bins];
    let html = `<b>${unit}</b><br>`;
    for (let i = 0; i < RAMP.length; i++) {
      const label = bins[i] != null ? `${edges[i]}–${bins[i]}` : `>${edges[edges.length - 1]}`;
      html += `<i style="background:${RAMP[i]}"></i>${label}<br>`;
    }
    div.innerHTML = html;
    return div;
  };
  legendCtl.addTo(map);
}
function syncModeButtons() {
  const layers = MAP_CFG[mapCountry].layers;
  document.querySelectorAll('.map-btn').forEach(b => {
    const on = layers.includes(b.dataset.mode);
    b.disabled = !on;
    b.classList.toggle('is-disabled', !on);
    b.classList.toggle('is-active', on && b.dataset.mode === mapMode);
  });
  const note = $('map-prev-note');
  if (note) note.style.display = layers.includes('prevalence') ? 'none' : '';
}
function applyMode() {
  if (!geoLayer) return;
  geoLayer.setStyle(styleFn);
  geoLayer.eachLayer(l => l.setTooltipContent(tooltipFor(l.feature)));
  buildLegend();
  syncModeButtons();
}
async function loadCountryData(cc) {
  const cfg = MAP_CFG[cc];
  let geo, prev = {}, pm = {}, names = {};
  if (cfg.topo) { const t = await fetch(cfg.topo).then(r => r.json()); geo = window.topojson.feature(t, t.objects[cfg.topoObject]); }
  else { geo = await fetch(cfg.geojson).then(r => r.json()); }
  if (cfg.prev) { const p = await fetch(cfg.prev).then(r => r.ok ? r.json() : null).catch(() => null); if (p) Object.assign(prev, p.byTown || {}); }
  if (cfg.pm) {
    const d = await fetch(cfg.pm).then(r => r.json());
    if (d.districts) for (const [k, v] of Object.entries(d.districts)) pm[k] = v.pm25;
    else if (d.units) Object.assign(pm, d.units);
  }
  geo.features.forEach(f => {
    const p = f.properties, code = p[cfg.codeProp];
    names[code] = cc === 'tw'
      ? { zh: (p.COUNTYNAME || '') + p.TOWNNAME, en: (p.TOWNENG || p.TOWNNAME) + (p.COUNTYENG ? ', ' + p.COUNTYENG : '') }
      : { zh: p.nameLocal || p.name || code, en: p.name || code };
  });
  return { geo, prev, pm, names, cfg };
}
async function drawCountry(cc) {
  const d = await loadCountryData(cc);
  mapCountry = cc; GEO = d.geo; VAL = { prev: d.prev, pm: d.pm }; NAMES = d.names;
  if (!d.cfg.layers.includes(mapMode)) mapMode = d.cfg.layers[0];
  if (geoLayer) { map.removeLayer(geoLayer); geoLayer = null; }
  geoLayer = window.L.geoJSON(GEO, {
    style: styleFn,
    onEachFeature: (f, layer) => layer.bindTooltip(tooltipFor(f), { sticky: true }),
  }).addTo(map);
  if (d.cfg.fit) map.fitBounds(d.cfg.fit); else map.fitBounds(geoLayer.getBounds(), { padding: [8, 8] });
  buildLegend();
  syncModeButtons();
  setTimeout(() => map && map.invalidateSize(), 150);
}
async function initMap() {
  const el = $('map');
  if (!el || !window.L || !window.topojson) return;
  try {
    map = window.L.map(el, { scrollWheelZoom: false, attributionControl: true });
    map.attributionControl.setPrefix(false).addAttribution(
      L('界線 © NLSC／taiwan-atlas · Natural Earth｜PM2.5 © ACAG｜失智盛行率為模型估計值',
        'Boundaries © NLSC/taiwan-atlas · Natural Earth · PM2.5 © ACAG · dementia = modelled estimate'));
    await drawCountry('tw');
    document.querySelectorAll('.map-btn').forEach(b => b.addEventListener('click', () => {
      if (b.disabled) return;
      mapMode = b.dataset.mode; applyMode();
    }));
    const cs = $('map-country');
    if (cs) cs.addEventListener('change', () => drawCountry(cs.value));
  } catch (e) {
    console.error('map init failed:', e);
    el.innerHTML = `<p class="map-fail">${L('地圖資料載入失敗。', 'Map data failed to load.')}</p>`;
  }
}
function relabelMap() { if (map && geoLayer) applyMode(); }

/* ── Init ── */
/* LDL unit: mg/dL (default) vs mmol/L — update the input's range/placeholder, and
   convert the typed value when the unit changes so the number stays meaningful. */
const LDL_MMOL_COUNTRIES = new Set(['GB', 'HK', 'AU', 'NZ', 'CA', 'IE']);
function applyLdlUnit() {
  const sel = $('in-ldl-unit'), inp = $('in-ldl');
  if (!sel || !inp) return;
  if (sel.value === 'mmol') { inp.min = '1'; inp.max = '8'; inp.step = '0.1'; inp.placeholder = '3.4'; }
  else { inp.min = '40'; inp.max = '300'; inp.step = '1'; inp.placeholder = '130'; }
}
function onLdlUnitChange() {
  const sel = $('in-ldl-unit'), inp = $('in-ldl');
  const v = parseFloat(inp.value);
  if (!isNaN(v) && v > 0) {   // sel.value is the NEW unit → convert from the old one
    inp.value = sel.value === 'mmol' ? (v * LDL_MGDL_TO_MMOL).toFixed(2) : String(Math.round(v / LDL_MGDL_TO_MMOL));
  }
  applyLdlUnit();
}

async function init() {
  document.querySelectorAll('[data-goto]').forEach(b => b.addEventListener('click', () => showStep(+b.dataset.goto)));
  document.querySelectorAll('.wizard-steps li').forEach(li => {
    li.setAttribute('role', 'button');
    li.setAttribute('tabindex', '0');
    const go = () => showStep(+li.dataset.step);
    li.addEventListener('click', go);
    li.addEventListener('keydown', e => {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); go(); }
    });
  });
  document.querySelectorAll('.cat-view-btn').forEach(b => b.addEventListener('click', () => { catView = b.dataset.view; applyCatView(); }));
  const addBtn = $('res-add');
  if (addBtn) addBtn.addEventListener('click', () => {
    const last = residences[residences.length - 1] || { country: 'TW', place: '63000', to: 2000 };
    residences.push({ country: last.country, place: last.place, from: last.to || 2000, to: 2026 });
    renderResidences();
  });
  // load real PM2.5 — Taiwan county series + world country series (ACAG) — plus geo-detect, in parallel
  let detectedIso = null;
  try {
    const [cty, world, iso] = await Promise.all([
      fetch('/data/pm25/tw-county-pm25.json').then(r => r.json()),
      fetch('/data/pm25/world-country-pm25.json').then(r => r.json()).catch(() => null),
      detectCountryIso().catch(() => null),
    ]);
    COUNTY_PM = cty;
    COUNTY_LIST = Object.entries(COUNTY_PM.counties)
      .map(([code, c]) => [code, c.name, c.nameEn])
      .sort((a, b) => a[1].localeCompare(b[1], 'zh-Hant'));
    WORLD_PM = world;
    detectedIso = iso;
  } catch (e) { COUNTY_LIST = FALLBACK_COUNTIES.slice(); }
  buildCountryList();
  // Soft-default the first residence to the visitor's country (overridable; only the untouched default row).
  const detectedCountry = isoToCountryValue(detectedIso);
  if (detectedCountry && detectedCountry !== residences[0].country) {
    residences[0].country = detectedCountry;
    if (detectedCountry !== 'TW') residences[0].place = '';  // non-TW rows show "nationwide"; place unused
  }
  if (residences[0].country === 'TW' && !COUNTY_LIST.some(c => c[0] === residences[0].place)) {
    residences[0].place = (COUNTY_LIST[0] || ['63000'])[0];
  }
  // LDL unit: default to mmol/L for countries that report it, else mg/dL; wire the toggle.
  const ldlUnitSel = $('in-ldl-unit');
  if (ldlUnitSel) {
    if (detectedIso && LDL_MMOL_COUNTRIES.has(String(detectedIso).toUpperCase())) ldlUnitSel.value = 'mmol';
    ldlUnitSel.addEventListener('change', onLdlUnitChange);
    applyLdlUnit();
  }

  applyOptionLangs();
  renderResidences();
  window.addEventListener('langchange', () => {
    applyOptionLangs();
    renderResidences();
    if (currentStep === 4 && lastResult) renderResults(lastResult);
    relabelMap();
  });
  initMap();
}
init();
</script>
