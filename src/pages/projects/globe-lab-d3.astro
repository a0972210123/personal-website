---
import BaseLayout from '../../layouts/BaseLayout.astro';
import T from '../../components/T.astro';
---
<BaseLayout
  title="Globe prototype · d3 orthographic — exposome"
  description="Prototype: global PM2.5 + modifiable-risk PAF on a d3-geo orthographic globe (lightweight, canvas, no WebGL)."
>
  <meta slot="head" name="robots" content="noindex" />

  <div class="container-wide globe-lab">
    <section class="gl-hero">
      <p class="gl-tag">PROTOTYPE · d3-geo orthographic (canvas)</p>
      <h1><T zh="地球儀原型 — d3 正射投影" en="Globe prototype — d3 orthographic" /></h1>
      <p class="gl-sub">
        <T zh="輕量方案：d3-geo 正射投影畫到 canvas，可拖曳旋轉、無 WebGL。全球 PM2.5（近年）＋可調控失智風險 PAF（27 國）。皆為教育性模型估計。"
           en="Lightweight route: d3-geo orthographic drawn to canvas, drag-to-rotate, no WebGL. Global PM2.5 (recent) + modifiable-dementia-risk PAF (27 countries). Educational modelled estimates." />
      </p>
    </section>

    <div class="gl-toggle" id="gl-toggle">
      <button type="button" class="gl-btn is-active" data-metric="pm25"><T zh="PM2.5（近年）" en="PM2.5 (recent)" /></button>
      <button type="button" class="gl-btn" data-metric="paf"><T zh="可調控風險 PAF" en="Modifiable risk (PAF)" /></button>
    </div>

    <div class="globe-wrap" id="globe-wrap">
      <canvas id="globe"></canvas>
      <div class="globe-tip" id="globe-tip" hidden></div>
      <div class="globe-legend" id="globe-legend"></div>
    </div>
    <p class="gl-note">
      <T zh="※ 原型頁，未連到網站導覽。界線 © Natural Earth（public domain）｜PM2.5 © ACAG/WashU, CC BY 4.0｜PAF：Livingston 2024 相對風險 × 各國危險因子盛行率 — 模型估計。"
         en="※ Prototype page, not in site nav. Boundaries © Natural Earth (public domain) · PM2.5 © ACAG/WashU, CC BY 4.0 · PAF: Livingston 2024 RRs × national risk-factor prevalence — modelled." />
    </p>
  </div>
</BaseLayout>

<!-- vendored, self-hosted (Leaflet precedent). d3-array must precede d3-geo. -->
<script is:inline src="/vendor/d3-array.min.js"></script>
<script is:inline src="/vendor/d3-geo.min.js"></script>

<script>
  const d3 = window.d3;
  const RAMP = ['#ffeda0', '#fed976', '#feb24c', '#fd8d3c', '#f03b20', '#bd0026'];
  const METRICS = {
    pm25: { bins: [5, 10, 15, 25, 35], zh: 'PM2.5 µg/m³', en: 'PM2.5 µg/m³', unit: 'µg/m³', dec: 1 },
    paf:  { bins: [20, 24, 28, 32, 36], zh: '可調控失智風險 PAF %', en: 'Attributable dementia risk PAF %', unit: '%', dec: 1 },
  };
  const lang = () => (document.documentElement.getAttribute('data-lang') === 'en' ? 'en' : 'zh');
  const L = (zh, en) => (lang() === 'en' ? en : zh);
  const isDark = () => document.documentElement.getAttribute('data-theme') === 'dark';
  const noData = () => (isDark() ? '#2b3050' : '#e6e6e6');
  const oceanCol = () => (isDark() ? '#0b0d18' : '#eef3fb');
  const strokeCol = () => (isDark() ? '#2a2f4a' : '#ffffff');
  const sphereEdge = () => (isDark() ? '#3a4066' : '#c9d4e6');

  function colorFor(v, bins) {
    if (v == null || Number.isNaN(v)) return noData();
    for (let i = 0; i < bins.length; i++) if (v < bins[i]) return RAMP[i];
    return RAMP[bins.length];
  }

  const wrap = document.getElementById('globe-wrap');
  const canvas = document.getElementById('globe');
  const ctx = canvas.getContext('2d');
  const tip = document.getElementById('globe-tip');
  const legendEl = document.getElementById('globe-legend');
  const projection = d3.geoOrthographic().precision(0.4);
  const path = d3.geoPath(projection, ctx);
  const graticule = d3.geoGraticule10();
  let W = 0, H = 0, rotation = [-10, -15, 0], features = [], metric = 'pm25';
  let dragging = false, spin = true, hover = null, raf = null;

  projection.rotate(rotation);

  function resize() {
    const r = wrap.getBoundingClientRect();
    W = r.width; H = r.height;
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    canvas.width = W * dpr; canvas.height = H * dpr;
    canvas.style.width = W + 'px'; canvas.style.height = H + 'px';
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    projection.fitExtent([[14, 14], [W - 14, H - 14]], { type: 'Sphere' });
    draw();
  }

  function draw() {
    if (!W) return;
    ctx.clearRect(0, 0, W, H);
    // ocean sphere
    ctx.beginPath(); path({ type: 'Sphere' }); ctx.fillStyle = oceanCol(); ctx.fill();
    // graticule
    ctx.beginPath(); path(graticule);
    ctx.strokeStyle = isDark() ? 'rgba(255,255,255,0.05)' : 'rgba(0,0,0,0.05)';
    ctx.lineWidth = 0.5; ctx.stroke();
    // countries
    const bins = METRICS[metric].bins;
    for (const f of features) {
      ctx.beginPath(); path(f);
      ctx.fillStyle = colorFor(f.properties[metric], bins);
      ctx.fill();
      ctx.lineWidth = f === hover ? 1.4 : 0.4;
      ctx.strokeStyle = f === hover ? (isDark() ? '#fff' : '#111') : strokeCol();
      ctx.stroke();
    }
    // sphere edge
    ctx.beginPath(); path({ type: 'Sphere' });
    ctx.strokeStyle = sphereEdge(); ctx.lineWidth = 1; ctx.stroke();
  }

  function tick() {
    raf = requestAnimationFrame(tick);
    if (spin && !dragging) {
      rotation[0] += 0.18;
      projection.rotate(rotation);
      draw();
    }
  }

  // ── interaction: drag to rotate ──
  let last = null;
  wrap.addEventListener('pointerdown', (e) => { dragging = true; last = [e.clientX, e.clientY]; wrap.setPointerCapture(e.pointerId); });
  wrap.addEventListener('pointerup', () => { dragging = false; last = null; });
  wrap.addEventListener('pointerleave', () => { hover = null; tip.hidden = true; });
  wrap.addEventListener('pointermove', (e) => {
    if (dragging && last) {
      const k = 0.3;
      rotation[0] += (e.clientX - last[0]) * k;
      rotation[1] = Math.max(-90, Math.min(90, rotation[1] - (e.clientY - last[1]) * k));
      last = [e.clientX, e.clientY];
      projection.rotate(rotation);
      draw();
      return;
    }
    // hover tooltip
    const rect = canvas.getBoundingClientRect();
    const p = projection.invert([e.clientX - rect.left, e.clientY - rect.top]);
    let found = null;
    if (p && Number.isFinite(p[0])) {
      for (const f of features) if (d3.geoContains(f, p)) { found = f; break; }
    }
    if (found !== hover) { hover = found; draw(); }
    if (found) {
      const m = METRICS[metric], v = found.properties[metric];
      tip.innerHTML = `<b>${found.properties.name}</b><br>${L(m.zh, m.en)}: ` +
        (v == null ? L('無資料', 'no data') : `${(+v).toFixed(m.dec)} ${m.unit}`);
      tip.hidden = false;
      tip.style.left = Math.min(W - 150, e.clientX - rect.left + 12) + 'px';
      tip.style.top = (e.clientY - rect.top + 12) + 'px';
    } else { tip.hidden = true; }
  });
  wrap.addEventListener('pointerdown', () => { spin = false; });   // stop auto-spin once user interacts

  // ── legend ──
  function buildLegend() {
    const m = METRICS[metric], bins = m.bins;
    const rows = [];
    for (let i = 0; i <= bins.length; i++) {
      const lo = i === 0 ? 0 : bins[i - 1];
      const label = i === bins.length ? `${bins[i - 1]}+` : `${lo}–${bins[i]}`;
      rows.push(`<span class="lg-row"><i style="background:${RAMP[i]}"></i>${label}</span>`);
    }
    legendEl.innerHTML = `<div class="lg-title">${L(m.zh, m.en)}</div>` + rows.join('');
  }

  // ── mode toggle ──
  document.getElementById('gl-toggle').addEventListener('click', (e) => {
    const b = e.target.closest('[data-metric]'); if (!b) return;
    metric = b.dataset.metric;
    document.querySelectorAll('#gl-toggle .gl-btn').forEach((x) => x.classList.toggle('is-active', x === b));
    buildLegend(); draw();
  });

  // theme + language reactivity
  new MutationObserver(draw).observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });
  window.addEventListener('langchange', () => { buildLegend(); });
  window.addEventListener('resize', resize);

  fetch('/data/geo/world-globe.geojson').then((r) => r.json()).then((geo) => {
    features = geo.features;
    resize(); buildLegend(); tick();
  }).catch((err) => { legendEl.textContent = 'load error: ' + err; });
</script>

<style>
  .globe-lab { padding-top: var(--spacing-lg); padding-bottom: var(--spacing-xl); }
  .gl-tag { font-size: 0.72rem; letter-spacing: 0.08em; color: var(--color-accent); font-weight: 700; margin-bottom: 0.3rem; }
  .gl-hero h1 { font-size: clamp(1.6rem, 4vw, 2.2rem); margin-bottom: 0.5rem; }
  .gl-sub { color: var(--color-text-muted); font-size: 0.95rem; line-height: 1.7; max-width: 640px; }
  .gl-toggle { display: flex; gap: 0.5rem; margin: 1.2rem 0 0.7rem; flex-wrap: wrap; }
  .gl-btn {
    font: inherit; font-size: 0.82rem; font-weight: 600; cursor: pointer;
    padding: 0.4rem 0.9rem; border-radius: 999px;
    border: 1px solid var(--color-border); background: var(--color-surface); color: var(--color-text-muted);
    transition: border-color 0.15s, color 0.15s;
  }
  .gl-btn:hover { border-color: var(--color-accent); color: var(--color-text); }
  .gl-btn.is-active { border-color: var(--color-accent); color: #fff; background: var(--color-accent); }
  .globe-wrap {
    position: relative; height: 460px; border: 1px solid var(--color-border);
    border-radius: var(--radius-md); background: var(--color-surface); overflow: hidden;
    touch-action: none; cursor: grab;
  }
  .globe-wrap:active { cursor: grabbing; }
  #globe { display: block; width: 100%; height: 100%; }
  .globe-tip {
    position: absolute; pointer-events: none; z-index: 5;
    background: var(--card-bg); border: 1px solid var(--card-border); box-shadow: var(--card-shadow);
    color: var(--color-text); font-size: 0.8rem; line-height: 1.4; padding: 0.35rem 0.55rem; border-radius: 8px;
    max-width: 190px;
  }
  .globe-legend {
    position: absolute; right: 12px; bottom: 12px; z-index: 4;
    background: var(--card-bg); border: 1px solid var(--card-border); box-shadow: var(--card-shadow);
    border-radius: 8px; padding: 0.5rem 0.6rem; font-size: 0.72rem; color: var(--color-text);
    display: flex; flex-direction: column; gap: 0.18rem;
  }
  .globe-legend .lg-title { font-weight: 700; margin-bottom: 0.15rem; }
  .globe-legend .lg-row { display: flex; align-items: center; gap: 0.4rem; }
  .globe-legend i { width: 0.85rem; height: 0.85rem; border-radius: 2px; display: inline-block; }
  .gl-note { margin-top: 0.8rem; font-size: 0.78rem; color: var(--color-text-muted); line-height: 1.6; }
</style>
