---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import T from '../../../components/T.astro';
import { marketingUnits as docs } from '../../../data/marketing';
---
<BaseLayout
  title="行銷專欄 Marketing Column — Matt Ye"
  description="葉淨維 Matt Ye 的行銷專欄：52 週行銷學習地圖的公開筆記，涵蓋平台演算法、短影音、開發者行銷到品牌策略。"
>
  <section class="mkt-hero">
    <a href="/projects" class="back-link"><T zh="← 其他作品" en="← Side Projects" /></a>
    <h1><T zh="行銷" en="Marketing" /> <span class="accent-text"><T zh="專欄" en="Column" /></span></h1>
    <p class="mkt-subtitle"><T zh="一年 52 週的行銷學習地圖，每週一個可實作的單元。" en="A 52-week marketing learning roadmap — one actionable unit at a time." /></p>
  </section>

  <div class="docs-grid">
    {docs.map(doc => (
      <a href={doc.url ?? `/projects/marketing/${doc.slug}`} class="doc-card">
        <div class="doc-card-body">
          <h2 class="doc-title"><T zh={doc.title} en={doc.titleEn} /></h2>
          <p class="doc-desc">{doc.description}</p>
        </div>
        <div class="doc-footer">
          <div class="doc-tags">
            {doc.tags.map(tag => <span class="doc-tag">{tag}</span>)}
          </div>
          <span class="doc-link"><T zh="閱讀 →" en="Read →" /></span>
        </div>
      </a>
    ))}
  </div>
</BaseLayout>

<style>
  .mkt-hero {
    padding: 3rem 0 2rem;
  }

  .back-link {
    display: inline-block;
    font-size: 0.85rem;
    color: var(--color-text-muted);
    text-decoration: none;
    margin-bottom: 1rem;
  }

  .back-link:hover {
    color: var(--color-text);
  }

  .mkt-hero h1 {
    font-size: clamp(2rem, 5vw, 2.8rem);
    font-weight: 700;
    margin: 0 0 0.5rem;
  }

  .mkt-subtitle {
    color: var(--color-text-muted);
    font-size: 1.05rem;
    margin: 0;
  }

  .docs-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
    padding-bottom: 4rem;
  }

  .doc-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    text-decoration: none;
    color: inherit;
    transition: box-shadow 0.2s, border-color 0.2s;
  }

  .doc-card:hover {
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
    border-color: var(--color-accent);
  }

  .doc-card-body {
    flex: 1;
  }

  .doc-title {
    font-size: 1.1rem;
    font-weight: 600;
    margin: 0 0 0.15rem;
  }

  .doc-desc {
    font-size: 0.92rem;
    color: var(--color-text-muted);
    line-height: 1.65;
    margin: 0;
  }

  .doc-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .doc-tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .doc-tag {
    font-size: 0.72rem;
    background: var(--color-border);
    color: var(--color-text-muted);
    padding: 0.15rem 0.5rem;
    border-radius: 99px;
  }

  .doc-link {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-accent);
    white-space: nowrap;
  }
</style>
