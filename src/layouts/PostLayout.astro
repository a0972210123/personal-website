---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  lang?: 'zh' | 'en';
  tags?: string[];
}

const { title, description, pubDate, lang = 'zh', tags } = Astro.props;

const htmlLang = lang === 'zh' ? 'zh-TW' : 'en';

const dateFormatted = pubDate.toLocaleDateString(
  lang === 'zh' ? 'zh-TW' : 'en-US',
  { year: 'numeric', month: 'long', day: 'numeric' }
);
---
<BaseLayout title={title} description={description} lang={htmlLang} ogType="article">
  <a href="/writing" class="back-link">← Writing</a>

  <header class="post-page-header">
    <h1>{title}</h1>
    <div class="post-meta">
      <time datetime={pubDate.toISOString()}>{dateFormatted}</time>
      <span class="lang-badge">{lang === 'zh' ? '中' : 'EN'}</span>
      {tags && tags.length > 0 && (
        <div class="tags">
          {tags.map(tag => <span class="tag">{tag}</span>)}
        </div>
      )}
    </div>
  </header>

  <article class="prose">
    <slot />
  </article>

  <!-- Tab switching + lazy Mermaid for diagram posts -->
  <script is:inline>
  (function() {
    function initTabs() {
      document.querySelectorAll('.dtabs').forEach(function(tabs) {
        tabs.querySelectorAll('.dtab-btn').forEach(function(btn) {
          btn.addEventListener('click', function() {
            var panelId = btn.dataset.panel;
            tabs.querySelectorAll('.dtab-btn').forEach(function(b) { b.classList.remove('dtab-active'); });
            tabs.querySelectorAll('.dtab-panel').forEach(function(p) { p.classList.remove('dtab-active'); });
            btn.classList.add('dtab-active');
            document.getElementById(panelId).classList.add('dtab-active');
            if (panelId === 'panel-flow' && window.__renderMermaid) {
              window.__renderMermaid();
            }
          });
        });
      });
    }

    function initMermaid() {
      if (!document.querySelector('.mermaid')) return;
      var rendered = false;
      window.__renderMermaid = function() {
        if (rendered) return;
        rendered = true;
        import('https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs').then(function(m) {
          m.default.initialize({
            startOnLoad: false,
            theme: 'base',
            securityLevel: 'loose',
            themeVariables: { fontFamily: 'inherit', fontSize: '13px' }
          });
          m.default.run({ querySelector: '#panel-flow .mermaid' });
        }).catch(function(e) { console.warn('Mermaid failed:', e); });
      };
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', function() { initTabs(); initMermaid(); });
    } else {
      initTabs(); initMermaid();
    }
  })();
  </script>
</BaseLayout>
