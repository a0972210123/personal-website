---
interface Props {
  id: string;
  title: string;
  description: string;
  pubDate: Date;
  lang: 'zh' | 'en';
  series?: string;
}

const { id, title, description, pubDate, lang, series } = Astro.props;

const dateFormatted = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---
<li class="post-card" data-series={series ?? ''}>
  <div class="post-card-header">
    <a href={`/writing/${id}`} class="post-card-title">{title}</a>
    <span class="post-card-date">
      <time datetime={pubDate.toISOString()}>{dateFormatted}</time>
    </span>
    <span class="lang-badge">{lang === 'zh' ? '中' : 'EN'}</span>
  </div>
  <p class="post-card-desc">{description}</p>
</li>
